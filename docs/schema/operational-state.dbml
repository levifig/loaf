// Loaf operational state schema.
// Source of truth: internal/state/migrations/*.sql.
// This mirror is guarded by TestSchemaDocumentationMirrorsExecutableMigration.

Table schema_migrations {
  version integer [pk, not null]
  name text [not null]
  checksum text [not null]
  applied_at text [not null]
}

Table projects {
  id text [pk, not null]
  identity_hash text [not null, unique]
  created_at text [not null]
  updated_at text [not null]
  friendly_name text
  current_path text
  last_seen_at text
}

Table project_paths {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  path text [not null, unique]
  is_current integer [not null]
  first_seen_at text [not null]
  last_seen_at text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, is_current)
    (project_id) [unique, note: 'where is_current = 1']
  }
}

Table aliases {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  entity_kind text [not null]
  entity_id text [not null]
  namespace text [not null]
  alias text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, namespace, alias) [unique]
    (project_id, entity_kind, entity_id)
  }
}

Table specs {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table tasks {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  spec_id text [ref: > specs.id]
  title text [not null]
  status text [not null]
  priority text
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, spec_id)
  }
}

Table ideas {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table sparks {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  scope text
  status text [not null]
  text text [not null]
  source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table brainstorms {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table shaping_drafts {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table sessions {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  harness_session_id text
  branch text
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table session_state_snapshots {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  session_id text [not null, ref: > sessions.id]
  content text [not null]
  observed_branch text
  observed_worktree text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, session_id) [unique]
    (project_id, session_id)
  }
}

Table artifact_bodies {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  entity_kind text [not null]
  entity_id text [not null]
  body_kind text [not null, default: 'markdown']
  content text [not null]
  content_hash text [not null]
  source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, entity_kind, entity_id, body_kind) [unique]
    (project_id, entity_kind, entity_id)
    (project_id, source_id)
  }
}

Table artifact_search {
  rowid integer [pk]
  project_id text
  entity_kind text
  entity_id text
  body_kind text
  content text
}

Table journal_search {
  rowid integer [pk]
  project_id text
  journal_entry_id text
  session_id text
  entry_type text
  scope text
  message text
}

Table reports {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  report_kind text [not null]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
}

Table runs {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  generator_ref text [not null]
  generator_version text
  generator_hash text
  status text [not null]
  metadata text
  started_at text
  completed_at text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, generator_ref, status)
  }
}

Table findings {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  report_id text [not null, ref: > reports.id]
  run_id text [ref: > runs.id]
  title text [not null]
  status text [not null]
  severity text [not null]
  confidence text [not null]
  dimension text
  path text
  line_start integer
  line_end integer
  symbol text
  metadata text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, report_id)
    (project_id, run_id)
    (project_id, severity, status, confidence)
  }
}

Table verdicts {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  finding_id text [not null, ref: > findings.id]
  run_id text [ref: > runs.id]
  outcome text [not null]
  rationale text [not null]
  reproduction_notes text
  metadata text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, finding_id)
    (project_id, run_id)
  }
}

Table plans {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  spec_id text [ref: > specs.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, spec_id)
  }
}

Table handoffs {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  session_id text [ref: > sessions.id]
  task_id text [ref: > tasks.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, session_id, task_id)
  }
}

Table councils {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  spec_id text [ref: > specs.id]
  title text [not null]
  status text [not null]
  body_source_id text [ref: > sources.id]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, spec_id)
  }
}

Table journal_entries {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  entry_type text [not null]
  scope text
  message text [not null]
  observed_branch text
  observed_worktree text
  harness_session_id text
  session_id text [ref: > sessions.id]
  spec_id text [ref: > specs.id]
  task_id text [ref: > tasks.id]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, session_id, spec_id, task_id)
  }
}

Table events {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  entity_kind text [not null]
  entity_id text [not null]
  event_type text [not null]
  from_status text
  to_status text
  note text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, entity_kind, entity_id)
  }
}

Table relationships {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  from_entity_kind text [not null]
  from_entity_id text [not null]
  to_entity_kind text [not null]
  to_entity_id text [not null]
  relationship_type text [not null]
  reason text
  created_at text [not null]
  updated_at text [not null]
  origin text
  source_id text
  source_field text
  indexes {
    (project_id, from_entity_kind, from_entity_id)
    (project_id, to_entity_kind, to_entity_id)
    (project_id, origin)
  }
}

Table tags {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  name text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, name) [unique]
  }
}

Table entity_tags {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  tag_id text [not null, ref: > tags.id]
  entity_kind text [not null]
  entity_id text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, tag_id, entity_kind, entity_id) [unique]
    (project_id, entity_kind, entity_id)
  }
}

Table bundles {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  slug text [not null]
  title text [not null]
  tag_query text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, slug) [unique]
  }
}

Table bundle_members {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  bundle_id text [not null, ref: > bundles.id]
  entity_kind text [not null]
  entity_id text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, bundle_id, entity_kind, entity_id) [unique]
  }
}

Table sources {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  source_kind text [not null]
  path text [not null]
  hash text
  line_start integer
  line_end integer
  imported_at text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, path)
  }
}

Table backend_mappings {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  backend text [not null]
  entity_kind text [not null]
  entity_id text [not null]
  external_kind text [not null]
  external_id text [not null]
  external_url text
  sync_status text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, backend, external_kind, external_id) [unique]
    (project_id, entity_kind, entity_id)
  }
}

Table hook_events {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  hook_id text [not null]
  hook_phase text [not null]
  command text
  exit_code integer
  message text
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, hook_id, hook_phase)
  }
}

Table exports {
  id text [pk, not null]
  project_id text [not null, ref: > projects.id]
  export_kind text [not null]
  format text [not null]
  path text [not null]
  state_version integer
  source_entity_kind text
  source_entity_id text
  generated_at text [not null]
  created_at text [not null]
  updated_at text [not null]
  indexes {
    (project_id, source_entity_kind, source_entity_id)
  }
}
