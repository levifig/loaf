{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook artifact-body-write",
        "timeout": 30,
        "failClosed": true,
        "blocking": true,
        "description": "Block direct .agents artifact body writes that bypass SQLite registration"
      },
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook check-secrets",
        "timeout": 30,
        "failClosed": true,
        "blocking": true,
        "description": "Check for hardcoded secrets before writing"
      },
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook security-audit",
        "timeout": 600,
        "failClosed": true,
        "blocking": true,
        "description": "Run security audit on bash commands"
      },
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook render-drift",
        "timeout": 30,
        "failClosed": true,
        "blocking": true,
        "if": "Bash(git push:*)",
        "description": "Validate stamped durable renders are self-consistent before push"
      },
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook validate-push",
        "timeout": 60,
        "failClosed": false,
        "blocking": false,
        "if": "Bash(git push:*)",
        "description": "Validates version bump, CHANGELOG, and build before git push"
      },
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook workflow-pre-pr",
        "timeout": 5,
        "failClosed": false,
        "blocking": false,
        "if": "Bash(gh pr create:*)",
        "description": "Remind about PR format and CHANGELOG entry before gh pr create"
      },
      {
        "loaf-managed": true,
        "matcher": "Bash",
        "command": "loaf check --hook validate-commit",
        "timeout": 30,
        "failClosed": true,
        "blocking": true,
        "if": "Bash(git commit:*)",
        "description": "Validate commit messages follow conventions"
      }
    ]
  }
}