{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Edit|Write|Bash",
        "failClosed": true,
        "command": "loaf check --hook check-secrets"
      },
      {
        "loaf-managed": true,
        "timeout": 600,
        "matcher": "Bash",
        "failClosed": true,
        "command": "loaf check --hook security-audit"
      },
      {
        "loaf-managed": true,
        "timeout": 60,
        "matcher": "Bash",
        "command": "loaf check --hook validate-push",
        "if": "Bash(git push:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "loaf check --hook workflow-pre-pr",
        "if": "Bash(gh pr create:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "cat \"$HOME/.cursor/hooks/instructions/pre-merge.md\"",
        "if": "Bash(gh pr merge:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "cat \"$HOME/.cursor/hooks/instructions/pre-push.md\"",
        "if": "Bash(git push:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "failClosed": true,
        "command": "loaf check --hook validate-commit",
        "if": "Bash(git commit:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --detect-linear",
        "if": "Bash(git commit:*)"
      }
    ],
    "postToolUse": [
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Edit|Write",
        "command": "loaf task refresh"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Edit|Write",
        "command": "bash $HOME/.cursor/hooks/post-tool/kb-staleness-nudge.sh"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "cat \"$HOME/.cursor/hooks/instructions/post-merge.md\"",
        "if": "Bash(gh pr merge:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --from-hook",
        "if": "Bash(git commit:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --from-hook",
        "if": "Bash(gh pr create:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --from-hook",
        "if": "Bash(gh pr merge:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Edit|Write",
        "prompt": "SESSION JOURNAL NUDGE: file changes made"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "prompt": "SESSION JOURNAL NUDGE: code committed. The commit is already auto-logged — no need to log it again. Instead, log any related decisions or observations that aren't captured by the commit message.",
        "if": "Bash(git commit:*)"
      }
    ],
    "sessionStart": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "loaf session start"
      }
    ],
    "sessionEnd": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "loaf session end --if-active"
      }
    ],
    "preCompact": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "bash $HOME/.cursor/hooks/session/compact.sh"
      },
      {
        "loaf-managed": true,
        "timeout": 60,
        "prompt": "CONTEXT COMPACTION IMMINENT: Your conversation context will be compacted soon.\nREQUIRED — two actions before the model responds:\n1. **Flush journal entries.** Log all unrecorded decisions, discoveries, and progress:\n   - `decision(scope): key decisions made this session`\n   - `discover(scope): important findings`\n   - `conclude(scope): session summary`\n   Run `loaf session log \"type(scope): description\"` for each.\n\n2. **Write state summary.** Update the session file's `## Current State` section\n   with a condensed summary of: what was accomplished, current work state,\n   key decisions, git state, and next steps. This section is the resumption\n   context after compaction — write it as if briefing a colleague who just\n   walked in.\n\nThe journal IS your external memory. Entries not flushed now are lost forever."
      }
    ],
    "postCompact": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "bash $HOME/.cursor/hooks/session/post-compact.sh"
      }
    ]
  }
}