{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Edit|Write|Bash",
        "failClosed": true,
        "command": "loaf check --hook check-secrets"
      },
      {
        "loaf-managed": true,
        "timeout": 600,
        "matcher": "Bash",
        "failClosed": true,
        "command": "loaf check --hook security-audit"
      },
      {
        "loaf-managed": true,
        "timeout": 60,
        "matcher": "Bash",
        "command": "loaf check --hook validate-push",
        "if": "Bash(git push:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "loaf check --hook workflow-pre-pr",
        "if": "Bash(gh pr create:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "cat \"$HOME/.cursor/hooks/instructions/pre-merge.md\"",
        "if": "Bash(gh pr merge:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "cat \"$HOME/.cursor/hooks/instructions/pre-push.md\"",
        "if": "Bash(git push:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "failClosed": true,
        "command": "loaf check --hook validate-commit",
        "if": "Bash(git commit:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --detect-linear",
        "if": "Bash(git commit:*)"
      }
    ],
    "postToolUse": [
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Edit|Write",
        "command": "loaf task refresh"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Edit|Write",
        "command": "bash $HOME/.cursor/hooks/post-tool/kb-staleness-nudge.sh"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "command": "cat \"$HOME/.cursor/hooks/instructions/post-merge.md\"",
        "if": "Bash(gh pr merge:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --from-hook",
        "if": "Bash(git commit:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --from-hook",
        "if": "Bash(gh pr create:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 30,
        "matcher": "Bash",
        "command": "loaf session log --from-hook",
        "if": "Bash(gh pr merge:*)"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Edit|Write",
        "prompt": "SESSION JOURNAL NUDGE: file changes made"
      },
      {
        "loaf-managed": true,
        "timeout": 5,
        "matcher": "Bash",
        "prompt": "SESSION JOURNAL NUDGE: code committed",
        "if": "Bash(git commit:*)"
      }
    ],
    "sessionStart": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "loaf session start"
      }
    ],
    "sessionEnd": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "loaf session end --if-active"
      }
    ],
    "preCompact": [
      {
        "loaf-managed": true,
        "timeout": 60,
        "command": "bash $HOME/.cursor/hooks/session/compact.sh"
      },
      {
        "loaf-managed": true,
        "timeout": 60,
        "prompt": "CONTEXT COMPACTION IMMINENT: Your conversation context will be compacted soon.\nREQUIRED: Flush all unrecorded journal entries NOW, before responding to the user. Do not defer — entries lost to compaction cannot be recovered.\nEntry types: - `decision(scope): key decisions made this session` - `discover(scope): important findings` - `conclude(scope): session summary`\nRun `loaf session log \"type(scope): description\"` for each entry, then continue."
      }
    ]
  }
}