{
  "name": "loaf",
  "version": "2.0.0-dev.47",
  "description": "Loaf - An Opinionated Agentic Framework for Claude Code, OpenCode, Cursor, Codex, and Gemini",
  "type": "module",
  "bin": {
    "loaf": "bin/loaf"
  },
  "exports": {
    ".": {
      "import": "./dist-cli/index.js"
    }
  },
  "files": [
    "bin/",
    "dist-cli/",
    "content/",
    "config/",
    "build/"
  ],
  "scripts": {
    "build:go": "node cli/scripts/build-go.mjs",
    "verify:go-artifacts": "node cli/scripts/verify-go-artifacts.mjs",
    "build:cli": "tsup",
    "build:cli-ref": "bun cli/scripts/generate-cli-ref.ts",
    "build:content": "node dist-cli/build-content.js",
    "build": "npm run build:cli-ref && npm run build:cli && npm run build:go && npm run build:content && npm run verify:go-artifacts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build:cli",
    "test": "vitest run",
    "test:smoke": "node cli/scripts/smoke-test.js",
    "eval:routing": "node cli/scripts/eval-skill-routing.mjs",
    "prepare": "npm run build:cli && npm run build:go",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levifig/loaf.git"
  },
  "author": "Levi Figueira",
  "license": "MIT",
  "keywords": [
    "ai",
    "agent",
    "skills",
    "cli",
    "claude",
    "cursor",
    "codex",
    "gemini"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
