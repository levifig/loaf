{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist-cli",
    "rootDir": "cli",
    "types": ["node"]
  },
  "include": ["cli/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-cli", "dist-backup", "cli/**/*.test.ts"]
}
