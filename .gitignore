# Dependencies
node_modules/

# Build output (committed by CI)
# dist/ - tracked (for OpenCode, Cursor, Codex, Gemini)
# plugins/ - tracked (for Claude Code marketplace)
# .claude-plugin/ - tracked (for Claude Code marketplace)

# CLI build output
dist-cli/

# Root-level build outputs (deprecated - use dist/)
/skills/
/agents/
/commands/
/hooks.json

# Temporary backups
dist-backup/
plugins-backup/

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Claude Code ephemeral plans
.claude/plans/

# Local agent work (tracked: project artifacts, not ephemeral state)
.agents/*
!.agents/AGENTS.md
!.agents/TASKS.json
!.agents/specs/
!.agents/tasks/
!.agents/sessions/
!.agents/ideas/
!.agents/drafts/
!.agents/councils/
!.agents/reports/

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Package manager locks (using npm)
yarn.lock
pnpm-lock.yaml
bun.lockb
