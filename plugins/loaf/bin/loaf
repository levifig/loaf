    targetName: TARGET_NAME3,
    version,
    targetsConfig,
    transformMd,
    mergeFrontmatter
  });
  generateCodexHooksJson(config, distDir);
}
function generateCodexHooksJson(config, distDir) {
  const preToolHooks = config.hooks["pre-tool"] || [];
  const enforcementHooks = preToolHooks.filter((hook) => {
    if (!ENFORCEMENT_HOOKS2.has(hook.id)) return false;
    const matcher = hook.matcher || "";
    return matcher.includes("Bash");
  });
  if (enforcementHooks.length === 0) {
    return;
  }
  const hooksJson = {
    version: 1,
    hooks: {}
  };
  const hooks = hooksJson.hooks;
  hooks.PreToolUse = enforcementHooks.map((hook) => {
    const result = {
      [LOAF_HOOK_MARKER2]: true,
      matcher: "Bash",
      command: `loaf check --hook ${hook.id}`,
      timeout: Math.floor((hook.timeout || 3e4) / 1e3),
      failClosed: hook.failClosed !== false
      // Default to true for enforcement
    };
    if (hook.description) {
      result.description = hook.description;
    }
    return result;
  });
  const codexDir = join12(distDir, ".codex");
  mkdirSync10(codexDir, { recursive: true });
  writeFileSync9(
    join12(codexDir, "hooks.json"),
    JSON.stringify(hooksJson, null, 2)
  );
}

