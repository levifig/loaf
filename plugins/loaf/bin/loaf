// cli/lib/cleanup/scanner.ts
function readMdFiles(dir) {
  if (!existsSync29(dir)) return [];
  const results = [];
  let entries;
  try {
    entries = readdirSync13(dir);
  } catch {
    return results;
  }
  for (const name of entries) {
    if (name === "archive" || !name.endsWith(".md")) continue;
    const filePath = join33(dir, name);
    try {
      if (!statSync2(filePath).isFile()) continue;
      const raw = readFileSync25(filePath, "utf-8");
      const { data } = matter11(raw);
      results.push({ path: filePath, filename: name, frontmatter: data, raw });
    } catch {
      continue;
    }
  }
  return results;
}
function daysSince(dateStr) {
  if (!dateStr) return null;
  const date = new Date(dateStr);
  if (isNaN(date.getTime())) return null;
  return Math.floor((Date.now() - date.getTime()) / (1e3 * 60 * 60 * 24));
}
function normalizeSessionRef(ref) {
  return ref.replace(/^\.agents\/sessions\/(archive\/)?/, "");
}
function lastActivity(fm) {
  const sessionBlock = fm.session;
  if (sessionBlock && typeof sessionBlock === "object") {
    return sessionBlock.last_updated || sessionBlock.created || void 0;
  }
  return fm.updated || fm.created || void 0;
}
function getStatus(fm) {
  const sessionBlock = fm.session;
  if (sessionBlock && typeof sessionBlock === "object" && sessionBlock.status) {
    return String(sessionBlock.status).toLowerCase();
  }
  return String(fm.status || "").toLowerCase();
}
function scanSessions(agentsDir) {
  const dir = join33(agentsDir, "sessions");
  const files = readMdFiles(dir);
  const recs = [];
  for (const file of files) {
    const fm = file.frontmatter;
    const status = getStatus(fm);
    const hasLearnings = file.raw.includes("## Key Decisions") || file.raw.includes("## Lessons Learned") || file.raw.includes("lessons_learned") || fm.traceability && typeof fm.traceability === "object" && "decisions" in fm.traceability;
    if (status === "completed" || status === "complete") {
      if (hasLearnings) {
        recs.push({
          type: "session",
          path: file.path,
          filename: file.filename,
          action: "archive",
          reason: "Completed session with extractable learnings",
          hint: "Consider running /crystallize before archiving",
          frontmatter: fm
        });
      } else {
        recs.push({
          type: "session",
          path: file.path,
          filename: file.filename,
          action: "archive",
          reason: "Completed session",
          frontmatter: fm
        });
      }
    } else if (status === "cancelled" || status === "abandoned") {
      recs.push({
        type: "session",
        path: file.path,
        filename: file.filename,
        action: "archive",
        reason: `Session ${status} \u2014 archive with status preserved`,
        frontmatter: fm
      });
    } else {
      const days = daysSince(lastActivity(fm));
      if (days !== null && days > 7) {
        recs.push({
          type: "session",
          path: file.path,
          filename: file.filename,
          action: "flag",
          reason: `Stale session \u2014 inactive for ${days} days`,
          frontmatter: fm
        });
      } else {
        recs.push({
          type: "session",
          path: file.path,
          filename: file.filename,
          action: "skip",
          reason: "Active session",
          frontmatter: fm
        });
      }
    }
  }
  return recs;
}
function scanTasks(agentsDir, index) {
  const recs = [];
  const knownSpecIds = new Set(Object.keys(index.specs));
  for (const [id, entry] of Object.entries(index.tasks)) {
    if (entry.file.startsWith("archive/")) continue;
    const filePath = join33(agentsDir, "tasks", entry.file);
    if (entry.status === "done") {
      recs.push({
        type: "task",
        path: filePath,
        filename: entry.file,
        action: "archive",
        reason: `Task ${id} is done`,
        frontmatter: { id, title: entry.title, status: entry.status, spec: entry.spec }
      });
    } else if (entry.spec && !knownSpecIds.has(entry.spec)) {
      recs.push({
        type: "task",
        path: filePath,
        filename: entry.file,
        action: "flag",
        reason: `Task ${id} references missing spec ${entry.spec}`,
        frontmatter: { id, title: entry.title, status: entry.status, spec: entry.spec }
      });
    } else {
      recs.push({
        type: "task",
        path: filePath,
        filename: entry.file,
        action: "skip",
        reason: `Task ${id} is ${entry.status}`,
        frontmatter: { id, title: entry.title, status: entry.status }
      });
    }
  }
  const orphans = findOrphans(agentsDir, index);
  for (const orphan of orphans.tasks) {
    recs.push({
      type: "task",
      path: join33(agentsDir, "tasks", orphan.entry.file),
      filename: orphan.entry.file,
      action: "flag",
      reason: `Task ${orphan.id} exists on disk but not in index \u2014 run loaf task sync --import`,
      frontmatter: { id: orphan.id, title: orphan.entry.title }
    });
  }
  return recs;
}
function scanSpecs(agentsDir, index) {
  const recs = [];
  for (const [id, entry] of Object.entries(index.specs)) {
    if (entry.file.startsWith("archive/")) continue;
    const filePath = join33(agentsDir, "specs", entry.file);
    if (entry.status === "complete") {
      recs.push({
        type: "spec",
        path: filePath,
        filename: entry.file,
        action: "archive",
        reason: `Spec ${id} is complete`,
        frontmatter: { id, title: entry.title, status: entry.status }
      });
    } else if (entry.status === "drafting") {
      const days = daysSince(entry.created);
      if (days !== null && days > 14) {
        recs.push({
          type: "spec",
          path: filePath,
          filename: entry.file,
          action: "flag",
          reason: `Spec ${id} has been drafting for ${days} days`,
          frontmatter: { id, title: entry.title, status: entry.status }
        });
      } else {
        recs.push({
          type: "spec",
          path: filePath,
          filename: entry.file,
          action: "skip",
          reason: `Spec ${id} is ${entry.status}`,
          frontmatter: { id, title: entry.title, status: entry.status }
        });
      }
    } else {
      recs.push({
        type: "spec",
        path: filePath,
        filename: entry.file,
        action: "skip",
        reason: `Spec ${id} is ${entry.status}`,
        frontmatter: { id, title: entry.title, status: entry.status }
      });
    }
  }
  const orphans = findOrphans(agentsDir, index);
  for (const orphan of orphans.specs) {
    recs.push({
      type: "spec",
      path: join33(agentsDir, "specs", orphan.entry.file),
      filename: orphan.entry.file,
      action: "flag",
      reason: `Spec ${orphan.id} exists on disk but not in index \u2014 run loaf task sync --import`,
      frontmatter: { id: orphan.id, title: orphan.entry.title }
    });
  }
  return recs;
}
function scanPlans(agentsDir) {
  const dir = join33(agentsDir, "plans");
  const files = readMdFiles(dir);
  const recs = [];
  const sessionsDir = join33(agentsDir, "sessions");
  const activeSessionFiles = [];
  const archivedSessionFiles = [];
  if (existsSync29(sessionsDir)) {
    for (const name of readdirSync13(sessionsDir)) {
      if (name === "archive" || !name.endsWith(".md")) continue;
      try {
        const raw = readFileSync25(join33(sessionsDir, name), "utf-8");
        const { data } = matter11(raw);
        const status = getStatus(data);
        if (status === "completed" || status === "complete" || status === "cancelled" || status === "archived") {
          archivedSessionFiles.push(name);
        } else {
          activeSessionFiles.push(name);
        }
      } catch {
        continue;
      }
    }
  }
  const sessionArchive = join33(sessionsDir, "archive");
  if (existsSync29(sessionArchive)) {
    try {
      for (const name of readdirSync13(sessionArchive)) {
        if (name.endsWith(".md")) archivedSessionFiles.push(name);
      }
    } catch {
    }
  }
  const matchesSession = (ref, files2) => {
    if (files2.includes(ref)) return true;
    const stem = ref.replace(/\.md$/, "");
    return files2.some((f) => f.startsWith(stem));
  };
  for (const file of files) {
    const fm = file.frontmatter;
    const sessionRef = fm.session;
    if (!sessionRef) {
      recs.push({
        type: "plan",
        path: file.path,
        filename: file.filename,
        action: "delete",
        reason: "Orphaned plan \u2014 no linked session",
        frontmatter: fm
      });
    } else if (matchesSession(sessionRef, archivedSessionFiles)) {
      recs.push({
        type: "plan",
        path: file.path,
        filename: file.filename,
        action: "delete",
        reason: "Linked session is archived/completed",
        frontmatter: fm
      });
    } else if (!matchesSession(sessionRef, activeSessionFiles)) {
      recs.push({
        type: "plan",
        path: file.path,
        filename: file.filename,
        action: "delete",
        reason: `Linked session "${sessionRef}" not found`,
        frontmatter: fm
      });
    } else {
      const days = daysSince(lastActivity(fm));
      if (days !== null && days > 14) {
        recs.push({
          type: "plan",
          path: file.path,
          filename: file.filename,
          action: "delete",
          reason: `Stale plan \u2014 inactive for ${days} days with active session`,
          frontmatter: fm
        });
      } else {
        recs.push({
          type: "plan",
          path: file.path,
          filename: file.filename,
          action: "skip",
          reason: "Plan linked to active session",
          frontmatter: fm
        });
      }
    }
  }
  return recs;
}
function scanDrafts(agentsDir, index) {
  const dir = join33(agentsDir, "drafts");
  const files = readMdFiles(dir);
  const recs = [];
  const promotedDrafts = /* @__PURE__ */ new Set();
  for (const entry of Object.values(index.specs)) {
    if (entry.source && entry.source.includes("/drafts/")) {
      const filename = entry.source.replace(/^.*\/drafts\//, "");
      promotedDrafts.add(filename);
    }
  }
  for (const file of files) {
    const fm = file.frontmatter;
    const days = daysSince(lastActivity(fm) || fm.created);
    if (promotedDrafts.has(file.filename)) {
      const hasSparks = file.raw.includes("## Sparks");
      recs.push({
        type: "draft",
        path: file.path,
        filename: file.filename,
        action: "delete",
        reason: "Draft promoted to spec \u2014 served its purpose",
        hint: hasSparks ? "Contains ## Sparks section \u2014 review before deletion" : void 0,
        frontmatter: fm
      });
    } else if (days !== null && days > 30) {
      const hasSparks = file.raw.includes("## Sparks");
      recs.push({
        type: "draft",
        path: file.path,
        filename: file.filename,
        action: "flag",
        reason: `Stale draft \u2014 ${days} days old`,
        hint: hasSparks ? "Contains ## Sparks section \u2014 review before deletion" : void 0,
        frontmatter: fm
      });
    } else {
      recs.push({
        type: "draft",
        path: file.path,
        filename: file.filename,
        action: "skip",
        reason: "Recent draft",
        frontmatter: fm
      });
    }
  }
  return recs;
}
function scanCouncils(agentsDir) {
  const dir = join33(agentsDir, "councils");
  const files = readMdFiles(dir);
  const recs = [];
  const sessionsDir = join33(agentsDir, "sessions");
  const allSessionFiles = [];
  const completedSessionFiles = [];
  for (const subdir of [sessionsDir, join33(sessionsDir, "archive")]) {
    if (existsSync29(subdir)) {
      try {
        for (const name of readdirSync13(subdir)) {
          if (!name.endsWith(".md")) continue;
          allSessionFiles.push(name);
          try {
            const raw = readFileSync25(join33(subdir, name), "utf-8");
            const { data } = matter11(raw);
            const status = getStatus(data);
            if (["completed", "complete", "archived", "cancelled"].includes(status)) {
              completedSessionFiles.push(name);
            }
          } catch {
          }
        }
      } catch {
      }
    }
  }
  const matchesAnySession = (ref) => {
    if (allSessionFiles.includes(ref)) return true;
    const stem = ref.replace(/\.md$/, "");
    return allSessionFiles.some((f) => f.startsWith(stem));
  };
  const sessionIsCompleted = (ref) => {
    if (completedSessionFiles.includes(ref)) return true;
    const stem = ref.replace(/\.md$/, "");
    return completedSessionFiles.some((f) => f.startsWith(stem));
  };
  for (const file of files) {
    const fm = file.frontmatter;
    const councilBlock = fm.council;
    const councilDate = councilBlock?.created || councilBlock?.timestamp;
    const sessionRef = councilBlock?.session_reference || councilBlock?.session;
    const days = daysSince(councilDate || lastActivity(fm));
    if (sessionRef && !matchesAnySession(normalizeSessionRef(sessionRef))) {
      recs.push({
        type: "council",
        path: file.path,
        filename: file.filename,
        action: "flag",
        reason: `Orphaned council \u2014 linked session "${sessionRef}" not found`,
        frontmatter: fm
      });
    } else if (days !== null && days > 14) {
      const hasDecision = file.raw.includes("## Decision") && !file.raw.match(/## Decision\s*\n\s*\n\s*(\[To be filled|$)/);
      const normalizedRef = sessionRef ? normalizeSessionRef(sessionRef) : null;
      const sessionDone = normalizedRef && sessionIsCompleted(normalizedRef);
      if (hasDecision && sessionDone) {
        recs.push({
          type: "council",
          path: file.path,
          filename: file.filename,
          action: "archive",
          reason: `Council is ${days} days old \u2014 decision recorded, session completed`,
          hint: "Verify the linked session summary captures the council outcome before archiving",
          frontmatter: fm
        });
      } else {
        const reasons = [];
        if (!hasDecision) reasons.push("decision not yet recorded");
        if (!sessionRef) reasons.push("no linked session");
        else if (!sessionDone) reasons.push("linked session not yet completed");
        recs.push({
          type: "council",
          path: file.path,
          filename: file.filename,
          action: "flag",
          reason: `Stale council \u2014 ${days} days old, ${reasons.join(", ")}`,
          frontmatter: fm
        });
      }
    } else {
      recs.push({
        type: "council",
        path: file.path,
        filename: file.filename,
        action: "skip",
        reason: "Recent council",
        frontmatter: fm
      });
    }
  }
  return recs;
}
function scanReports(agentsDir) {
  const dir = join33(agentsDir, "reports");
  const files = readMdFiles(dir);
  const recs = [];
  const sessionArchiveDir = join33(agentsDir, "sessions", "archive");
  const archivedSessionFiles = [];
  if (existsSync29(sessionArchiveDir)) {
    try {
      for (const name of readdirSync13(sessionArchiveDir)) {
        if (name.endsWith(".md")) archivedSessionFiles.push(name);
      }
    } catch {
    }
  }
  const sessionIsArchived = (ref) => {
    if (archivedSessionFiles.includes(ref)) return true;
    const stem = ref.replace(/\.md$/, "");
    return archivedSessionFiles.some((f) => f.startsWith(stem));
  };
  for (const file of files) {
    const fm = file.frontmatter;
    const reportBlock = fm.report;
    const archivedAt = reportBlock?.archived_at || fm.archived_at;
    const reportStatus = reportBlock?.status;
    const processedAt = reportBlock?.processed_at;
    const sessionRef = reportBlock?.session_reference;
    if (archivedAt) {
      recs.push({
        type: "report",
        path: file.path,
        filename: file.filename,
        action: "skip",
        reason: "Already archived",
        frontmatter: fm
      });
    } else if (reportStatus === "processed" || processedAt) {
      if (!sessionRef) {
        recs.push({
          type: "report",
          path: file.path,
          filename: file.filename,
          action: "flag",
          reason: "Report is processed but missing session_reference \u2014 repair metadata",
          frontmatter: fm
        });
      } else if (!sessionIsArchived(normalizeSessionRef(sessionRef))) {
        recs.push({
          type: "report",
          path: file.path,
          filename: file.filename,
          action: "skip",
          reason: "Report is processed but linked session is not yet archived",
          frontmatter: fm
        });
      } else {
        recs.push({
          type: "report",
          path: file.path,
          filename: file.filename,
          action: "archive",
          reason: "Report is processed and prerequisites met \u2014 ready for archive",
          frontmatter: fm
        });
      }
    } else {
      const days = daysSince(lastActivity(fm));
      if (days !== null && days > 14) {
        recs.push({
          type: "report",
          path: file.path,
          filename: file.filename,
          action: "flag",
          reason: `Report is ${days} days old but not yet processed`,
          frontmatter: fm
        });
      } else {
        recs.push({
          type: "report",
          path: file.path,
          filename: file.filename,
          action: "skip",
          reason: "Recent report",
          frontmatter: fm
        });
      }
    }
  }
  return recs;
}
function scanArtifacts(options) {
  const { agentsDir, filter } = options;
  const recommendations = [];
  const warnings = [];
  for (const dir of ARTIFACT_DIRS) {
    if (filter && !filter.includes(dir.type)) continue;
    const fullPath = join33(agentsDir, dir.dirname);
    if (!existsSync29(fullPath)) {
      if (dir.required) {
        warnings.push(`Required directory missing: ${dir.dirname}/`);
      }
    }
  }
  const indexPath = join33(agentsDir, "TASKS.json");
  const index = loadIndex(indexPath) ?? buildIndexFromFiles(agentsDir);
  const shouldScan = (type) => !filter || filter.includes(type);
  if (shouldScan("session")) recommendations.push(...scanSessions(agentsDir));
  if (shouldScan("task")) recommendations.push(...scanTasks(agentsDir, index));
  if (shouldScan("spec")) recommendations.push(...scanSpecs(agentsDir, index));
  if (shouldScan("plan")) recommendations.push(...scanPlans(agentsDir));
  if (shouldScan("draft")) recommendations.push(...scanDrafts(agentsDir, index));
  if (shouldScan("council")) recommendations.push(...scanCouncils(agentsDir));
  if (shouldScan("report")) recommendations.push(...scanReports(agentsDir));
  const summary = ARTIFACT_TYPES.filter((t) => shouldScan(t)).map((type) => {
    const typeRecs = recommendations.filter((r) => r.type === type);
    return {
      type,
      total: typeRecs.length,
      archive: typeRecs.filter((r) => r.action === "archive").length,
      delete: typeRecs.filter((r) => r.action === "delete").length,
      flag: typeRecs.filter((r) => r.action === "flag").length,
      skip: typeRecs.filter((r) => r.action === "skip").length
    };
  }).filter((s) => s.total > 0);
  return { recommendations, summary, warnings };
}

// cli/commands/cleanup.ts
var bold10 = (s) => `\x1B[1m${s}\x1B[0m`;
var green9 = (s) => `\x1B[32m${s}\x1B[0m`;
var red8 = (s) => `\x1B[31m${s}\x1B[0m`;
var yellow11 = (s) => `\x1B[33m${s}\x1B[0m`;
var gray11 = (s) => `\x1B[90m${s}\x1B[0m`;
var cyan8 = (s) => `\x1B[36m${s}\x1B[0m`;
var TYPE_LABELS = {
  session: "SESSIONS",
  task: "TASKS",
  spec: "SPECS",
  plan: "PLANS",
  draft: "DRAFTS",
  council: "COUNCILS",
  report: "REPORTS"
};
function formatPreview(fm) {
  if (!fm) return gray11("  (no frontmatter)");
  const keys = Object.keys(fm).slice(0, 3);
  return keys.map((k) => {
    const v = fm[k];
    const display = typeof v === "string" ? v : JSON.stringify(v);
    return gray11(`  ${k}: ${display}`);
  }).join("\n");
}
var NESTED_ARCHIVE_TYPES = /* @__PURE__ */ new Set(["session", "council", "report"]);
function archiveGenericArtifact(filePath, artifactType) {
  const dir = dirname12(filePath);
  const archiveDir = join34(dir, "archive");
  const filename = filePath.split("/").pop();
  const destPath = join34(archiveDir, filename);
  mkdirSync18(archiveDir, { recursive: true });
  const now = (/* @__PURE__ */ new Date()).toISOString();
  const raw = readFileSync26(filePath, "utf-8");
  const { data, content } = matter12(raw);
  const blockKey = NESTED_ARCHIVE_TYPES.has(artifactType) ? artifactType : null;
  if (blockKey && data[blockKey] && typeof data[blockKey] === "object") {
    const block = data[blockKey];
    block.status = "archived";
    block.archived_at = now;
    block.archived_by = "loaf cleanup";
  } else {
    data.archived_at = now;
    data.archived_by = "loaf cleanup";
  }
  const updated = matter12.stringify(content, data);
  writeFileSync18(filePath, updated, "utf-8");
  renameSync2(filePath, destPath);
}
function registerCleanupCommand(program2) {
  program2.command("cleanup").description("Scan .agents/ artifacts and recommend cleanup actions").option("--dry-run", "Show recommendations without prompting for actions").option("--sessions", "Only review sessions").option("--specs", "Only review specs").option("--plans", "Only review plans").option("--drafts", "Only review drafts").action(async (options) => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red8("error:")} No .agents/ directory found`);
      process.exit(1);
    }
    console.log(`
${bold10("loaf cleanup")}
`);
    const filter = (() => {
      const types = [];
      if (options.sessions) types.push("session");
      if (options.specs) types.push("spec");
      if (options.plans) types.push("plan");
      if (options.drafts) types.push("draft");
      return types.length > 0 ? types : void 0;
    })();
    const result = scanArtifacts({ agentsDir, filter });
    for (const warning of result.warnings) {
      console.log(`  ${yellow11("warn:")} ${warning}`);
    }
    if (result.warnings.length > 0) console.log();
    for (const typeSummary of result.summary) {
      const label = TYPE_LABELS[typeSummary.type];
      console.log(`  ${bold10(label)} ${gray11(`(${typeSummary.total} total)`)}`);
      const actionableRecs = result.recommendations.filter(
        (r) => r.type === typeSummary.type && r.action !== "skip"
      );
      if (typeSummary.archive > 0) {
        const items = actionableRecs.filter((r) => r.action === "archive").map((r) => r.filename);
        console.log(`    ${green9("Ready to archive:")}  ${typeSummary.archive}  ${gray11(items.join(", "))}`);
      }
      if (typeSummary.delete > 0) {
        const items = actionableRecs.filter((r) => r.action === "delete").map((r) => r.filename);
        console.log(`    ${red8("Ready to delete:")}   ${typeSummary.delete}  ${gray11(items.join(", "))}`);
      }
      if (typeSummary.flag > 0) {
        const items = actionableRecs.filter((r) => r.action === "flag").map((r) => r.filename);
        console.log(`    ${yellow11("Needs review:")}      ${typeSummary.flag}  ${gray11(items.join(", "))}`);
      }
      if (typeSummary.skip > 0) {
        console.log(`    ${gray11(`Active/current:     ${typeSummary.skip}`)}`);
      }
      console.log();
    }
    const actionable = result.recommendations.filter((r) => r.action !== "skip");
    if (actionable.length === 0) {
      console.log(`  ${green9("\u2713")} Nothing to clean up.
`);
      return;
    }
    if (options.dryRun || !isTTY()) {
      const mode = options.dryRun ? "--dry-run" : "non-TTY";
      console.log(`  ${cyan8(`(${mode})`)} ${actionable.length} actionable item(s). Run interactively to take action.
`);
      return;
    }
    console.log(`  ${bold10("Actions")} \u2014 ${actionable.length} item(s)
`);
    let index = null;
    const getIndex = () => {
      if (!index) index = getOrBuildIndex(agentsDir);
      return index;
    };
    const tasksToArchive = [];
    const specsToArchive = [];
    let actionsPerformed = 0;
    for (const rec of actionable) {
      console.log(`  ${cyan8("\u2192")} ${bold10(rec.filename)}`);
      console.log(`    ${rec.reason}`);
      if (rec.hint) console.log(`    ${yellow11("hint:")} ${rec.hint}`);
      if (rec.action === "archive") {
        if (rec.type === "task") {
          const match = rec.filename.match(/^(TASK-\d+)/);
          if (match) {
            const confirmed = await askYesNo3(`    Archive ${match[1]}? [y/N] `);
            if (confirmed) {
              tasksToArchive.push(match[1]);
              actionsPerformed++;
            }
          }
        } else if (rec.type === "spec") {
          const match = rec.filename.match(/^(SPEC-\d+)/);
          if (match) {
            const confirmed = await askYesNo3(`    Archive ${match[1]}? [y/N] `);
            if (confirmed) {
              specsToArchive.push(match[1]);
              actionsPerformed++;
            }
          }
        } else {
          const confirmed = await askYesNo3(`    Archive? [y/N] `);
          if (confirmed && existsSync30(rec.path)) {
            archiveGenericArtifact(rec.path, rec.type);
            console.log(`    ${green9("\u2713")} Archived`);
            actionsPerformed++;
          }
        }
      } else if (rec.action === "delete") {
        console.log(formatPreview(rec.frontmatter));
        const confirmed = await askYesNo3(`    ${red8("Delete")}? [y/N] `);
        if (confirmed && existsSync30(rec.path)) {
          rmSync7(rec.path);
          console.log(`    ${green9("\u2713")} Deleted`);
          actionsPerformed++;
        }
      } else if (rec.action === "flag") {
        console.log(`    ${gray11("(flagged for review \u2014 no automatic action)")}`);
      }
      console.log();
    }
    if (tasksToArchive.length > 0) {
      const idx = getIndex();
      const results = archiveTasks(agentsDir, idx, tasksToArchive);
      for (const r of results) {
        if (r.status === "archived") {
          console.log(`  ${green9("\u2713")} Archived ${r.id}`);
        } else {
          console.log(`  ${yellow11("\u26A0")} Skipped ${r.id}: ${r.reason}`);
        }
      }
    }
    if (specsToArchive.length > 0) {
      const idx = getIndex();
      const results = archiveSpecs(agentsDir, idx, specsToArchive);
      for (const r of results) {
        if (r.status === "archived") {
          console.log(`  ${green9("\u2713")} Archived ${r.id}`);
        } else {
          console.log(`  ${yellow11("\u26A0")} Skipped ${r.id}: ${r.reason}`);
        }
      }
    }
    if (index) {
      saveIndex(join34(agentsDir, "TASKS.json"), index);
    }
    console.log(`  ${green9("\u2713")} Cleanup complete \u2014 ${actionsPerformed} action(s) performed.
`);
  });
}

// cli/commands/check.ts
import { readFileSync as readFileSync27, existsSync as existsSync31 } from "fs";
import { dirname as dirname13 } from "path";
import { fileURLToPath as fileURLToPath7 } from "url";
import { execSync as execSync2 } from "child_process";
var __dirname5 = dirname13(fileURLToPath7(import.meta.url));
var bold11 = (s) => `\x1B[1m${s}\x1B[0m`;
var green10 = (s) => `\x1B[32m${s}\x1B[0m`;
var red9 = (s) => `\x1B[31m${s}\x1B[0m`;
var yellow12 = (s) => `\x1B[33m${s}\x1B[0m`;
var gray12 = (s) => `\x1B[90m${s}\x1B[0m`;
async function readStdin() {
  return new Promise((resolve2, reject) => {
    let data = "";
    process.stdin.setEncoding("utf8");
    process.stdin.on("data", (chunk) => {
      data += chunk;
    });
    process.stdin.on("end", () => {
      resolve2(data);
    });
    process.stdin.on("error", (err) => {
      reject(err);
    });
    if (process.stdin.isTTY) {
      resolve2("");
    }
  });
}
function parseContext(stdinData) {
  if (!stdinData.trim()) {
    return {};
  }
  return JSON.parse(stdinData);
}
function getToolName(context) {
  return context.tool?.name || context.tool_name || "";
}
function getCommand(context) {
  return context.tool_input?.command || context.tool?.input?.command || context.input?.command || "";
}
function getFilePath(context) {
  return context.tool_input?.file_path || context.tool?.input?.file_path || context.input?.file_path || "";
}
function getContent(context) {
  return context.tool_input?.content || context.tool?.input?.content || context.tool_input?.new_string || context.tool?.input?.new_string || context.input?.content || context.input?.new_string || "";
}
function outputJson(result, hookId) {
  const output = {
    hook: hookId,
    passed: result.passed && !result.blocked,
    blocked: result.blocked,
    exitCode: result.blocked ? 2 : 0,
    warnings: result.warnings,
    errors: result.errors,
    findings: result.findings
  };
  console.log(JSON.stringify(output, null, 2));
}
function outputText(result, hookId) {
  if (result.blocked) {
    console.error(`
${red9("\u2717")} ${bold11(hookId)}: blocked`);
    for (const error of result.errors) {
      console.error(`   ${red9("\u2022")} ${error}`);
    }
    if (result.findings && result.findings.length > 0) {
      console.error(`
   ${bold11("Findings:")}`);
      for (const finding of result.findings) {
        console.error(`   ${gray12("-")} ${finding}`);
      }
    }
  } else if (result.warnings.length > 0) {
    console.log(`
${yellow12("\u26A0")} ${bold11(hookId)}: passed with warnings`);
    for (const warning of result.warnings) {
      console.log(`   WARN: ${warning}`);
    }
  } else {
    console.log(`${green10("\u2713")} ${bold11(hookId)}: passed`);
  }
}
async function checkSecrets(context) {
  const result = {
    passed: true,
    blocked: false,
    warnings: [],
    errors: [],
    findings: []
  };
  const filePath = getFilePath(context);
  const content = getContent(context);
  const command = getCommand(context);
  const toolName = getToolName(context);
  let contentToScan = content || "";
  if (toolName === "Bash" && command) {
    contentToScan += "\n" + command;
  }
  if (!filePath && !contentToScan.trim()) {
    return result;
  }
  const secretPatterns = [
    { name: "AWS Access Key ID", regex: /AKIA[0-9A-Z]{16}/g },
    { name: "AWS Secret Key", regex: /aws_secret_access_key\s*=\s*["']?[A-Za-z0-9/+=]{40}["']?/ig },
    { name: "OpenAI API Key", regex: /sk-[a-zA-Z0-9]{20,}/g },
    { name: "Stripe Live Key", regex: /sk_live_[a-zA-Z0-9]{10,}/g },
    { name: "Stripe Test Key", regex: /sk_test_[a-zA-Z0-9]{10,}/g },
    { name: "Private Key", regex: /-----BEGIN (?:RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----/g },
    { name: "Database Connection", regex: /(postgres|mysql|mongodb):\/\/[^:]+:[^@]+@/g },
    { name: "Password Assignment", regex: /password\s*=\s*["'][^"']{8,}["']/ig },
    { name: "Secret Assignment", regex: /secret\s*=\s*["'][^"']{8,}["']/ig },
    { name: "API Key Assignment", regex: /api_key\s*=\s*["'][^"']{16,}["']/ig },
    { name: "JWT Token", regex: /eyJ[A-Za-z0-9-_]+\.eyJ[A-Za-z0-9-_]+\.[A-Za-z0-9-_.+/=]*/g },
    { name: "GitHub Token", regex: /gh[pousr]_[A-Za-z0-9_]{36}/g }
  ];
  const targetContent = contentToScan;
  const foundSecrets = [];
  for (const { name, regex } of secretPatterns) {
    const matches = targetContent.match(regex);
    if (matches) {
      for (const match of matches) {
        const matchPreview = match.substring(0, 40);
        foundSecrets.push(`${name}: ${matchPreview}...`);
      }
    }
  }
  if (foundSecrets.length > 0) {
    result.passed = false;
    result.blocked = true;
    result.errors.push(`Potential secrets detected in ${filePath || "input"}`);
    result.findings = foundSecrets;
  }
  return result;
}
async function validatePush(context) {
  const result = {
    passed: true,
    blocked: false,
    warnings: [],
    errors: []
  };
  const toolName = getToolName(context);
  const command = getCommand(context);
  if (toolName !== "Bash" || !command.match(/^git\s+push/)) {
    return result;
  }
  const errors = [];
  const hasPackageJson = existsSync31("package.json");
  let hasBuildScript = false;
  if (hasPackageJson) {
    try {
      const pkg = JSON.parse(readFileSync27("package.json", "utf-8"));
      hasBuildScript = !!pkg.scripts?.build;
    } catch {
    }
  }
  try {
    const lastTag = execSync2("git describe --tags --abbrev=0 2>/dev/null", {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "ignore"]
    }).trim();
    if (lastTag && hasPackageJson) {
      try {
        const pkg = JSON.parse(readFileSync27("package.json", "utf-8"));
        const currentVersion = pkg.version;
        const tagPkgContent = execSync2(
          `git show ${lastTag}:package.json 2>/dev/null`,
          { encoding: "utf-8", stdio: ["pipe", "pipe", "ignore"] }
        );
        const tagPkg = JSON.parse(tagPkgContent);
        const tagVersion = tagPkg.version;
        if (currentVersion && currentVersion === tagVersion) {
          errors.push(`Version not bumped since ${lastTag} (still ${currentVersion})`);
        }
      } catch {
      }
    }
  } catch {
  }
  try {
    const lastTag = execSync2("git describe --tags --abbrev=0 2>/dev/null", {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "ignore"]
    }).trim();
    if (lastTag) {
      if (!existsSync31("CHANGELOG.md")) {
        errors.push("CHANGELOG.md not found (required for tagged releases)");
      } else {
        try {
          const changedFiles = execSync2(
            `git diff ${lastTag} --name-only -- CHANGELOG.md 2>/dev/null`,
            { encoding: "utf-8", stdio: ["pipe", "pipe", "ignore"] }
          ).trim();
          if (!changedFiles) {
            errors.push(`CHANGELOG.md not updated since ${lastTag}`);
          }
        } catch {
        }
      }
    }
  } catch {
  }
  if (hasBuildScript) {
    try {
      execSync2("npm run build", {
        cwd: process.cwd(),
        encoding: "utf-8",
        stdio: ["pipe", "pipe", "pipe"],
        timeout: 12e4
        // 2 minute timeout
      });
    } catch {
      errors.push("Build failed - fix build errors before pushing");
    }
  }
  if (errors.length > 0) {
    result.passed = false;
    result.blocked = true;
    result.errors.push(...errors);
  }
  return result;
}
async function workflowPrePr(context) {
  const result = {
    passed: true,
    blocked: false,
    warnings: [],
    errors: []
  };
  const toolName = getToolName(context);
  const command = getCommand(context);
  if (toolName !== "Bash" || !command.includes("gh pr create")) {
    return result;
  }
  if (existsSync31("CHANGELOG.md")) {
    try {
      const changelog = readFileSync27("CHANGELOG.md", "utf-8");
      const unreleasedMatch = changelog.match(/##\s*\[Unreleased\]([\s\S]*?)(?=\n##\s|$)/);
      if (unreleasedMatch) {
        const unreleasedSection = unreleasedMatch[1];
        const hasEntries = /^[-*]\s/m.test(unreleasedSection);
        if (!hasEntries) {
          result.passed = false;
          result.blocked = true;
          result.errors.push("CHANGELOG.md [Unreleased] section is empty (no entries found)");
          result.errors.push("Add changelog entries before creating a PR");
        }
      } else {
        result.passed = false;
        result.blocked = true;
        result.errors.push("CHANGELOG.md missing [Unreleased] section");
      }
    } catch {
      result.passed = false;
      result.blocked = true;
      result.errors.push("Could not read CHANGELOG.md");
    }
  } else {
    result.passed = false;
    result.blocked = true;
    result.errors.push("CHANGELOG.md not found");
  }
  const hasFillFlag = /--fill/.test(command);
  const hasBodyFileFlag = /--body-file/.test(command);
  const hasAnyExplicitFlag = /--(title|body|fill|body-file)/.test(command);
  if (hasAnyExplicitFlag && !hasFillFlag && !hasBodyFileFlag) {
    const titleMatch = command.match(/--title(?:\s+|=)(?:"([^"]+)"|'([^']+)'|([^\s"']+))/);
    if (!titleMatch) {
      result.passed = false;
      result.blocked = true;
      result.errors.push("Missing --title flag - PR title is required");
      result.errors.push('Example: gh pr create --title "feat: add new feature"');
    } else {
      const title = (titleMatch[1] || titleMatch[2] || titleMatch[3]).trim();
      if (title.length < 10) {
        result.passed = false;
        result.blocked = true;
        result.errors.push(`PR title is too short (${title.length} chars) - minimum 10 characters`);
      }
      const conventionalPattern = /^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\(.+\))?!?: .+/i;
      if (!conventionalPattern.test(title)) {
        result.warnings.push("PR title doesn't follow Conventional Commits format (e.g., 'feat: add feature')");
      }
    }
    const hasBodyFlag = /--body/.test(command);
    if (!hasBodyFlag) {
      result.passed = false;
      result.blocked = true;
      result.errors.push("Missing --body flag - PR description is required");
      result.errors.push('Example: gh pr create --title "..." --body "Description of changes"');
    }
  }
  return result;
}
async function validateCommit(context) {
  const result = {
    passed: true,
    blocked: false,
    warnings: [],
    errors: []
  };
  const toolName = getToolName(context);
  const command = getCommand(context);
  if (toolName !== "Bash" || !command.includes("git commit")) {
    return result;
  }
  if (command.includes("--amend") && !command.includes("-m")) {
    return result;
  }
  if (command.includes("--no-edit") || command.includes("git merge")) {
    return result;
  }
  let message = null;
  const msgMatch = command.match(/-m(?:\s+|=)(?:"([^"]+)"|'([^']+)'|([^\s"']+))/);
  if (msgMatch) {
    message = msgMatch[1] || msgMatch[2] || msgMatch[3];
  } else {
    const heredocMatch = command.match(/<<'?EOF'?\s*\n(.+?)\n\s*EOF/s);
    if (heredocMatch) {
      message = heredocMatch[1].trim();
    }
  }
  if (!message) {
    return result;
  }
  const conventionalCommitRegex = /^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\(.+\))?!?: .+/;
  if (!conventionalCommitRegex.test(message)) {
    result.passed = false;
    result.blocked = true;
    result.errors.push("Commit message does not follow Conventional Commits format");
    result.errors.push("Expected format: <type>[optional scope]: <description>");
    result.errors.push("Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci, build, revert");
    result.errors.push(`Your message: "${message}"`);
  }
  const subjectLine = message.split("\n")[0];
  if (subjectLine.length > 72) {
    result.warnings.push(`Subject line is ${subjectLine.length} characters (recommended: \u226472)`);
  }
  return result;
}
async function securityAudit(context) {
  const result = {
    passed: true,
    blocked: false,
    warnings: [],
    errors: [],
    findings: []
  };
  const toolName = getToolName(context);
  const command = getCommand(context);
  if (toolName !== "Bash") {
    return result;
  }
  const dangerousPatterns = [
    {
      name: "Dangerous rm -rf",
      regex: /rm\s+-rf?\s+\/|rm\s+-rf?\s+\*+/,
      critical: true
    },
    {
      name: "chmod 777 (world-writable)",
      regex: /chmod\s+.*777/,
      critical: true
    },
    {
      name: "eval of untrusted input",
      regex: /eval\s*\$|eval\s*\`/,
      critical: true
    },
    {
      name: "Unsafe curl to bash",
      regex: /curl.*\|\s*(ba)?sh/,
      critical: true
    },
    {
      name: "wget to shell",
      regex: /wget.*\|\s*(ba)?sh/,
      critical: true
    },
    {
      name: "sudo without validation",
      regex: /sudo\s+(rm|dd|mkfs|fdisk|format)/,
      critical: false
    },
    {
      name: "Hardcoded sudo password",
      regex: /echo\s+['"].*['"]\s*\|\s*sudo/,
      critical: true
    },
    {
      name: "Unsafe find exec",
      regex: /find\s+.*-exec\s+(rm|mv|cp)\s*\{\}/,
      critical: false
    },
    {
      name: "SQL injection risk in command",
      regex: /mysql.*-e\s*.*['"]\s*\$/,
      critical: false
    }
  ];
  const targetCommand = command || "";
  const criticalFindings = [];
  const warningFindings = [];
  for (const { name, regex, critical } of dangerousPatterns) {
    if (regex.test(targetCommand)) {
      const finding = `${name}: matched pattern in command`;
      if (critical) {
        criticalFindings.push(finding);
      } else {
        warningFindings.push(finding);
      }
    }
  }
  if (criticalFindings.length > 0) {
    result.passed = false;
    result.blocked = true;
    result.errors.push("Critical security issues detected in command");
    result.findings = [...criticalFindings, ...warningFindings];
  } else if (warningFindings.length > 0) {
    result.warnings.push(...warningFindings);
  }
  return result;
}
function registerCheckCommand(program2) {
  program2.command("check").description("Run enforcement hook checks").option("--hook <id>", "Hook ID to run (check-secrets, validate-push, workflow-pre-pr, validate-commit, security-audit)").option("--json", "Output JSON format").action(async (options) => {
    const validHooks = [
      "check-secrets",
      "validate-push",
      "workflow-pre-pr",
      "validate-commit",
      "security-audit"
    ];
    if (!options.hook) {
      console.error(`${red9("error:")} --hook <id> is required`);
      console.error(`${gray12("Valid hooks:")} ${validHooks.join(", ")}`);
      process.exit(1);
    }
    if (!validHooks.includes(options.hook)) {
      console.error(`${red9("error:")} Unknown hook: ${bold11(options.hook)}`);
      console.error(`${gray12("Valid hooks:")} ${validHooks.join(", ")}`);
      process.exit(1);
    }
    let context;
    try {
      const stdinData = await readStdin();
      context = parseContext(stdinData);
    } catch (err) {
      console.error(`${red9("error:")} Failed to read stdin: ${err}`);
      process.exit(1);
    }
    let result;
    try {
      switch (options.hook) {
        case "check-secrets":
          result = await checkSecrets(context);
          break;
        case "validate-push":
          result = await validatePush(context);
          break;
        case "workflow-pre-pr":
          result = await workflowPrePr(context);
          break;
        case "validate-commit":
          result = await validateCommit(context);
          break;
        case "security-audit":
          result = await securityAudit(context);
          break;
        default:
          console.error(`${red9("error:")} Unknown hook: ${options.hook}`);
          process.exit(1);
      }
    } catch (err) {
      console.error(`${red9("error:")} Check failed with exception: ${err}`);
      process.exit(1);
    }
    if (options.json) {
      outputJson(result, options.hook);
    } else {
      outputText(result, options.hook);
    }
    if (result.blocked) {
      process.exit(2);
    } else {
      process.exit(0);
    }
  });
}

// cli/commands/session.ts
import { execSync as execSync3 } from "child_process";
import {
  existsSync as existsSync32,
  mkdirSync as mkdirSync19,
  readdirSync as readdirSync14,
  readFileSync as readFileSync28,
  writeFileSync as writeFileSync19,
  renameSync as renameSync3,
  unlinkSync as unlinkSync3,
  openSync,
  closeSync,
  statSync as statSync3
} from "fs";
import { join as join36, basename as basename7 } from "path";
import matter13 from "gray-matter";
var bold12 = (s) => `\x1B[1m${s}\x1B[0m`;
var green11 = (s) => `\x1B[32m${s}\x1B[0m`;
var red10 = (s) => `\x1B[31m${s}\x1B[0m`;
var yellow13 = (s) => `\x1B[33m${s}\x1B[0m`;
var cyan9 = (s) => `\x1B[36m${s}\x1B[0m`;
var gray13 = (s) => `\x1B[90m${s}\x1B[0m`;
var LOCK_STALENESS_THRESHOLD = 3e4;
function isLockStale(lockPath) {
  try {
    const stats = statSync3(lockPath);
    const age = Date.now() - stats.mtimeMs;
    return age > LOCK_STALENESS_THRESHOLD;
  } catch {
    return true;
  }
}
function forceReleaseLock(lockPath) {
  try {
    unlinkSync3(lockPath);
    console.log(`  Released stale lock: ${lockPath}`);
  } catch {
  }
}
async function acquireLock(lockPath, maxRetries = 50, retryDelay = 100) {
  for (let i = 0; i < maxRetries; i++) {
    try {
      if (existsSync32(lockPath) && isLockStale(lockPath)) {
        forceReleaseLock(lockPath);
      }
      const fd = openSync(lockPath, "wx");
      const lockContent = {
        pid: process.pid,
        timestamp: Date.now()
      };
      writeFileSync19(fd, JSON.stringify(lockContent), "utf-8");
      closeSync(fd);
      return;
    } catch {
      await new Promise((resolve2) => setTimeout(resolve2, retryDelay));
    }
  }
  throw new Error(`Could not acquire lock after ${maxRetries} retries: ${lockPath}`);
}
function releaseLock(lockPath) {
  try {
    unlinkSync3(lockPath);
  } catch {
  }
}
function writeFileAtomic(filePath, content) {
  const tempPath = `${filePath}.tmp.${Date.now()}.${Math.random().toString(36).slice(2, 11)}`;
  try {
    writeFileSync19(tempPath, content, "utf-8");
    renameSync3(tempPath, filePath);
  } catch (err) {
    try {
      unlinkSync3(tempPath);
    } catch {
    }
    throw err;
  }
}
function getCurrentBranch() {
  try {
    const branch = execSync3("git branch --show-current", {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
    if (!branch) {
      const commitSha = execSync3("git rev-parse --short HEAD", {
        encoding: "utf-8",
        stdio: ["pipe", "pipe", "pipe"]
      }).trim();
      return `detached-${commitSha}`;
    }
    return branch;
  } catch {
    return "unknown";
  }
}
function getRecentCommits(count = 5) {
  try {
    const output = execSync3(`git log --pretty=format:"%H %s" -${count}`, {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
    if (!output) return [];
    return output.split("\n").map((line) => {
      const spaceIndex = line.indexOf(" ");
      return {
        hash: line.substring(0, 7),
        // Short hash
        message: line.substring(spaceIndex + 1)
      };
    });
  } catch {
    return [];
  }
}
function getLastCommitSha() {
  try {
    return execSync3("git rev-parse --short HEAD", {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
  } catch {
    return "unknown";
  }
}
function findSpecForBranch(agentsDir, branch) {
  const specsDir = join36(agentsDir, "specs");
  if (!existsSync32(specsDir)) return null;
  const files = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
  for (const file of files) {
    try {
      const content = readFileSync28(join36(specsDir, file), "utf-8");
      const parsed = matter13(content);
      const fm = parsed.data;
      if (fm.branch === branch) {
        return {
          id: fm.id || file.replace(/\.md$/, ""),
          title: fm.title || "Untitled",
          sessionFile: fm.session
        };
      }
    } catch {
      continue;
    }
  }
  return null;
}
function updateSpecSessionField(agentsDir, specId, sessionFileName) {
  const specsDir = join36(agentsDir, "specs");
  if (!existsSync32(specsDir)) return;
  const files = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
  for (const file of files) {
    if (file.includes(specId)) {
      const filePath = join36(specsDir, file);
      try {
        const content = readFileSync28(filePath, "utf-8");
        const parsed = matter13(content);
        if (parsed.data.session !== sessionFileName) {
          parsed.data.session = sessionFileName;
          const newContent = matter13.stringify(parsed.content, parsed.data);
          writeFileSync19(filePath, newContent, "utf-8");
        }
      } catch {
      }
      break;
    }
  }
}
function getSessionFilePath(agentsDir, branch, timestamp) {
  const ts = timestamp || getTimestampForFilename();
  const slug = branch.replace(/^feat\//, "").replace(/[^a-zA-Z0-9-_]/g, "-").replace(/-+/g, "-");
  return join36(agentsDir, "sessions", `${ts}-${slug}.md`);
}
function getTimestampForFilename() {
  const now = /* @__PURE__ */ new Date();
  const year = now.getFullYear();
  const month = String(now.getMonth() + 1).padStart(2, "0");
  const day = String(now.getDate()).padStart(2, "0");
  const hour = String(now.getHours()).padStart(2, "0");
  const minute = String(now.getMinutes()).padStart(2, "0");
  const second = String(now.getSeconds()).padStart(2, "0");
  return `${year}${month}${day}-${hour}${minute}${second}`;
}
function findActiveSessionForBranch(agentsDir, branch) {
  const sessionsDir = join36(agentsDir, "sessions");
  if (!existsSync32(sessionsDir)) return null;
  const files = readdirSync14(sessionsDir).filter((f) => f.endsWith(".md") && !f.startsWith("archive"));
  const candidates = [];
  for (const file of files) {
    const filePath = join36(sessionsDir, file);
    const session = readSessionFile(filePath);
    if (session && session.data.branch === branch && session.data.status !== "archived") {
      candidates.push({ filePath, data: session.data, content: session.content });
    }
  }
  if (candidates.length === 0) {
    let currentBranchHash = null;
    let parentBranch = null;
    try {
      currentBranchHash = execSync3("git rev-parse HEAD", { encoding: "utf-8" }).trim();
      const reflogOutput = execSync3(`git reflog show --format='%H %gs' ${branch} 2>/dev/null | tail -5`, { encoding: "utf-8" });
      const checkoutMatch = reflogOutput.match(/checkout: moving from ([^\s]+) to/);
      const createdMatch = reflogOutput.match(/branch: Created from ([^\s]+)/);
      const renamedMatch = reflogOutput.match(/Branch: renamed refs\/heads\/([^\s]+) to/);
      if (checkoutMatch) {
        parentBranch = checkoutMatch[1];
      } else if (createdMatch) {
        parentBranch = createdMatch[1];
      } else if (renamedMatch) {
        parentBranch = renamedMatch[1];
      }
    } catch {
    }
    if (parentBranch) {
      const specsDir = join36(agentsDir, "specs");
      if (existsSync32(specsDir)) {
        const specFiles = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
        for (const specFile of specFiles) {
          try {
            const specPath = join36(specsDir, specFile);
            const specContent = readFileSync28(specPath, "utf-8");
            const specParsed = matter13(specContent);
            const specFm = specParsed.data;
            if (specFm.branch === parentBranch && specFm.session) {
              const sessionPath = join36(agentsDir, "sessions", specFm.session);
              if (existsSync32(sessionPath)) {
                const session = readSessionFile(sessionPath);
                if (session && session.data.branch === parentBranch && session.data.status !== "archived") {
                  session.data.branch = branch;
                  const newSessionContent = matter13.stringify(session.content, session.data);
                  writeFileSync19(sessionPath, newSessionContent, "utf-8");
                  specFm.branch = branch;
                  const newSpecContent = matter13.stringify(specParsed.content, specFm);
                  writeFileSync19(specPath, newSpecContent, "utf-8");
                  candidates.push({ filePath: sessionPath, data: session.data, content: session.content });
                  break;
                }
              }
            }
          } catch {
            continue;
          }
        }
      }
    }
  }
  if (candidates.length === 0) return null;
  const statusPriority = {
    active: 1,
    paused: 2,
    blocked: 2,
    complete: 2
  };
  candidates.sort((a, b) => {
    const priorityA = statusPriority[a.data.status] ?? 3;
    const priorityB = statusPriority[b.data.status] ?? 3;
    if (priorityA !== priorityB) {
      return priorityA - priorityB;
    }
    const timeA = a.data.last_updated || a.data.last_entry || "0";
    const timeB = b.data.last_updated || b.data.last_entry || "0";
    return timeB.localeCompare(timeA);
  });
  return candidates[0];
}
async function getOrCreateSession(agentsDir, branch, specInfo) {
  const sessionsDir = join36(agentsDir, "sessions");
  const lockPath = join36(sessionsDir, `.create-${branch.replace(/[^a-zA-Z0-9-]/g, "-")}.lock`);
  let lockAcquired = false;
  try {
    await acquireLock(lockPath, 100, 50);
    lockAcquired = true;
    let existing = null;
    for (let i = 0; i < 10; i++) {
      await new Promise((resolve2) => setTimeout(resolve2, 20));
      existing = findActiveSessionForBranch(agentsDir, branch);
      if (existing) break;
    }
    if (existing) {
      return { ...existing, isNew: false };
    }
    const filePath = getSessionFilePath(agentsDir, branch);
    const created = createSessionFile(filePath, branch, specInfo);
    if (!created) {
      const existingSession = readSessionFile(filePath);
      if (existingSession) {
        return { filePath, data: existingSession.data, content: existingSession.content, isNew: false };
      }
      const fallbackSession = readSessionFile(filePath);
      if (fallbackSession) {
        return { filePath, data: fallbackSession.data, content: fallbackSession.content, isNew: false };
      }
    }
    const session = readSessionFile(filePath);
    return { filePath, data: session.data, content: session.content, isNew: true };
  } finally {
    if (lockAcquired) {
      releaseLock(lockPath);
    }
  }
}
function readSessionFile(filePath) {
  if (!existsSync32(filePath)) return null;
  try {
    const raw = readFileSync28(filePath, "utf-8");
    const parsed = matter13(raw);
    const rawData = parsed.data;
    if (rawData.session && typeof rawData.session === "object") {
      const nested = rawData.session;
      const migratedData = { ...rawData };
      delete migratedData.session;
      for (const [key, value] of Object.entries(nested)) {
        migratedData[key] = value;
      }
      return {
        data: migratedData,
        content: parsed.content
      };
    }
    return {
      data: rawData,
      content: parsed.content
    };
  } catch {
    return null;
  }
}
function parseEntry(entry) {
  const match = entry.match(/^([a-z]+)(?:\(([^)]+)\))?:\s*(.+)$/);
  if (!match) return null;
  const [, type, scope, description] = match;
  const validTypes = [
    "resume",
    "pause",
    "progress",
    "commit",
    "pr",
    "merge",
    "decide",
    "discover",
    "conclude",
    "block",
    "unblock",
    "spark",
    "todo",
    "assume",
    // New types
    "branch",
    "task",
    "linear",
    "hypothesis",
    "try",
    "reject",
    "compact"
  ];
  if (!validTypes.includes(type)) return null;
  return {
    type,
    scope,
    description
  };
}
function getTimestamp() {
  return (/* @__PURE__ */ new Date()).toISOString();
}
function getDateTimeString() {
  const now = /* @__PURE__ */ new Date();
  const date = now.toISOString().split("T")[0];
  const time = now.toTimeString().split(":")[0] + ":" + now.toTimeString().split(":")[1];
  return `${date} ${time}`;
}
function createSessionFile(filePath, branch, specInfo) {
  if (existsSync32(filePath)) {
    return null;
  }
  const now = getTimestamp();
  const frontmatter = {
    branch,
    status: "active",
    created: now,
    last_entry: now
  };
  if (specInfo?.id) {
    frontmatter.spec = specInfo.id;
  }
  const title = specInfo ? `${specInfo.id}: ${specInfo.title}` : branch;
  const entry = `- ${getDateTimeString()} resume(${branch}): session started`;
  const body = `# Session: ${title}

## Journal

${entry}
`;
  const content = matter13.stringify(body, frontmatter);
  try {
    const fd = openSync(filePath, "wx");
    writeFileSync19(fd, content, "utf-8");
    closeSync(fd);
  } catch {
    return null;
  }
  return frontmatter;
}
async function appendEntry(filePath, entryLines, updateFrontmatter) {
  const lockPath = `${filePath}.lock`;
  let lockAcquired = false;
  try {
    await acquireLock(lockPath);
    lockAcquired = true;
    const session = readSessionFile(filePath);
    if (!session) {
      throw new Error("Session file not found");
    }
    updateFrontmatter(session.data);
    const trimmedContent = session.content.trimEnd();
    const separator = trimmedContent.endsWith("\n") ? "\n" : "\n\n";
    const newContent = matter13.stringify(
      trimmedContent + separator + entryLines.join("\n") + "\n",
      session.data
    );
    writeFileAtomic(filePath, newContent);
  } finally {
    if (lockAcquired) {
      releaseLock(lockPath);
    }
  }
}
function extractRecentEntries(content, count = 15) {
  const lines = content.split("\n");
  const entries = [];
  const entryPattern = /^- \d{4}-\d{2}-\d{2} \d{2}:\d{2} /;
  for (const line of lines) {
    if (entryPattern.test(line)) {
      entries.push(line.trim());
    }
  }
  return entries.slice(-count);
}
function extractDecideEntries(content) {
  const decideEntries = [];
  const lines = content.split("\n");
  for (const line of lines) {
    if (line.match(/^- \d{4}-\d{2}-\d{2} \d{2}:\d{2} decide\([^)]+\):/)) {
      decideEntries.push(line.trim());
    }
  }
  return decideEntries;
}
function persistDecisionsToSpec(agentsDir, specId, decideEntries, sessionBranch) {
  const specsDir = join36(agentsDir, "specs");
  if (!existsSync32(specsDir)) {
    return { success: false, message: "No specs directory found" };
  }
  const specFiles = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
  const specFile = specFiles.find((f) => f.includes(specId));
  if (!specFile) {
    return { success: false, message: `Spec ${specId} not found` };
  }
  const specPath = join36(specsDir, specFile);
  const specContent = readFileSync28(specPath, "utf-8");
  const changelogMatch = specContent.match(/\n## Changelog\n/);
  const dateStr = (/* @__PURE__ */ new Date()).toISOString().split("T")[0];
  const entryHeader = `- ${dateStr} \u2014 Session ${sessionBranch} archived: ${decideEntries.length} decision(s) extracted`;
  let updatedContent;
  if (changelogMatch) {
    const insertPos = changelogMatch.index + changelogMatch[0].length;
    const decisionsList = decideEntries.map((e) => `  ${e}`).join("\n");
    const entry = `${entryHeader}
${decisionsList}

`;
    updatedContent = specContent.slice(0, insertPos) + entry + specContent.slice(insertPos);
  } else {
    const decisionsList = decideEntries.map((e) => `  ${e}`).join("\n");
    const entry = `
## Changelog

${entryHeader}
${decisionsList}
`;
    updatedContent = specContent + entry;
  }
  writeFileSync19(specPath, updatedContent, "utf-8");
  return { success: true, message: `Appended to ${specFile}` };
}
function countTasksInSession(content) {
  const completed = (content.match(/- \[x\]/gi) || []).length;
  const total = (content.match(/- \[[ x]\]/gi) || []).length;
  return { completed, total };
}
function registerSessionCommand(program2) {
  const session = program2.command("session").description("Manage session journals");
  session.command("start").description("Start/resume session for current branch").action(async () => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const sessionsDir = join36(agentsDir, "sessions");
    if (!existsSync32(sessionsDir)) {
      mkdirSync19(sessionsDir, { recursive: true });
    }
    const branch = getCurrentBranch();
    if (branch === "unknown") {
      console.error(`  ${red10("error:")} Not in a git repository`);
      process.exit(1);
    }
    if (branch.startsWith("detached-")) {
      console.error(`  ${yellow13("\u26A0")} Warning: In detached HEAD state (${branch})`);
      console.error(`  ${gray13("Sessions in detached HEAD state are isolated to the specific commit.")}`);
    }
    console.log(`
  ${bold12("loaf session start")}
`);
    console.log(`  Branch: ${cyan9(branch)}`);
    const specInfo = findSpecForBranch(agentsDir, branch);
    if (specInfo) {
      console.log(`  Linked to: ${bold12(specInfo.id)} \u2014 ${specInfo.title}`);
    } else {
      console.log(`  ${yellow13("!")} No linked spec found \u2014 creating ad-hoc session`);
    }
    const { filePath: sessionFilePath, data: sessionData, content: sessionContent, isNew } = await getOrCreateSession(agentsDir, branch, specInfo);
    if (isNew) {
      console.log(`  ${green11("+")} Creating new session file`);
      if (specInfo) {
        const sessionFileName = basename7(sessionFilePath);
        updateSpecSessionField(agentsDir, specInfo.id, sessionFileName);
      }
    } else {
      console.log(`  ${green11("\u2713")} Resuming existing session`);
    }
    const lastCommit = getLastCommitSha();
    const commits = getRecentCommits(3);
    const { completed, total } = countTasksInSession(sessionContent);
    const timestamp = getDateTimeString();
    const journalLines = [];
    const shouldAppendResume = !isNew && sessionData.status !== "active";
    if (shouldAppendResume) {
      journalLines.push(`- ${timestamp} resume(${branch}): session resumed`);
      if (lastCommit !== "unknown") {
        journalLines.push(`- ${timestamp} context: last commit ${lastCommit}`);
      }
      if (completed > 0 || total > 0) {
        journalLines.push(`- ${timestamp} progress: ${completed}/${total} tasks completed`);
      }
      if (commits.length > 0) {
        for (const commit of commits.slice(0, 3)) {
          journalLines.push(`- ${timestamp} commit(${commit.hash}): "${commit.message}"`);
        }
      }
    }
    if (journalLines.length > 0) {
      await appendEntry(
        sessionFilePath,
        journalLines,
        (data) => {
          data.status = "active";
          data.last_updated = getTimestamp();
          data.last_entry = getTimestamp();
        }
      );
    } else if (sessionData.status !== "active" || isNew) {
      sessionData.status = "active";
      sessionData.last_updated = getTimestamp();
      sessionData.last_entry = getTimestamp();
      const newContent = matter13.stringify(sessionContent, sessionData);
      writeFileSync19(sessionFilePath, newContent, "utf-8");
    }
    console.log(`  ${green11("\u2713")} Session active: ${gray13(sessionFilePath.replace(agentsDir, ".agents"))}`);
    const recentEntries = extractRecentEntries(sessionContent, 15);
    if (recentEntries.length > 0) {
      console.log(`
  ${bold12("Recent journal entries:")}
`);
      for (const entry of recentEntries.slice(0, 20)) {
        const lines = entry.split("\n");
        for (const line of lines.slice(0, 5)) {
          console.log(`    ${line}`);
        }
        if (lines.length > 5) {
          console.log(`    ${gray13("...")}`);
        }
      }
    }
    console.log();
  });
  session.command("end").description("End session with progress summary").action(async () => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const branch = getCurrentBranch();
    if (branch === "unknown") {
      console.error(`  ${red10("error:")} Not in a git repository`);
      process.exit(1);
    }
    let existingSession = findActiveSessionForBranch(agentsDir, branch);
    if (!existingSession) {
      console.error(`  ${red10("error:")} No active session found for branch ${branch}`);
      process.exit(1);
    }
    const sessionFilePath = existingSession.filePath;
    const session2 = existingSession;
    console.log(`
  ${bold12("loaf session end")}
`);
    const lastCommit = getLastCommitSha();
    const commits = getRecentCommits(5);
    const { completed, total } = countTasksInSession(session2.content);
    const commitCount = commits.length;
    const timestamp = getDateTimeString();
    const journalLines = [
      `- ${timestamp} pause(${branch}): session paused`,
      `- ${timestamp} progress: ${completed}/${total} tasks completed, ${commitCount} commits`
    ];
    if (lastCommit !== "unknown") {
      journalLines.push(`- ${timestamp} context: last commit ${lastCommit}`);
    }
    console.log(`  ${yellow13("?")} Consider adding final entries:`);
    console.log(`    ${gray13('loaf session log "decide(scope): key decision"')}`);
    console.log(`    ${gray13('loaf session log "conclude(scope): final notes"')}`);
    console.log(`    ${gray13('loaf session log "todo(next): follow-up task"')}`);
    console.log();
    await appendEntry(
      sessionFilePath,
      journalLines,
      (data) => {
        data.status = "paused";
        data.last_updated = getTimestamp();
        data.last_entry = getTimestamp();
      }
    );
    console.log(`  ${green11("\u2713")} Session paused: ${gray13(sessionFilePath.replace(agentsDir, ".agents"))}`);
    console.log();
  });
  session.command("log [entry]").description("Log entry to session journal").option("--from-hook", "Parse entry from hook stdin").option("--detect-linear", "Detect Linear magic words in recent commits").action(async (entry, options) => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const branch = getCurrentBranch();
    if (branch === "unknown") {
      console.error(`  ${red10("error:")} Not in a git repository`);
      process.exit(1);
    }
    if (branch.startsWith("detached-")) {
      console.error(`  ${yellow13("\u26A0")} Warning: In detached HEAD state (${branch})`);
    }
    let existingSession = findActiveSessionForBranch(agentsDir, branch);
    if (!existingSession) {
      if (options.fromHook) {
        process.exit(0);
      }
      console.error(`  ${red10("error:")} No active session found for branch ${branch}. Run 'loaf session start' first.`);
      process.exit(1);
    }
    const sessionFilePath = existingSession.filePath;
    const session2 = existingSession;
    let entryText = entry;
    if (options.fromHook) {
      try {
        const stdin = await readStdin();
        const hookData = JSON.parse(stdin);
        const command = hookData.tool_input?.command || hookData.tool?.input?.command || hookData.input?.command;
        if (command && typeof command === "string") {
          if (command.includes("git commit")) {
            const msgMatch = command.match(/-m\s+['"]([^'"]+)['"]/) || command.match(/-m\s+(\S+)/);
            const message = msgMatch ? msgMatch[1] : "commit";
            const hash = getLastCommitSha();
            entryText = `commit(${hash}): ${message}`;
          } else if (command.includes("gh pr create")) {
            const titleMatch = command.match(/--title\s+["']([^"']+)["']/);
            const title = titleMatch ? titleMatch[1] : "";
            const raw = hookData.raw;
            let prNum = "";
            if (raw && typeof raw === "string") {
              const prUrlMatch = raw.match(/https:\/\/github\.com\/[^\/]+\/[^\/]+\/pull\/(\d+)/);
              if (prUrlMatch) {
                prNum = prUrlMatch[1];
              }
            }
            if (prNum && title) {
              entryText = `pr(#${prNum}): ${title}`;
            } else if (title) {
              entryText = `pr: ${title}`;
            } else {
              entryText = `pr: PR created`;
            }
          } else if (command.includes("gh pr merge")) {
            const prMatch = command.match(/merge\s+https:\/\/github\.com\/[^\/]+\/[^\/]+\/pull\/(\d+)/) || command.match(/pr\s+merge\s+(\d+)/);
            const prNum = prMatch ? prMatch[1] : "unknown";
            entryText = `merge(#${prNum}): merged`;
          } else {
            entryText = `progress(hook): ${command.slice(0, 100)}${command.length > 100 ? "..." : ""}`;
          }
        } else {
          if (hookData.commit) {
            entryText = `commit(${hookData.commit}): ${hookData.message || "commit"}`;
          } else if (hookData.pr) {
            entryText = `pr(#${hookData.pr}): ${hookData.title || "PR created"}`;
          } else if (hookData.merge) {
            entryText = `merge(#${hookData.merge}): merged`;
          } else {
            process.exit(0);
          }
        }
      } catch (err) {
        console.error(`  ${red10("error:")} Failed to parse stdin JSON: ${err}`);
        process.exit(1);
      }
    }
    if (options.detectLinear) {
      try {
        const commits = getRecentCommits(3);
        const detections = [];
        const magicPattern = /\b(fixe?s?d?|close?s?d?|resolve?s?d?)\s+([A-Z]+-\d+)/gi;
        for (const commit of commits) {
          const matches = commit.message.matchAll(magicPattern);
          for (const match of matches) {
            detections.push({
              issueId: match[2],
              action: match[1].toLowerCase(),
              commit: commit.hash
            });
          }
        }
        if (detections.length === 0) {
          console.log(`  ${gray13("\u2139")} No Linear magic words detected in recent commits`);
          process.exit(0);
        }
        const uniqueIssues = [...new Set(detections.map((d) => d.issueId))];
        entryText = `discover(linear): found magic words for ${uniqueIssues.join(", ")}`;
      } catch (err) {
        console.error(`  ${red10("error:")} Failed to scan commits: ${err}`);
        process.exit(1);
      }
    }
    if (!entryText) {
      console.error(`  ${red10("error:")} Entry text is required. Use: loaf session log "type(scope): description"`);
      console.error(`  ${gray13("Examples:")}`);
      console.error(`    ${gray13('loaf session log "decide(hooks): remove bash wrappers"')}`);
      console.error(`    ${gray13('loaf session log "todo(next): implement tests"')}`);
      process.exit(1);
    }
    const parsedEntry = parseEntry(entryText);
    if (!parsedEntry) {
      console.error(`  ${red10("error:")} Invalid entry format. Use: type(scope): description`);
      console.error(`  ${gray13("Examples:")}`);
      console.error(`    ${gray13('loaf session log "decide(hooks): remove bash wrappers"')}`);
      console.error(`    ${gray13('loaf session log "todo(next): implement tests"')}`);
      process.exit(1);
    }
    const timestamp = getDateTimeString();
    const formattedEntry = `- ${timestamp} ${entryText}`;
    await appendEntry(
      sessionFilePath,
      [formattedEntry],
      (data) => {
        data.last_updated = getTimestamp();
        data.last_entry = getTimestamp();
      }
    );
    console.log(`  ${green11("\u2713")} Logged: ${cyan9(entryText)}`);
  });
  session.command("archive").description("Archive completed session").option("--branch <branch>", "Archive session for specific branch (default: current)").action(async (options) => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const branch = options.branch || getCurrentBranch();
    if (branch === "unknown" && !options.branch) {
      console.error(`  ${red10("error:")} Not in a git repository. Use --branch <branch>`);
      process.exit(1);
    }
    let existingSession = findActiveSessionForBranch(agentsDir, branch);
    if (!existingSession) {
      console.error(`  ${red10("error:")} No active session found for branch ${branch}`);
      process.exit(1);
    }
    const sessionFilePath = existingSession.filePath;
    const session2 = existingSession;
    console.log(`
  ${bold12("loaf session archive")}
`);
    const archiveDir = join36(agentsDir, "sessions", "archive");
    if (!existsSync32(archiveDir)) {
      mkdirSync19(archiveDir, { recursive: true });
    }
    const decideEntries = extractDecideEntries(session2.content);
    if (decideEntries.length > 0) {
      console.log(`  ${bold12("Key decisions extracted:")}`);
      for (const entry of decideEntries.slice(0, 10)) {
        console.log(`    ${entry}`);
      }
      if (decideEntries.length > 10) {
        console.log(`    ${gray13(`... and ${decideEntries.length - 10} more`)}`);
      }
      console.log();
      if (session2.data.spec && decideEntries.length > 0) {
        const result = persistDecisionsToSpec(
          agentsDir,
          session2.data.spec,
          decideEntries,
          session2.data.branch || branch
        );
        if (result.success) {
          console.log(`  ${green11("\u2713")} ${result.message}`);
        } else {
          console.log(`  ${yellow13("\u26A0")} Could not persist to spec: ${result.message}`);
        }
        console.log();
      }
    }
    const now = getTimestamp();
    session2.data.status = "archived";
    session2.data.archived_at = now;
    session2.data.last_updated = now;
    const newContent = matter13.stringify(
      session2.content,
      session2.data
    );
    writeFileSync19(sessionFilePath, newContent, "utf-8");
    const fileName = basename7(sessionFilePath);
    const archivePath = join36(archiveDir, fileName);
    try {
      renameSync3(sessionFilePath, archivePath);
      console.log(`  ${green11("\u2713")} Archived: ${gray13(archivePath.replace(agentsDir, ".agents"))}`);
    } catch (err) {
      console.error(`  ${red10("error:")} Failed to move file: ${err}`);
      process.exit(1);
    }
    console.log();
  });
  session.command("list").description("List all active and archived sessions").option("--all", "Include archived sessions").action(async (options) => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const sessionsDir = join36(agentsDir, "sessions");
    if (!existsSync32(sessionsDir)) {
      console.log(`
  ${gray13("No sessions directory found.")}`);
      console.log(`  Run ${cyan9("loaf session start")} to create your first session.
`);
      return;
    }
    console.log(`
  ${bold12("loaf session list")}
`);
    const activeSessions = [];
    const files = readdirSync14(sessionsDir).filter((f) => f.endsWith(".md"));
    for (const file of files) {
      const filePath = join36(sessionsDir, file);
      const session2 = readSessionFile(filePath);
      if (session2 && session2.data.status !== "archived") {
        activeSessions.push({ ...session2, filePath, isArchived: false });
      }
    }
    const archivedSessions = [];
    if (options.all) {
      const archiveDir = join36(sessionsDir, "archive");
      if (existsSync32(archiveDir)) {
        const archiveFiles = readdirSync14(archiveDir).filter((f) => f.endsWith(".md"));
        for (const file of archiveFiles) {
          const filePath = join36(archiveDir, file);
          const session2 = readSessionFile(filePath);
          if (session2) {
            archivedSessions.push({ ...session2, filePath, isArchived: true });
          }
        }
      }
    }
    if (activeSessions.length === 0) {
      console.log(`  ${gray13("No active sessions found.")}`);
    } else {
      console.log(`  ${bold12("Active Sessions")}:`);
      for (const s of activeSessions) {
        const statusColor = s.data.status === "active" ? green11 : yellow13;
        const specInfo = s.data.spec ? gray13(` (${s.data.spec})`) : "";
        const lastUpdated = s.data.last_updated ? gray13(` \u2014 updated ${new Date(s.data.last_updated).toLocaleDateString()}`) : "";
        console.log(`    ${statusColor("\u25CF")} ${s.data.branch}${specInfo}${lastUpdated}`);
        console.log(`      ${gray13(s.filePath.replace(agentsDir, ".agents"))}`);
      }
    }
    if (options.all && archivedSessions.length > 0) {
      console.log();
      console.log(`  ${bold12("Archived Sessions")}:`);
      for (const s of archivedSessions) {
        const archivedDate = s.data.archived_at ? gray13(` \u2014 archived ${new Date(s.data.archived_at).toLocaleDateString()}`) : "";
        console.log(`    ${gray13("\u25CB")} ${s.data.branch}${archivedDate}`);
        console.log(`      ${gray13(s.filePath.replace(agentsDir, ".agents"))}`);
      }
    }
    console.log();
    console.log(`  ${activeSessions.length} active${options.all ? `, ${archivedSessions.length} archived` : ""}`);
    console.log();
  });
}

// cli/index.ts
var __dirname6 = dirname15(fileURLToPath8(import.meta.url));
function getVersion5() {
  for (const candidate of [join37(__dirname6, "..", "package.json"), join37(__dirname6, "..", "..", "package.json")]) {
    try {
      const pkg = JSON.parse(readFileSync29(candidate, "utf-8"));
      if (pkg.name === "loaf") return pkg.version;
    } catch {
      continue;
    }
  }
  return "0.0.0";
}
var program = new Command();
program.name("loaf").description("Loaf \u2014 An Opinionated Agentic Framework").version(getVersion5(), "-v, --version");
registerBuildCommand(program);
registerInstallCommand(program);
registerInitCommand(program);
registerReleaseCommand(program);
registerTaskCommand(program);
registerSpecCommand(program);
registerKbCommand(program);
registerSetupCommand(program);
registerVersionCommand(program);
registerCleanupCommand(program);
registerCheckCommand(program);
registerSessionCommand(program);
if (process.argv.includes("--agent-help")) {
  const { generateCliJson: generateCliJson2 } = await Promise.resolve().then(() => (init_cli_reference_generator(), cli_reference_generator_exports));
  console.log(generateCliJson2(program));
  process.exit(0);
}
if (process.argv.length <= 2) {
  program.outputHelp();
  process.exit(0);
}
program.parse();
