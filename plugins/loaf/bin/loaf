  kb.command("init").description("Initialize knowledge base directories and QMD collections").option("--json", "Output results as JSON").action(async (options2) => {
    let gitRoot;
    try {
      gitRoot = findGitRoot();
    } catch {
      if (!options2.json) {
        console.error(`  ${red6("error:")} Not inside a git repository`);
      }
      process.exit(1);
    }
    const repoName = basename4(gitRoot);
    const actions = [];
    const dirs = ["docs/knowledge", "docs/decisions"];
    for (const dir of dirs) {
      const fullPath = join34(gitRoot, dir);
      if (existsSync29(fullPath)) {
        actions.push({ action: "directory", target: dir, status: "exists" });
      } else {
        mkdirSync19(fullPath, { recursive: true });
        actions.push({ action: "directory", target: dir, status: "created" });
      }
    }
    const configPath = join34(gitRoot, ".agents", "loaf.json");
    let configStatus = "exists";
    if (!existsSync29(configPath)) {
      const agentsDir = join34(gitRoot, ".agents");
      if (!existsSync29(agentsDir)) {
        mkdirSync19(agentsDir, { recursive: true });
      }
      const config = {
        knowledge: {
          local: ["docs/knowledge", "docs/decisions"],
          staleness_threshold_days: 30,
          imports: []
        }
      };
      writeFileSync18(configPath, JSON.stringify(config, null, 2) + "\n", "utf-8");
      configStatus = "created";
    } else {
      try {
        const raw = readFileSync24(configPath, "utf-8");
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
          configStatus = "exists";
        } else if (!parsed.knowledge || typeof parsed.knowledge !== "object" || Array.isArray(parsed.knowledge)) {
          parsed.knowledge = {
            local: ["docs/knowledge", "docs/decisions"],
            staleness_threshold_days: 30,
            imports: []
          };
          writeFileSync18(configPath, JSON.stringify(parsed, null, 2) + "\n", "utf-8");
          configStatus = "updated";
        }
      } catch {
        configStatus = "exists";
      }
    }
    actions.push({
      action: "config",
      target: ".agents/loaf.json",
      status: configStatus === "updated" ? "created" : configStatus
    });
    const qmdAvailable = isQmdAvailable();
    const qmdActions = [];
    if (qmdAvailable) {
      const existing = listCollections();
      const collections = [
        { name: `${repoName}-knowledge`, path: join34(gitRoot, "docs/knowledge") },
        { name: `${repoName}-decisions`, path: join34(gitRoot, "docs/decisions") }
      ];
      for (const col of collections) {
        if (existing.includes(col.name)) {
          qmdActions.push({ collection: col.name, path: col.path, status: "exists" });
        } else {
          registerCollection(col.name, col.path);
          qmdActions.push({ collection: col.name, path: col.path, status: "registered" });
        }
      }
    }
    if (options2.json) {
      const output = {
        directories: actions.filter((a) => a.action === "directory"),
        config: { path: ".agents/loaf.json", status: configStatus },
        qmd: {
          available: qmdAvailable,
          collections: qmdActions
        }
      };
      process.stdout.write(JSON.stringify(output, null, 2) + "\n");
      return;
    }
    console.log(`
  ${bold8("loaf kb init")}
`);
    for (const a of actions) {
      if (a.status === "created") {
        console.log(`  ${green8("+")} Created ${a.target}`);
      } else {
        console.log(`  ${gray9("-")} Already exists: ${a.target}`);
      }
    }
    if (configStatus === "updated") {
      console.log(`  ${green8("+")} Added knowledge section to .agents/loaf.json`);
    }
    console.log();
    if (qmdAvailable) {
      console.log(`  ${bold8("QMD")}`);
      for (const qa of qmdActions) {
        if (qa.status === "registered") {
          console.log(`  ${green8("+")} Registered collection: ${cyan6(qa.collection)}`);
        } else {
          console.log(`  ${gray9("-")} Collection exists: ${cyan6(qa.collection)}`);
        }
      }
    } else {
      console.log(`  ${bold8("QMD")}`);
      console.log(`  ${yellow10("info:")} QMD not found. Install QMD for knowledge retrieval:`);
      console.log(`        ${cyan6("https://github.com/tobi/qmd")}`);
    }
    console.log();
    console.log(`  ${green8("\u2713")} Knowledge base initialized`);
    console.log();
  });
  kb.command("import").description("Import external project knowledge via QMD collection").argument("<name>", "Name of the external project's knowledge collection").option("--path <path>", "Path to the external project's knowledge directory").option("--json", "Output results as JSON").action(async (name, options2) => {
    if (!isQmdAvailable()) {
      if (options2.json) {
        process.stdout.write(
          JSON.stringify({ error: "QMD is required for importing external knowledge" }, null, 2) + "\n"
        );
      } else {
        console.error(
          `  ${red6("error:")} QMD is required for importing external knowledge. Install QMD: ${cyan6("https://github.com/tobi/qmd")}`
        );
      }
      process.exit(1);
    }
    let gitRoot;
    try {
      gitRoot = findGitRoot();
    } catch {
      if (!options2.json) {
        console.error(`  ${red6("error:")} Not inside a git repository`);
      }
      process.exit(1);
    }
    const config = loadKbConfig(gitRoot);
    const collectionName = `${name}-knowledge`;
    if (config.imports.some((i) => i.name === name)) {
      if (options2.json) {
        process.stdout.write(
          JSON.stringify({ name, collection: collectionName, status: "already_imported" }, null, 2) + "\n"
        );
      } else {
        console.log(`  Already imported: ${bold8(name)}`);
      }
      process.exit(0);
    }
    const configPath = join34(gitRoot, ".agents", "loaf.json");
    let parsed = {};
    if (existsSync29(configPath)) {
      try {
        const raw = readFileSync24(configPath, "utf-8");
        const result = JSON.parse(raw);
        if (!result || typeof result !== "object" || Array.isArray(result)) {
          throw new Error("Expected a JSON object");
        }
        parsed = result;
      } catch {
        if (options2.json) {
          process.stdout.write(
            JSON.stringify({ error: "Cannot parse .agents/loaf.json \u2014 fix or remove it before importing" }, null, 2) + "\n"
          );
        } else {
          console.error(`  ${red6("error:")} Cannot parse .agents/loaf.json \u2014 fix or remove it before importing`);
        }
        process.exit(1);
      }
    } else {
      const agentsDir = join34(gitRoot, ".agents");
      if (!existsSync29(agentsDir)) {
        mkdirSync19(agentsDir, { recursive: true });
      }
    }
    const existing = listCollections();
    const collectionExists = existing.includes(collectionName);
    if (!collectionExists) {
      try {
        const collectionPath = options2.path ?? name;
        registerCollection(collectionName, collectionPath);
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        if (options2.json) {
          process.stdout.write(
            JSON.stringify({ error: `Failed to register collection: ${message}` }, null, 2) + "\n"
          );
        } else {
          console.error(`  ${red6("error:")} Failed to register QMD collection: ${message}`);
        }
        process.exit(1);
      }
    }
    if (!parsed.knowledge || typeof parsed.knowledge !== "object" || Array.isArray(parsed.knowledge)) {
      parsed.knowledge = { local: ["docs/knowledge", "docs/decisions"], staleness_threshold_days: 30, imports: [] };
    }
    const kb2 = parsed.knowledge;
    if (!Array.isArray(kb2.imports)) {
      kb2.imports = [];
    }
    kb2.imports.push({ name });
    writeFileSync18(configPath, JSON.stringify(parsed, null, 2) + "\n", "utf-8");
    if (options2.json) {
      process.stdout.write(
        JSON.stringify({ name, collection: collectionName, status: "imported" }, null, 2) + "\n"
      );
      return;
    }
    console.log(`  Imported: ${bold8(name)}`);
  });
}

