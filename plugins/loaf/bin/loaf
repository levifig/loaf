function generateCoreFunctions(platform2) {
  return `// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
// Core Hook Functions
// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

/**
 * Run a hook via subprocess (loaf check or script execution)
 * 
 * Exit codes:
 *   0 = allow (hook passed)
 *   1 = error (hook failed but not blocking)
 *   2 = block (hook rejected the action)
 * 
 * @param hookType - 'pre-tool', 'post-tool', or 'session'
 * @param toolName - Name of the tool being invoked
 * @param hookId - Specific hook identifier
 * @param command - Direct command to execute (alternative to script)
 * @param script - Script file to execute
 * @param timeout - Maximum execution time in milliseconds
 * @param failClosed - When true, subprocess errors block the action
 * @returns Hook result with exit code, output, and error information
 */
interface HookResult {
  exitCode: number;
  stdout: string;
  stderr: string;
  error?: string;
}

function serializeHookPayload(toolName: string, toolInput: unknown, rawInput?: unknown): string | undefined {
  const normalizedToolInput =
    toolInput && typeof toolInput === 'object'
      ? toolInput
      : toolInput === undefined
        ? {}
        : { value: toolInput };

  try {
    return JSON.stringify({
      tool: { name: toolName || '' },
      tool_name: toolName || '',
      tool_input: normalizedToolInput,
      input: normalizedToolInput,
      raw: rawInput,
    });
  } catch {
    return undefined;
  }
}

async function runHook(
  hookType: string,
  toolName: string,
  hookId: string,
  command?: string,
  script?: string,
  payload?: string,
  timeout: number = 60000,
  failClosed: boolean = false,
): Promise<HookResult> {
  const env = {
    ...process.env,
    LOAF_HOOK_TYPE: hookType,
    LOAF_HOOK_ID: hookId,
    LOAF_TOOL_NAME: toolName || '',
  };

  try {
    // If hook has direct command (e.g., 'loaf check ...'), execute it
    if (command) {
      const child = execFile('bash', ['-c', command], {
        cwd: process.cwd(),
        env,
        encoding: 'utf-8',
        timeout,
      });
      if (payload && child.stdin) {
        child.stdin.write(payload);
        child.stdin.end();
      }
      
      const result = await new Promise<HookResult>((resolve) => {
        let stdoutStr = '';
        let stderrStr = '';
        child.stdout?.on('data', (data) => stdoutStr += data);
        child.stderr?.on('data', (data) => stderrStr += data);
        child.on('close', (code) => {
          resolve({ exitCode: code || 0, stdout: stdoutStr, stderr: stderrStr });
        });
        child.on('error', (err) => {
          resolve({ exitCode: failClosed ? 2 : 1, stdout: stdoutStr, stderr: stderrStr || err.message, error: err.message });
        });
      });
      return result;
    }

    // Otherwise run the script file
    if (script) {
      const scriptPath = join(__dirname, 'hooks', script);
      const interpreter = script.endsWith('.py') ? 'python3' : 'bash';
      const child = execFile(interpreter, [scriptPath], {
        cwd: process.cwd(),
        env,
        encoding: 'utf-8',
        timeout,
      });
      if (payload && child.stdin) {
        child.stdin.write(payload);
        child.stdin.end();
      }
      
      const result = await new Promise<HookResult>((resolve) => {
        let stdoutStr = '';
        let stderrStr = '';
        child.stdout?.on('data', (data) => stdoutStr += data);
        child.stderr?.on('data', (data) => stderrStr += data);
        child.on('close', (code) => {
          resolve({ exitCode: code || 0, stdout: stdoutStr, stderr: stderrStr });
        });
        child.on('error', (err) => {
          resolve({ exitCode: failClosed ? 2 : 1, stdout: stdoutStr, stderr: stderrStr || err.message, error: err.message });
        });
      });
      return result;
    }

    return { exitCode: 1, stdout: '', stderr: 'No command or script specified' };
  } catch (error: any) {
    return {
      exitCode: failClosed ? 2 : 1,
      stdout: '',
      stderr: error.message,
      error: error.message,
    };
  }
}

/**
 * Check if a tool name matches a pattern
 * Patterns can be:
 *   - Simple wildcard: "Bash*" matches "Bash", "BashFile", etc.
 *   - Union pattern: "Edit|Write" matches either
 *   - Exact match: "Edit" matches only "Edit"
 */
function matchesTool(toolName: string, pattern: string): boolean {
  if (!toolName || !pattern) return false;
  
  const patterns = pattern.split('|');
  return patterns.some((p) => {
    const trimmed = p.trim();
    if (trimmed.endsWith('*')) {
      return toolName.startsWith(trimmed.slice(0, -1));
    }
    return toolName === trimmed;
  });
}

function matchesIfCondition(toolName: string, toolInput: unknown, ifCondition: string | undefined): boolean {
  if (!ifCondition) return true;
  
  // Parse pattern like "Bash(gh pr merge:*)" or "Bash(git push:*)"
  // Tool name before '(' and command pattern inside parentheses
  const match = ifCondition.match(/^(\\w+)\\(([^)]+)\\)$/);
  if (!match) return true;
  
  const [, expectedTool, commandPattern] = match;
  if (toolName !== expectedTool) return false;
  
  const input = toolInput as Record<string, unknown> | undefined;
  const command = (input?.command || input?.file_path) as string | undefined;
  if (!command) return false;
  
  // Handle glob patterns with :* suffix (e.g., "git commit:*" means "starts with git commit")
  // The :* format treats everything before : as a literal prefix, * matches anything after
  if (commandPattern.endsWith(':')) {
    // Pattern like "git commit:" - match commands starting with this prefix
    const prefix = commandPattern.slice(0, -1);
    return command.startsWith(prefix);
  }
  
  if (commandPattern.endsWith(':*')) {
    // Pattern like "git commit:*" - match commands starting with "git commit"
    const prefix = commandPattern.slice(0, -2);
    return command.startsWith(prefix);
  }
  
  // For other patterns, convert glob to regex
  // Escape regex special characters then convert * to .* and ? to .
  let regexPattern = commandPattern
    .replace(/[.+^$"{}()|[]\\]/g, '\\$&')
    .replace(/*/g, '.*')
    .replace(/?/g, '.');
  
  const regex = new RegExp('^' + regexPattern + '$');
  return regex.test(command);
}
`;
}
function generateHookData(config) {
  const preToolHooks = config.hooks["pre-tool"] || [];
  const postToolHooks = config.hooks["post-tool"] || [];
  const sessionHooks = config.hooks.session || [];
  const commandPreToolHooks = preToolHooks.filter((h) => h.type !== "prompt");
  const commandPostToolHooks = postToolHooks.filter((h) => h.type !== "prompt");
  const commandSessionHooks = sessionHooks.filter((h) => h.type !== "prompt");
  const preToolByMatcher = groupHooksByMatcher(commandPreToolHooks);
  const postToolByMatcher = groupHooksByMatcher(commandPostToolHooks);
  const sessionByEvent = groupSessionHooksByEvent(commandSessionHooks);
  return `// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
// Hook Data
// \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

interface HookEntry {
  id: string;
  command?: string;
  script?: string;
  timeout: number;
  failClosed: boolean;
  if?: string;
}

const preToolHooks: Record<string, HookEntry[]> = ${JSON.stringify(preToolByMatcher, null, 2)};

const postToolHooks: Record<string, HookEntry[]> = ${JSON.stringify(postToolByMatcher, null, 2)};

const sessionHooks: Record<string, HookEntry[]> = ${JSON.stringify(sessionByEvent, null, 2)};`;
}
function generatePluginBody(config, platform2) {
  const preToolEvent = platform2.events.preTool;
  const postToolEvent = platform2.events.postTool;
  const sessionStartEvent = platform2.events.sessionStart;
  const sessionEndEvent = platform2.events.sessionEnd;
  let body = `    // Pre-tool hook handler
    '${preToolEvent}': async (input) => {
      const toolName = ${platform2.toolNameAccessor};
      const toolInput = ${platform2.toolInputAccessor};
      if (!toolName) return;

      const hookPayload = serializeHookPayload(toolName, toolInput, input);

      for (const [matcher, hookList] of Object.entries(preToolHooks)) {
        if (matchesTool(toolName, matcher)) {
          for (const hook of hookList) {
            if (!matchesIfCondition(toolName, toolInput, hook.if)) continue;
            const result = await runHook('pre-tool', toolName, hook.id, hook.command, hook.script, hookPayload, hook.timeout, hook.failClosed);
            
            // Exit code 2 = block the action
            if (result.exitCode === 2) {
              ${platform2.rejectPattern("result.stderr")}
            }
            
            // Log errors for debugging
            if (result.exitCode === 1) {
              console.warn(\`[loaf] Hook \${hook.id} error: \${result.stderr}\`);
            }
          }
        }
      }
    },

    // Post-tool hook handler
    '${postToolEvent}': async (input) => {
      const toolName = ${platform2.toolNameAccessor};
      const toolInput = ${platform2.toolInputAccessor};
      if (!toolName) return;

      const hookPayload = serializeHookPayload(toolName, toolInput, input);

      for (const [matcher, hookList] of Object.entries(postToolHooks)) {
        if (matchesTool(toolName, matcher)) {
          for (const hook of hookList) {
            if (!matchesIfCondition(toolName, toolInput, hook.if)) continue;
            const result = await runHook('post-tool', toolName, hook.id, hook.command, hook.script, hookPayload, hook.timeout, hook.failClosed);
            
            if (result.exitCode !== 0) {
              console.warn(\`[loaf] Post-hook \${hook.id} error (exit \${result.exitCode}): \${result.stderr}\`);
            }
          }
        }
      }
    }`;
  if (sessionStartEvent || sessionEndEvent) {
    body += `,
`;
    if (platform2.platform === "opencode") {
      body += generateOpenCodeSessionHandlers(config, platform2);
    } else if (platform2.platform === "amp") {
      body += generateAmpSessionHandlers(config, platform2);
    }
  }
  return body;
}
function generateOpenCodeSessionHandlers(config, platform2) {
  let body = `    // Session lifecycle event handler
    'event': async ({ event }) => {
      if (event.type === '${platform2.events.sessionStart}' && sessionHooks.sessionstart) {
        for (const hook of sessionHooks.sessionstart) {
          await runHook('session', 'session', hook.id, hook.command, hook.script, undefined, hook.timeout, hook.failClosed);
        }
      }
      if (event.type === '${platform2.events.sessionEnd}' && sessionHooks.sessionend) {
        for (const hook of sessionHooks.sessionend) {
          await runHook('session', 'session', hook.id, hook.command, hook.script, undefined, hook.timeout, hook.failClosed);
        }
      }`;
  const extraEvents = generateOpenCodeExtraEvents(config);
  if (extraEvents) {
    body += `
${extraEvents}`;
  }
  body += `
    }`;
  return body;
}
function generateOpenCodeExtraEvents(config) {
  const compactingHooks = config.hooks.session?.filter(
    (h) => h.event?.toLowerCase() === "precompact" && h.type !== "prompt"
  ) || [];
  if (compactingHooks.length === 0) return "";
  return `      if (event.type === 'context.compacting' && sessionHooks.precompact) {
        for (const hook of sessionHooks.precompact) {
          await runHook('session', 'session', hook.id, hook.command, hook.script, undefined, hook.timeout, hook.failClosed);
        }
      }`;
}
function generateAmpSessionHandlers(config, platform2) {
  let handlers = "";
  if (platform2.events.sessionStart) {
    handlers += `  // Session start handler
  '${platform2.events.sessionStart}': async () => {
    if (sessionHooks.sessionstart) {
      for (const hook of sessionHooks.sessionstart) {
        await runHook('session', 'session', hook.id, hook.command, hook.script, undefined, hook.timeout, hook.failClosed);
      }
    }
  },
`;
  }
  if (platform2.events.sessionEnd) {
    handlers += `  // Session end handler
  '${platform2.events.sessionEnd}': async () => {
    if (sessionHooks.sessionend) {
      for (const hook of sessionHooks.sessionend) {
        await runHook('session', 'session', hook.id, hook.command, hook.script, undefined, hook.timeout, hook.failClosed);
      }
    }
  },
`;
  }
  return handlers.slice(0, -2);
}
function groupHooksByMatcher(hooks) {
  const grouped = {};
  for (const hook of hooks) {
    const matcher = hook.matcher || "Edit|Write";
    if (!grouped[matcher]) grouped[matcher] = [];
    let command = hook.command;
    if (!command && !hook.script && ENFORCEMENT_HOOKS.has(hook.id)) {
      command = `loaf check --hook ${hook.id}`;
    }
    grouped[matcher].push({
      id: hook.id,
      command,
      script: hook.script ? getScriptFilename(hook.script) : void 0,
      timeout: hook.timeout || 6e4,
      failClosed: hook.failClosed || false,
      if: hook.if
    });
  }
  return grouped;
}
function groupSessionHooksByEvent(hooks) {
  const grouped = {};
  for (const hook of hooks) {
    const event = (hook.event || "").toLowerCase().replace(/\s+/g, "");
    if (!event) continue;
    if (!grouped[event]) grouped[event] = [];
    let command = hook.command;
    if (!command && !hook.script && ENFORCEMENT_HOOKS.has(hook.id)) {
      command = `loaf check --hook ${hook.id}`;
    }
    grouped[event].push({
      id: hook.id,
      command,
      script: hook.script ? getScriptFilename(hook.script) : void 0,
      timeout: hook.timeout || 6e4,
      failClosed: hook.failClosed || false,
      if: hook.if
    });
  }
  return grouped;
}
function getScriptFilename(scriptPath) {
  const parts = scriptPath.split("/");
  return parts.slice(-2).join("/");
}

// cli/lib/build/targets/opencode.ts
function substituteCommands(content) {
  return content.replace(/\{\{IMPLEMENT_CMD\}\}/g, "/implement").replace(/\{\{RESUME_CMD\}\}/g, "/resume").replace(/\{\{ORCHESTRATE_CMD\}\}/g, "/implement");
}
async function build2({
  config,
  targetsConfig,
  rootDir,
  srcDir,
  distDir
}) {
  const version = getVersion(rootDir);
  const transformMd = (content) => substituteCommands(content);
  if (existsSync7(distDir)) {
    rmSync2(distDir, { recursive: true });
  }
  mkdirSync7(distDir, { recursive: true });
  copySkills2(rootDir, srcDir, distDir, targetsConfig, transformMd, version);
  copyAgents2(srcDir, distDir, version);
  generateCommandsFromSkills(rootDir, distDir, version);
  generateRuntimePlugin(
    config,
    srcDir,
    distDir,
    OpenCodePlatform,
    version
  );
  const soulTemplateSrc = join9(srcDir, "templates", "soul.md");
  if (existsSync7(soulTemplateSrc)) {
    const templatesDir = join9(distDir, "templates");
    mkdirSync7(templatesDir, { recursive: true });
    cpSync4(soulTemplateSrc, join9(templatesDir, "soul.md"));
  }
  const hooksSrc = join9(srcDir, "hooks");
  if (existsSync7(hooksSrc)) {
    const hooksDest = join9(distDir, "plugins", "hooks");
    mkdirSync7(hooksDest, { recursive: true });
    cpSync4(hooksSrc, hooksDest, { recursive: true });
  }
}
function copySkills2(rootDir, srcDir, distDir, targetsConfig, transformMd, version) {
  const destDir = join9(distDir, "skills");
  mkdirSync7(destDir, { recursive: true });
  copySkills({
    srcDir: join9(rootDir, "dist"),
    // Reads from dist/skills/
    destDir,
    targetName: "opencode",
    version,
    targetsConfig,
    transformMd,
    mergeFrontmatter: (base, skillDir) => {
      const skillName = skillDir.split("/").pop() || "";
      const sidecarPath = join9(srcDir, "skills", skillName, "SKILL.opencode.yaml");
      if (existsSync7(sidecarPath)) {
        const sidecarContent = readFileSync8(sidecarPath, "utf-8");
        const sidecar = parseYaml2(sidecarContent) || {};
        return { ...base, ...sidecar };
      }
      return base;
    }
  });
}
function copyAgents2(srcDir, distDir, version) {
  const destDir = join9(distDir, "agents");
  mkdirSync7(destDir, { recursive: true });
  copyAgents({
    srcDir,
    destDir,
    targetName: "opencode",
    version,
    sidecarRequired: false
  });
}
function generateCommandsFromSkills(rootDir, distDir, version) {
  const skillsSrc = join9(rootDir, "dist", "skills");
  const sidecarsSrc = join9(rootDir, "content", "skills");
  const commandsDest = join9(distDir, "commands");
  if (!existsSync7(skillsSrc)) return;
  mkdirSync7(commandsDest, { recursive: true });
  const skills = readdirSync5(skillsSrc, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name);
  for (const skill of skills) {
    const sidecarPath = join9(sidecarsSrc, skill, "SKILL.opencode.yaml");
    if (!existsSync7(sidecarPath)) continue;
    const skillMdPath = join9(skillsSrc, skill, "SKILL.md");
    if (!existsSync7(skillMdPath)) continue;
    const content = readFileSync8(skillMdPath, "utf-8");
    const { content: body, data: skillFrontmatter } = matter4(content);
    const sidecarContent = readFileSync8(sidecarPath, "utf-8");
    const sidecar = parseYaml2(sidecarContent) || {};
    const mergedFrontmatter = {
      description: skillFrontmatter.description || "",
      ...sidecar,
      version
    };
    const relinked = body.replace(/\]\(templates\//g, `](../skills/${skill}/templates/`).replace(/\]\(references\//g, `](../skills/${skill}/references/`);
    const transformed = substituteCommands(matter4.stringify(relinked, mergedFrontmatter));
    writeFileSync7(join9(commandsDest, `${skill}.md`), transformed);
  }
}

// cli/lib/build/targets/cursor.ts
var cursor_exports = {};
__export(cursor_exports, {
  build: () => build3
});
import {
  mkdirSync as mkdirSync8,
  cpSync as cpSync5,
  writeFileSync as writeFileSync8,
  existsSync as existsSync8,
  readdirSync as readdirSync6,
  rmSync as rmSync3
} from "fs";
import { join as join10 } from "path";
var TARGET_NAME2 = "cursor";
var DEFAULT_AGENT_FRONTMATTER = {
  model: "inherit",
  is_background: true
};
var BINARY_PATH_HOOKS2 = /* @__PURE__ */ new Set([
  // Enforcement hooks
  "check-secrets",
  "validate-push",
  "validate-commit",
  "workflow-pre-pr",
  "security-audit",
  // Session lifecycle hooks
  "session-start-loaf",
  "session-end-loaf",
  // Journal auto-entry hooks
  "journal-post-commit",
  "journal-post-pr",
