    },
    manualHint: "uvx -p 3.13 --from git+https://github.com/oraios/serena serena start-mcp-server --project-from-cwd"
  }
];
function blobMatchesLinear(blob) {
  const b = blob.toLowerCase();
  return b.includes("mcp.linear.app") || /\blinear\b/.test(b);
}
function blobMatchesSerena(blob) {
  const b = blob.toLowerCase();
  return b.includes("oraios/serena") || b.includes("serena start-mcp-server") || b.includes("serena") && b.includes("uvx");
}
function getMatcher(mcpId) {
  if (mcpId === "linear") return blobMatchesLinear;
  if (mcpId === "serena") return blobMatchesSerena;
  return null;
}
function parseClaudeMcpListOutput(output) {
  const names = /* @__PURE__ */ new Set();
  for (const line of output.split(/\r?\n/)) {
    const t = line.trim();
    if (!t) continue;
    const m = t.match(/^(?:[\d.]+\s+|[•*-]\s+)?([a-zA-Z0-9_:-]+)\b/);
    if (!m) continue;
    const full = m[1].toLowerCase();
    names.add(full);
    const parts = full.split(":");
    if (parts.length > 1) {
      names.add(parts[parts.length - 1]);
    }
  }
  return names;
}
var claudeListCache = null;
function claudeListNames() {
  if (process.env.VITEST === "true" || process.env.LOAF_SKIP_CLAUDE_MCP_LIST === "1") {
    return /* @__PURE__ */ new Set();
  }
  if (claudeListCache) return claudeListCache;
  try {
    const out = execFileSync3("claude", ["mcp", "list"], {
      encoding: "utf-8",
      stdio: ["ignore", "pipe", "pipe"],
      maxBuffer: 2 * 1024 * 1024,
      timeout: 2500
    });
    claudeListCache = parseClaudeMcpListOutput(out);
  } catch {
    claudeListCache = /* @__PURE__ */ new Set();
  }
  return claudeListCache;
}
function safeJson(path) {
  try {
    if (!existsSync15(path)) return null;
    return JSON.parse(readFileSync13(path, "utf-8"));
  } catch {
    return null;
  }
}
function resolveKey(obj, key) {
  if (!obj || typeof obj !== "object") return void 0;
  const o = obj;
  if (key in o) return o[key];
  const parts = key.split(".");
  let current = obj;
  for (const part of parts) {
    if (!current || typeof current !== "object") return void 0;
    current = current[part];
  }
  return current;
}
function scanMcpServersGeneric(raw, mcpKey, id, match) {
  const servers = resolveKey(raw, mcpKey);
  if (!servers || typeof servers !== "object") return false;
  const entries = servers;
  if (id in entries) return true;
  for (const [, spec] of Object.entries(entries)) {
    if (match(JSON.stringify(spec))) return true;
  }
  return false;
}
function scanTomlForMcp(path, id, match) {
  try {
    if (!existsSync15(path)) return false;
    const content = readFileSync13(path, "utf-8");
    if (content.includes(`[mcp_servers.${id}]`)) return true;
    return match(content);
  } catch {
    return false;
  }
}
function detectMcpForTarget(projectRoot, target, mcpId) {
  const config = TARGET_MCP_CONFIGS[target];
  if (!config) return { configured: false, scope: null };
  const match = getMatcher(mcpId);
  if (!match) return { configured: false, scope: null };
  if (config.format === "toml") {
    for (const p of config.globalPaths) {
      if (scanTomlForMcp(expandHome(p), mcpId, match)) {
        return { configured: true, scope: "global" };
      }
    }
    for (const p of config.projectPaths) {
      if (scanTomlForMcp(join20(projectRoot, p), mcpId, match)) {
        return { configured: true, scope: "project" };
      }
    }
  } else {
    for (const p of config.globalPaths) {
      const j = safeJson(expandHome(p));
      if (scanMcpServersGeneric(j, config.mcpKey, mcpId, match)) {
        return { configured: true, scope: "global" };
      }
    }
    for (const p of config.projectPaths) {
      const j = safeJson(join20(projectRoot, p));
      if (scanMcpServersGeneric(j, config.mcpKey, mcpId, match)) {
        return { configured: true, scope: "project" };
      }
    }
  }
  if (target === "claude-code") {
    if (claudeListNames().has(mcpId)) {
      return { configured: true, scope: "global" };
    }
  }
  return { configured: false, scope: null };
}
function buildMcpStatuses(projectRoot, targets) {
  const targetList = targets ?? Object.keys(TARGET_MCP_CONFIGS);
  return MCP_REGISTRY.map((def) => {
    const targetStatuses = {};
    for (const t of targetList) {
      targetStatuses[t] = detectMcpForTarget(projectRoot, t, def.id);
    }
    return {
      id: def.id,
      displayName: def.displayName,
      tier: def.tier,
      targets: targetStatuses
    };
  });
}
function getMcpDefinition(id) {
  return MCP_REGISTRY.find((d) => d.id === id);
}
function getMcpArgs(def, target) {
  return def.targetArgs?.[target] ?? def.defaultArgs;
}
function isLinearIntegrationDisabled(projectRoot) {
  const cfg = readLoafConfig(projectRoot);
  return cfg.integrations?.linear?.enabled === false;
}

// cli/lib/install/mcp-recommendations.ts
var bold2 = (s) => `\x1B[1m${s}\x1B[0m`;
var green2 = (s) => `\x1B[32m${s}\x1B[0m`;
var gray2 = (s) => `\x1B[90m${s}\x1B[0m`;
var yellow = (s) => `\x1B[33m${s}\x1B[0m`;
function ask(question) {
  const rl = createInterface({
    input: process.stdin,
    output: process.stdout
  });
  return new Promise((resolve2) => {
    rl.question(question, (answer) => {
      rl.close();
      resolve2(answer.trim().toLowerCase());
    });
  });
}
function parseScope(answer) {
  if (answer.startsWith("g")) return "global";
  if (answer.startsWith("p")) return "project";
  return "no";
}
function installViaClaude(def, scope) {
  const scopeFlag = scope === "global" ? "user" : "project";
  const args = getMcpArgs(def, "claude-code");
  execFileSync4(
    "claude",
    ["mcp", "add", "--scope", scopeFlag, def.id, "--", ...args],
    { stdio: "inherit" }
  );
}
function mergeJsonMcpConfig(filePath, mcpKey, serverId, args) {
  const dir = join21(filePath, "..");
  if (!existsSync16(dir)) mkdirSync14(dir, { recursive: true });
  let data = {};
  if (existsSync16(filePath)) {
    try {
      data = JSON.parse(readFileSync14(filePath, "utf-8"));
    } catch {
      data = {};
    }
  }
  let servers;
  if (mcpKey in data && typeof data[mcpKey] === "object" && data[mcpKey] !== null) {
    servers = data[mcpKey];
  } else if (mcpKey.includes(".")) {
    const parts = mcpKey.split(".");
    let current = data;
    for (const part of parts.slice(0, -1)) {
      if (!current[part] || typeof current[part] !== "object") {
        current[part] = {};
      }
      current = current[part];
    }
    const lastPart = parts[parts.length - 1];
    if (!current[lastPart] || typeof current[lastPart] !== "object") {
      current[lastPart] = {};
    }
    servers = current[lastPart];
  } else {
    data[mcpKey] = {};
    servers = data[mcpKey];
  }
  servers[serverId] = {
    command: args[0],
    args: args.slice(1)
  };
  writeFileSync13(filePath, `${JSON.stringify(data, null, 2)}
`, "utf-8");
}
function mergeOpencodeMcpConfig(filePath, serverId, args) {
  const dir = join21(filePath, "..");
  if (!existsSync16(dir)) mkdirSync14(dir, { recursive: true });
  let data = {};
  if (existsSync16(filePath)) {
    try {
      data = JSON.parse(readFileSync14(filePath, "utf-8"));
    } catch {
      data = {};
    }
  }
  if (!data.mcp || typeof data.mcp !== "object") {
    data.mcp = {};
  }
  const servers = data.mcp;
  servers[serverId] = {
    type: "local",
    command: args,
    enabled: true
  };
  writeFileSync13(filePath, `${JSON.stringify(data, null, 2)}
`, "utf-8");
}
function installMcpForTarget(target, def, scope, projectRoot) {
  const args = getMcpArgs(def, target);
  const config = getTargetMcpConfig(target);
  if (!config) return { ok: false, message: `Unknown target: ${target}` };
  try {
    if (target === "claude-code") {
      if (!detectClaudeCode()) {
        return { ok: false, message: "Claude Code CLI not found" };
      }
      installViaClaude(def, scope);
      return { ok: true, message: `${scope} scope` };
    }
    if (target === "codex") {
      try {
        execFileSync4("codex", ["mcp", "add", def.id, "--", ...args], {
          stdio: "inherit"
        });
        return { ok: true, message: scope === "global" ? "global (via CLI)" : "project (via CLI)" };
      } catch {
        return { ok: false, message: "Codex CLI failed \u2014 configure manually in .codex/config.toml" };
      }
    }
    const filePath = scope === "global" ? join21(process.env.HOME || "", config.globalPaths[0].replace("~/", "")) : join21(projectRoot, config.projectPaths[0]);
    if (target === "opencode") {
      mergeOpencodeMcpConfig(filePath, def.id, args);
    } else {
      mergeJsonMcpConfig(filePath, config.mcpKey, def.id, args);
    }
    const loc = scope === "global" ? config.globalPaths[0] : config.projectPaths[0];
    return { ok: true, message: `merged into ${loc}` };
  } catch (e) {
    const msg = e instanceof Error ? e.message : String(e);
    return { ok: false, message: msg };
  }
}
function formatTargetLine(target, st) {
  if (st.configured) {
    const where = st.scope === "global" ? "global" : st.scope === "project" ? "project" : "";
    return `    ${green2("\u2713")} ${target}${where ? ` (${where})` : ""}`;
  }
  return `    ${yellow("\u26A1")} ${target}: not configured`;
}
function mcpIntegrationDoneForSession(st, availableTargets) {
  if (availableTargets.length === 0) return false;
  return availableTargets.every((t) => st.targets[t]?.configured);
}
async function runMcpRecommendations(opts) {
  if (opts.upgrade) return;
  if (!process.stdin.isTTY) {
    const existing = readLoafConfig(opts.projectRoot);
    for (const def of MCP_REGISTRY) {
      if (existing.integrations?.[def.id] === void 0) {
        mergeLoafConfigIntegrations(opts.projectRoot, {
          [def.id]: { enabled: false }
        });
      }
    }
    return;
  }
  const { projectRoot, availableTargets } = opts;
  if (availableTargets.length === 0) return;
  console.log(`
${bold2("Recommended MCP servers")}
`);
  const statuses = buildMcpStatuses(projectRoot, availableTargets);
  for (const st of statuses) {
    const def = getMcpDefinition(st.id);
    if (!def) continue;
    const tierLabel = def.tier === "optional" ? `${gray2("Optional \u2014 ")}` : "";
    console.log(`  ${tierLabel}${bold2(def.displayName)}`);
    for (const t of availableTargets) {
      const ts = st.targets[t];
      if (ts) console.log(formatTargetLine(t, ts));
    }
    if (mcpIntegrationDoneForSession(st, availableTargets)) {
      mergeLoafConfigIntegrations(projectRoot, {
        [def.id]: { enabled: true }
      });
      console.log();
      continue;
    }
    const scopeAnswer = await ask(
      `    Install? [n]o / [g]lobal / [p]roject (default: no): `
    );
    const scope = parseScope(scopeAnswer);
    if (scope === "no") {
      mergeLoafConfigIntegrations(projectRoot, {
        [def.id]: { enabled: false }
      });
      console.log(`    ${gray2("\u25CB")} Skipped \u2014 recorded in .agents/loaf.json`);
      console.log();
      continue;
    }
    const unconfigured = availableTargets.filter(
      (t) => !st.targets[t]?.configured
    );
    let selectedTargets;
    if (unconfigured.length === 1) {
      selectedTargets = unconfigured;
    } else {
      console.log(`
    Unconfigured targets:`);
      unconfigured.forEach((t, i) => {
        console.log(`      ${i + 1}. ${t}`);
      });
      const targetAnswer = await ask(
        `    Which targets? [a]ll / comma-separated numbers: `
      );
      if (targetAnswer.startsWith("a") || targetAnswer === "") {
        selectedTargets = unconfigured;
      } else {
        const indices = targetAnswer.split(",").map((s) => parseInt(s.trim(), 10) - 1).filter((i) => i >= 0 && i < unconfigured.length);
        selectedTargets = indices.length > 0 ? indices.map((i) => unconfigured[i]) : unconfigured;
      }
    }
    let allOk = true;
    for (const target of selectedTargets) {
      const result = installMcpForTarget(target, def, scope, projectRoot);
      if (result.ok) {
        console.log(`    ${green2("\u2713")} ${target}: ${result.message}`);
      } else {
        console.log(`    ${yellow("\u26A0")} ${target}: ${result.message}`);
        allOk = false;
      }
    }
    const alreadyConfigured = availableTargets.filter(
      (t) => st.targets[t]?.configured
    );
    const totalOk = alreadyConfigured.length + (allOk ? selectedTargets.length : 0);
    const enabled = totalOk === availableTargets.length;
    mergeLoafConfigIntegrations(projectRoot, {
      [def.id]: { enabled }
    });
    if (!enabled) {
      console.log(
        `    ${yellow("\u26A0")} ${gray2(`integrations.${def.id}.enabled remains false until all targets succeed.`)}`
      );
    }
    console.log();
  }
  console.log(
    `${green2("\u2713")} Integration choices recorded under ${gray2("integrations")} in ${gray2(".agents/loaf.json")}`
  );
  console.log();
}

// cli/commands/install.ts
function findProjectRoot() {
  try {
    return execFileSync5("git", ["rev-parse", "--show-toplevel"], {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
  } catch {
    return process.cwd();
  }
}
var __dirname2 = dirname5(fileURLToPath4(import.meta.url));
var bold3 = (s) => `\x1B[1m${s}\x1B[0m`;
var green3 = (s) => `\x1B[32m${s}\x1B[0m`;
var red2 = (s) => `\x1B[31m${s}\x1B[0m`;
var yellow2 = (s) => `\x1B[33m${s}\x1B[0m`;
var gray3 = (s) => `\x1B[90m${s}\x1B[0m`;
var white = (s) => `\x1B[97m${s}\x1B[0m`;
function findRootDir2() {
  let dir = __dirname2;
  for (let i = 0; i < 10; i++) {
    const pkgPath = join22(dir, "package.json");
    try {
      const pkg = JSON.parse(readFileSync15(pkgPath, "utf-8"));
      if (pkg.name === "loaf") return dir;
    } catch {
    }
    const parent = dirname5(dir);
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error("Could not find loaf root directory");
}
function askYesNo(question, defaultYes = false) {
  const rl = createInterface2({
    input: process.stdin,
    output: process.stdout
  });
  return new Promise((resolve2) => {
    rl.question(question, (answer) => {
      rl.close();
      const a = answer.trim().toLowerCase();
      if (!a) resolve2(defaultYes);
      else resolve2(a.startsWith("y"));
    });
  });
}
var DISPLAY_NAMES = {
  "claude-code": "Claude Code",
  opencode: "OpenCode",
  cursor: "Cursor",
  codex: "Codex",
  gemini: "Gemini",
  amp: "Amp"
};
function displayName(target) {
  return DISPLAY_NAMES[target] ?? target;
}
function isLoafOnPath() {
  try {
    execSync("which loaf", { stdio: "pipe" });
    return true;
  } catch {
    return false;
  }
}
async function installLoafBinary(rootDir) {
  const localBinDir = join22(process.env.HOME || "~", ".local", "bin");
  const sourceBinary = join22(rootDir, "dist-cli", "index.js");
  const targetBinary = join22(localBinDir, "loaf");
  if (!existsSync17(sourceBinary)) {
    console.log(`  ${red2("\u2717")} CLI binary not found at ${sourceBinary}`);
    console.log(`  ${gray3("Run 'npm run build:cli' first.")}`);
    return false;
  }
  if (!existsSync17(localBinDir)) {
    try {
      mkdirSync15(localBinDir, { recursive: true });
      console.log(`  ${green3("\u2713")} Created ${localBinDir}`);
    } catch (err) {
      console.log(`  ${red2("\u2717")} Could not create ${localBinDir}: ${err}`);
      return false;
    }
  }
  if (existsSync17(targetBinary)) {
    try {
      unlinkSync(targetBinary);
    } catch {
    }
  }
  try {
    copyFileSync2(sourceBinary, targetBinary);
    chmodSync2(targetBinary, 493);
    console.log(`  ${green3("\u2713")} Installed loaf binary to ${targetBinary}`);
    const pathEnv = process.env.PATH || "";
    if (!pathEnv.includes(localBinDir)) {
      console.log(`  ${yellow2("\u26A0")} ${localBinDir} is not on your PATH`);
      console.log(`  ${gray3("Add this to your shell profile:")}`);
      console.log(`  ${gray3(`  export PATH="${localBinDir}:$PATH"`)}`);
    }
    return true;
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    console.log(`  ${red2("\u2717")} Failed to install binary: ${msg}`);
    return false;
  }
}
var VALID_TARGETS = Object.keys(DEFAULT_CONFIG_DIRS);
function registerInstallCommand(program3) {
  program3.command("install").description("Install Loaf to detected AI tool configurations").option("--to <target>", 'Target to install to (or "all")').option("--upgrade", "Update only already-installed targets").action(async (options2) => {
    const rootDir = findRootDir2();
    const distDir = join22(rootDir, "dist");
    const devMode = isDevMode(rootDir);
    const upgrade = options2.upgrade ?? false;
    const projectRoot = findProjectRoot();
    console.log(`
${bold3("loaf install")}
`);
    const hasClaudeCode = detectClaudeCode();
    const tools = detectTools();
    if (hasClaudeCode) {
      console.log(`  ${green3("\u2713")} Claude Code detected`);
      if (devMode) {
        console.log(
          `    ${gray3("Test locally:")} ${white(`/plugin marketplace add ${rootDir}`)}`
        );
      } else {
        console.log(
          `    ${gray3("Install via:")} ${white("/plugin marketplace add levifig/loaf")}`
        );
      }
      console.log();
    }
    for (const tool of tools) {
      const status = tool.installed ? ` ${yellow2("(installed)")}` : "";
      console.log(`  ${green3("\u2713")} ${tool.name} detected${status}`);
    }
    if (tools.length === 0 && !hasClaudeCode) {
      console.log(`  ${gray3("No AI tools detected")}`);
      console.log();
      return;
    }
    console.log();
    let selectedTargets;
    if (options2.to === "all") {
      selectedTargets = tools.map((t) => t.key);
    } else if (options2.to) {
      if (!VALID_TARGETS.includes(options2.to) && options2.to !== "all") {
        console.error(
          `${red2("error:")} Unknown target ${bold3(options2.to)}
${gray3("Valid targets:")} ${VALID_TARGETS.join(", ")}, all`
        );
        process.exit(1);
      }
      const tool = tools.find((t) => t.key === options2.to);
      selectedTargets = [options2.to];
      if (!tool) {
        console.log(
          `  ${yellow2("\u26A1")} ${options2.to} was not auto-detected; installing to ${DEFAULT_CONFIG_DIRS[options2.to]}`
        );
      }
    } else if (upgrade) {
      selectedTargets = tools.filter((t) => t.installed).map((t) => t.key);
      if (selectedTargets.length === 0) {
        if (hasClaudeCode) {
          const fencedResults2 = installFencedSectionsForTargets(
            ["claude-code"],
            projectRoot,
            upgrade
          );
          if (fencedResults2["claude-code"]?.action === "updated") {
            console.log(`  ${green3("\u2713")} Claude Code updated Loaf framework section in project file`);
          } else if (fencedResults2["claude-code"]?.action === "skipped") {
            console.log(`  ${gray3("\u25CB")} Claude Code Loaf framework section already current`);
          }
          console.log();
        }
        console.log(`  ${gray3("No installed targets to upgrade")}`);
        console.log();
        return;
      }
      console.log(`  ${gray3("Upgrading:")} ${selectedTargets.join(", ")}`);
    } else {
      selectedTargets = [];
      for (const tool of tools) {
        const status = tool.installed ? ` ${yellow2("(installed)")}` : "";
        const yes = await askYesNo(
          `  Install to ${bold3(tool.name)}${status}? [Y/n] `,
          true
        );
        if (yes) {
          selectedTargets.push(tool.key);
        }
      }
    }
    if (selectedTargets.length === 0) {
      if (hasClaudeCode) {
        const fencedResults2 = installFencedSectionsForTargets(
          ["claude-code"],
          projectRoot,
          upgrade
        );
        if (fencedResults2["claude-code"]?.action === "created") {
          console.log(`  ${green3("\u2713")} Claude Code created project file with Loaf framework section`);
        } else if (fencedResults2["claude-code"]?.action === "appended") {
          console.log(`  ${green3("\u2713")} Claude Code added Loaf framework section to project file`);
        } else if (fencedResults2["claude-code"]?.action === "updated") {
          console.log(`  ${green3("\u2713")} Claude Code updated Loaf framework section in project file`);
        } else if (fencedResults2["claude-code"]?.action === "skipped") {
          console.log(`  ${gray3("\u25CB")} Claude Code Loaf framework section already current`);
        }
        console.log();
      }
      if (hasClaudeCode || options2.to === "all") {
        const mcpTargets2 = hasClaudeCode ? ["claude-code"] : [];
        await runMcpRecommendations({
          projectRoot,
          upgrade,
          availableTargets: mcpTargets2
        });
      }
      console.log(`  ${gray3("No targets selected")}`);
      console.log();
      return;
    }
    const pathDependentTargets = ["opencode", "cursor", "codex", "amp"];
    const needsPathBinary = selectedTargets.some(
      (t) => pathDependentTargets.includes(t)
    );
    if (needsPathBinary && !isLoafOnPath()) {
      console.log(
        `  ${yellow2("\u26A0")} Selected targets need 'loaf' on PATH but it's not available`
      );
      console.log(
        `  ${gray3("Targets:")} ${selectedTargets.filter((t) => pathDependentTargets.includes(t)).join(", ")}`
      );
      const shouldInstallBinary = await askYesNo(
        `  Install 'loaf' binary to ~/.local/bin? [y/N] `
      );
      if (shouldInstallBinary) {
        await installLoafBinary(rootDir);
        console.log();
      } else {
        console.log(
          `  ${gray3("Skipping binary installation. Some hooks may not work for PATH-dependent targets.")}`
        );
        console.log();
      }
    } else if (needsPathBinary) {
      console.log(`  ${green3("\u2713")} loaf binary available on PATH for target hooks`);
      console.log();
    }
    console.log();
    const installedTargets = [];
    for (const target of selectedTargets) {
      const tool = tools.find((t) => t.key === target);
      const configDir = tool?.configDir || DEFAULT_CONFIG_DIRS[target];
      const targetDistDir = join22(distDir, target);
      if (!existsSync17(targetDistDir)) {
        console.log(
          `  ${red2("\u2717")} ${displayName(target)} \u2014 no build output found. Run ${bold3("loaf build")} first.`
        );
        continue;
      }
      const installer = INSTALLERS[target];
      if (!installer) {
        console.log(`  ${red2("\u2717")} ${displayName(target)} \u2014 no installer available`);
        continue;
      }
      try {
        installer(targetDistDir, configDir, upgrade);
        console.log(`  ${green3("\u2713")} ${displayName(target)} installed to ${gray3(configDir)}`);
        installedTargets.push(target);
      } catch (error) {
        const msg = error instanceof Error ? error.message : String(error);
        console.log(`  ${red2("\u2717")} ${displayName(target)} \u2014 ${msg}`);
      }
    }
    console.log();
    const targetsWithFencedSections = installedTargets.filter((t) => t !== "gemini");
    const fencedTargets = hasClaudeCode ? ["claude-code", ...targetsWithFencedSections] : [...targetsWithFencedSections];
    const fencedResults = installFencedSectionsForTargets(
      fencedTargets,
      projectRoot,
      upgrade
    );
    let hasFencedOutput = false;
    for (const [target, result] of Object.entries(fencedResults)) {
      const name = displayName(target);
      if (result.action === "error") {
        console.log(
          `  ${red2("\u2717")} ${name} project file \u2014 ${result.error}`
        );
        hasFencedOutput = true;
      } else if (result.action === "created") {
        console.log(
          `  ${green3("\u2713")} ${name} created project file with Loaf framework section`
        );
        hasFencedOutput = true;
      } else if (result.action === "appended") {
        console.log(
          `  ${green3("\u2713")} ${name} added Loaf framework section to project file`
        );
        hasFencedOutput = true;
      } else if (result.action === "updated") {
        console.log(
          `  ${green3("\u2713")} ${name} updated Loaf framework section in project file (v${result.version})`
        );
        hasFencedOutput = true;
      } else if (result.action === "skipped") {
        console.log(
          `  ${gray3("\u25CB")} ${name} Loaf framework section already current (v${result.version})`
        );
        hasFencedOutput = true;
      }
    }
    if (hasFencedOutput) {
      console.log();
    }
    const mcpTargets = [.../* @__PURE__ */ new Set([
      ...hasClaudeCode ? ["claude-code"] : [],
      ...installedTargets,
      ...selectedTargets
    ])];
    await runMcpRecommendations({
      projectRoot,
      upgrade,
      availableTargets: mcpTargets
    });
  });
}

