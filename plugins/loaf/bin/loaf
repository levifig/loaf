        data.last_entry = getTimestamp();
      }
    );
    console.log(`  ${green12("\u2713")} Logged: ${cyan9(entryText)}`);
  });
  session.command("archive").description("Archive completed session").option("--branch <branch>", "Archive session for specific branch (default: current)").action(async (options2) => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const branch = options2.branch || getCurrentBranch();
    if (branch === "unknown" && !options2.branch) {
      console.error(`  ${red10("error:")} Not in a git repository. Use --branch <branch>`);
      process.exit(1);
    }
    const existingSession = findActiveSessionForBranch(agentsDir, branch);
    if (!existingSession) {
      console.error(`  ${red10("error:")} No active session found for branch ${branch}`);
      process.exit(1);
    }
    console.log(`
  ${bold13("loaf session archive")}
`);
    const archiveDir = join40(agentsDir, "sessions", "archive");
    if (!existsSync35(archiveDir)) {
      mkdirSync22(archiveDir, { recursive: true });
    }
    const decisionEntries = extractDecisionEntries(existingSession.content);
    if (decisionEntries.length > 0) {
      console.log(`  ${bold13("Key decisions extracted:")}`);
      for (const entry of decisionEntries.slice(0, 10)) {
        console.log(`    ${entry}`);
      }
      if (decisionEntries.length > 10) {
        console.log(`    ${gray14(`... and ${decisionEntries.length - 10} more`)}`);
      }
      console.log();
      if (existingSession.data.spec && decisionEntries.length > 0) {
        const result = persistDecisionsToSpec(
          agentsDir,
          existingSession.data.spec,
          decisionEntries,
          existingSession.data.branch || branch
        );
        if (result.success) {
          console.log(`  ${green12("\u2713")} ${result.message}`);
        } else {
          console.log(`  ${yellow14("\u26A0")} Could not persist to spec: ${result.message}`);
        }
        console.log();
      }
    }
    const archivePath = join40(archiveDir, basename5(existingSession.filePath));
    try {
      renameSync3(existingSession.filePath, archivePath);
    } catch (err) {
      console.error(`  ${red10("error:")} Failed to move file: ${err}`);
      process.exit(1);
    }
    const now = getTimestamp();
    const archivedSession = readSessionFile(archivePath);
    if (archivedSession) {
      archivedSession.data.status = "archived";
      archivedSession.data.archived_at = now;
      archivedSession.data.last_updated = now;
      const newContent = import_gray_matter13.default.stringify(
        archivedSession.content,
        archivedSession.data
      );
      writeFileSync21(archivePath, newContent, "utf-8");
    }
    console.log(`  ${green12("\u2713")} Archived: ${gray14(archivePath.replace(agentsDir, ".agents"))}`);
    console.log();
  });
  session.command("list").description("List all active and archived sessions").option("--all", "Include archived sessions").action(async (options2) => {
    const agentsDir = findAgentsDir();
    if (!agentsDir) {
      console.error(`  ${red10("error:")} Could not find .agents/ directory`);
      process.exit(1);
    }
    const sessionsDir = join40(agentsDir, "sessions");
    if (!existsSync35(sessionsDir)) {
      console.log(`
  ${gray14("No sessions directory found.")}`);
      console.log(`  Run ${cyan9("loaf session start")} to create your first session.
`);
      return;
    }
    console.log(`
  ${bold13("loaf session list")}
`);
    const activeSessions = [];
    const files = readdirSync14(sessionsDir).filter((f) => f.endsWith(".md"));
    for (const file of files) {
      const filePath = join40(sessionsDir, file);
      const session2 = readSessionFile(filePath);
      if (session2 && session2.data.status !== "archived") {
        activeSessions.push({ ...session2, filePath, isArchived: false });
      }
    }
    const archivedSessions = [];
    if (options2.all) {
      const archiveDir = join40(sessionsDir, "archive");
      if (existsSync35(archiveDir)) {
        const archiveFiles = readdirSync14(archiveDir).filter((f) => f.endsWith(".md"));
        for (const file of archiveFiles) {
          const filePath = join40(archiveDir, file);
          const session2 = readSessionFile(filePath);
          if (session2) {
            archivedSessions.push({ ...session2, filePath, isArchived: true });
          }
        }
      }
    }
    if (activeSessions.length === 0) {
      console.log(`  ${gray14("No active sessions found.")}`);
    } else {
      console.log(`  ${bold13("Active Sessions")}:`);
      for (const s of activeSessions) {
        const statusColor = s.data.status === "active" ? green12 : yellow14;
        const specInfo = s.data.spec ? gray14(` (${s.data.spec})`) : "";
        const lastUpdated = s.data.last_updated ? gray14(` \u2014 updated ${new Date(s.data.last_updated).toLocaleDateString()}`) : "";
        console.log(`    ${statusColor("\u25CF")} ${s.data.branch}${specInfo}${lastUpdated}`);
        console.log(`      ${gray14(s.filePath.replace(agentsDir, ".agents"))}`);
      }
    }
    if (options2.all && archivedSessions.length > 0) {
      console.log();
      console.log(`  ${bold13("Archived Sessions")}:`);
      for (const s of archivedSessions) {
        const archivedDate = s.data.archived_at ? gray14(` \u2014 archived ${new Date(s.data.archived_at).toLocaleDateString()}`) : "";
        console.log(`    ${gray14("\u25CB")} ${s.data.branch}${archivedDate}`);
        console.log(`      ${gray14(s.filePath.replace(agentsDir, ".agents"))}`);
      }
    }
    console.log();
    console.log(`  ${activeSessions.length} active${options2.all ? `, ${archivedSessions.length} archived` : ""}`);
    console.log();
  });
}

