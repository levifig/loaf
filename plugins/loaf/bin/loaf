  if (!existsSync35(nudgeFile)) {
    return [];
  }
  const files = readFileSync30(nudgeFile, "utf-8").split("\n").map((line) => line.trim()).filter(Boolean);
  unlinkSync3(nudgeFile);
  return [...new Set(files)];
}
var LOCK_STALENESS_THRESHOLD = 3e4;
function isLockStale(lockPath) {
  try {
    const stats = statSync3(lockPath);
    const age = Date.now() - stats.mtimeMs;
    return age > LOCK_STALENESS_THRESHOLD;
  } catch {
    return true;
  }
}
function forceReleaseLock(lockPath) {
  try {
    unlinkSync3(lockPath);
    console.log(`  Released stale lock: ${lockPath}`);
  } catch {
  }
}
async function acquireLock(lockPath, maxRetries = 50, retryDelay = 100) {
  for (let i = 0; i < maxRetries; i++) {
    try {
      if (existsSync35(lockPath) && isLockStale(lockPath)) {
        forceReleaseLock(lockPath);
      }
      const fd = openSync(lockPath, "wx");
      const lockContent = {
        pid: process.pid,
        timestamp: Date.now()
      };
      writeFileSync21(fd, JSON.stringify(lockContent), "utf-8");
      closeSync(fd);
      return;
    } catch {
      await new Promise((resolve2) => setTimeout(resolve2, retryDelay));
    }
  }
  throw new Error(`Could not acquire lock after ${maxRetries} retries: ${lockPath}`);
}
function releaseLock(lockPath) {
  try {
    unlinkSync3(lockPath);
  } catch {
  }
}
function writeFileAtomic(filePath, content) {
  const tempPath = `${filePath}.tmp.${Date.now()}.${Math.random().toString(36).slice(2, 11)}`;
  try {
    writeFileSync21(tempPath, content, "utf-8");
    renameSync3(tempPath, filePath);
  } catch (err) {
    try {
      unlinkSync3(tempPath);
    } catch {
    }
    throw err;
  }
}
function getCurrentBranch() {
  try {
    const branch = execSync3("git branch --show-current", {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
    if (!branch) {
      const commitSha = execSync3("git rev-parse --short HEAD", {
        encoding: "utf-8",
        stdio: ["pipe", "pipe", "pipe"]
      }).trim();
      return `detached-${commitSha}`;
    }
    return branch;
  } catch {
    return "unknown";
  }
}
function getRecentCommits(count = 5) {
  try {
    const output = execSync3(`git log --pretty=format:"%H %s" -${count}`, {
      encoding: "utf-8",
      stdio: ["pipe", "pipe", "pipe"]
    }).trim();
    if (!output) return [];
    return output.split("\n").map((line) => {
      const spaceIndex = line.indexOf(" ");
      return {
        hash: line.substring(0, 7),
        // Short hash
        message: line.substring(spaceIndex + 1)
      };
    });
  } catch {
    return [];
  }
}
