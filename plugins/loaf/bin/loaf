  task.command("archive").description("Move completed tasks to archive and update TASKS.json").argument("[ids...]", "Task IDs to archive (e.g., TASK-040 TASK-041)").option("--spec <id>", "Archive all done tasks for a spec").action(async (ids, options2) => {
