async function build({
  config,
  targetsConfig,
  rootDir,
  srcDir,
  distDir
}) {
  VERSION = getVersion(rootDir);
  const pluginsDir = join7(distDir, "plugins");
  const marketplaceDir = join7(distDir, ".claude-plugin");
  if (existsSync6(pluginsDir)) rmSync(pluginsDir, { recursive: true });
  if (existsSync6(marketplaceDir)) rmSync(marketplaceDir, { recursive: true });
  mkdirSync5(pluginsDir, { recursive: true });
  mkdirSync5(marketplaceDir, { recursive: true });
  createMarketplace(marketplaceDir);
  buildUnifiedPlugin(config, rootDir, srcDir, pluginsDir, targetsConfig);
}
function createMarketplace(marketplaceDir) {
  const marketplace = {
    name: "levifig-loaf",
    owner: { name: "Levi Figueira", email: "me@levifig.com" },
    metadata: { description: PLUGIN_DESCRIPTION, version: VERSION },
    plugins: [
      {
        name: PLUGIN_NAME,
        description: PLUGIN_DESCRIPTION,
        source: `./plugins/${PLUGIN_NAME}`,
        version: VERSION,
        license: "MIT",
        repository: REPOSITORY
      }
    ]
  };
  writeFileSync5(
    join7(marketplaceDir, "marketplace.json"),
    JSON.stringify(marketplace, null, 2)
  );
}
function buildUnifiedPlugin(config, rootDir, srcDir, pluginsDir, targetsConfig) {
  const pluginDir = join7(pluginsDir, PLUGIN_NAME);
  mkdirSync5(pluginDir, { recursive: true });
  const allSkills = discoverSkills(join7(rootDir, "dist"));
  const knownCommands = [];
  for (const skill of allSkills) {
    const skillDir = join7(rootDir, "content", "skills", skill);
    if (existsSync6(skillDir)) {
      const extensions = loadSkillExtensions(skillDir);
      if (extensions["user-invocable"] !== false) {
        knownCommands.push(skill);
      }
    }
  }
  const baseTransform = createCommandSubstituter("claude-code");
  const scopingTransform = (content) => {
    let result = content;
    for (const cmd of knownCommands) {
      const pattern = new RegExp(
        `(?<!/\\w+:)\\/${cmd}(?=\\s|\\)|\\]|,|$|\`)`,
        "g"
      );
      result = result.replace(pattern, `/loaf:${cmd}`);
    }
    return result;
  };
  const transformMd = (content) => scopingTransform(baseTransform(content));
  createPluginJson(config, pluginDir);
  const agentsDir = join7(pluginDir, "agents");
  mkdirSync5(agentsDir, { recursive: true });
  copyAgents({
    srcDir,
    destDir: agentsDir,
    targetName: TARGET_NAME,
    version: VERSION,
    sidecarRequired: true
  });
  const skillsDir = join7(pluginDir, "skills");
  mkdirSync5(skillsDir, { recursive: true });
  copySkills({
    srcDir: join7(rootDir, "dist"),
    // Read from intermediate dist/skills/
    destDir: skillsDir,
    targetName: TARGET_NAME,
    version: VERSION,
    targetsConfig,
    transformMd,
    mergeFrontmatter: (base, skillDir) => {
      const skillName = skillDir.split("/").pop() || "";
      const contentSkillDir = join7(srcDir, "skills", skillName);
      const extensions = loadSkillExtensions(contentSkillDir);
      const merged = { ...base, ...extensions };
      if (merged.description && merged.description.length > 250) {
        merged.description = merged.description.substring(0, 247) + "...";
      }
      return merged;
    }
  });
  copyAllHooks(config, srcDir, pluginDir);
  writeFileSync5(join7(pluginDir, ".lsp.json"), JSON.stringify(LSP_SERVERS, null, 2));
  const pluginTemplatesDir = join7(pluginDir, "templates");
  const soulTemplateSrc = join7(srcDir, "templates", "soul.md");
  if (existsSync6(soulTemplateSrc)) {
    mkdirSync5(pluginTemplatesDir, { recursive: true });
    cpSync3(soulTemplateSrc, join7(pluginTemplatesDir, "soul.md"));
  }
  const setupSrc = join7(srcDir, "SETUP.md");
  if (existsSync6(setupSrc)) {
    cpSync3(setupSrc, join7(pluginDir, "SETUP.md"));
  }
  const binDir = join7(pluginDir, "bin");
  mkdirSync5(binDir, { recursive: true });
  const cliSource = join7(rootDir, "dist-cli", "index.js");
  if (existsSync6(cliSource)) {
    copyFileSync(cliSource, join7(binDir, "loaf"));
    chmodSync(join7(binDir, "loaf"), 493);
  }
  const pluginPackageJson = {
    name: PLUGIN_NAME,
    version: VERSION
  };
  writeFileSync5(
    join7(pluginDir, "package.json"),
    JSON.stringify(pluginPackageJson, null, 2)
  );
}
function groupByMatcher(hooks) {
  const groups = {};
  for (const hook of hooks) {
    const matcher = hook.matcher || "Edit|Write";
    if (!groups[matcher]) groups[matcher] = [];
    groups[matcher].push(hook);
  }
  return groups;
}
function getClaudeHookCommand(hook) {
  if (BINARY_PATH_HOOKS.has(hook.id)) {
    if (!hook.command) {
      return `"\${CLAUDE_PLUGIN_ROOT}/bin/loaf" check --hook ${hook.id}`;
    }
    return hook.command.replace(/\bloaf\b/g, '"${CLAUDE_PLUGIN_ROOT}/bin/loaf"');
  }
  if (hook.command) {
    return hook.command.replace(/\$\{CLAUDE_PLUGIN_ROOT\}/g, "${CLAUDE_PLUGIN_ROOT}");
  }
  const parts = hook.script.split("/");
  const filename = parts[parts.length - 1];
  const hookPath = `hooks/${filename}`;
  if (filename.endsWith(".py")) {
    return `python3 \${CLAUDE_PLUGIN_ROOT}/${hookPath}`;
  }
  return `bash \${CLAUDE_PLUGIN_ROOT}/${hookPath}`;
}
function createPluginJson(config, pluginDir) {
  const pluginJson = {
    name: PLUGIN_NAME,
    version: VERSION,
    description: PLUGIN_DESCRIPTION,
    repository: REPOSITORY,
    license: "MIT",
    hooks: {},
    mcpServers: MCP_SERVERS
  };
  const hooks = pluginJson.hooks;
  const allPreToolHooks = config.hooks["pre-tool"] || [];
  const allPostToolHooks = config.hooks["post-tool"] || [];
  const allSessionHooks = config.hooks.session || [];
  if (allPreToolHooks.length > 0) {
    const preToolByMatcher = groupByMatcher(allPreToolHooks);
    hooks.PreToolUse = Object.entries(preToolByMatcher).map(([matcher, hookList]) => ({
      matcher,
      hooks: hookList.map((h) => {
        if (h.type === "prompt") {
          return {
            type: "prompt",
            prompt: h.prompt,
            ...h.if && { if: h.if },
            ...h.timeout && { timeout: Math.floor((h.timeout || 5e3) / 1e3) }
          };
        }
        return {
          type: "command",
          command: getClaudeHookCommand(h),
          ...h.if && { if: h.if },
          ...h.timeout && { timeout: Math.floor((h.timeout || 3e4) / 1e3) },
          ...h.description && { description: h.description },
          ...h.failClosed && { failClosed: h.failClosed }
        };
      })
    }));
  }
  if (allPostToolHooks.length > 0) {
    const postToolByMatcher = groupByMatcher(allPostToolHooks);
    hooks.PostToolUse = Object.entries(postToolByMatcher).map(([matcher, hookList]) => ({
      matcher,
      hooks: hookList.map((h) => {
        if (h.type === "prompt") {
          return {
            type: "prompt",
            prompt: h.prompt,
            ...h.if && { if: h.if },
            ...h.timeout && { timeout: Math.floor((h.timeout || 5e3) / 1e3) },
            ...h.description && { description: h.description }
          };
        }
        return {
          type: "command",
          command: getClaudeHookCommand(h),
          ...h.if && { if: h.if },
          ...h.description && { description: h.description },
          ...h.timeout && { timeout: Math.floor((h.timeout || 3e4) / 1e3) },
          ...h.failClosed && { failClosed: h.failClosed }
        };
      })
    }));
  }
  if (allSessionHooks.length > 0) {
    for (const hook of allSessionHooks) {
      const eventName = hook.event;
      if (!hooks[eventName]) hooks[eventName] = [];
      const hookEntry = {
        type: hook.type,
        ...hook.timeout && { timeout: Math.floor((hook.timeout || 6e4) / 1e3) },
        ...hook.description && { description: hook.description },
        ...hook.if && { if: hook.if }
      };
      if (hook.type === "prompt") {
        hookEntry.prompt = hook.prompt;
      } else {
        hookEntry.command = getClaudeHookCommand(hook);
        if (hook.failClosed) hookEntry.failClosed = hook.failClosed;
      }
      hooks[eventName].push({ hooks: [hookEntry] });
    }
  }
  const pluginJsonDir = join7(pluginDir, ".claude-plugin");
  mkdirSync5(pluginJsonDir, { recursive: true });
  writeFileSync5(join7(pluginJsonDir, "plugin.json"), JSON.stringify(pluginJson, null, 2));
}
function copyAllHooks(config, srcDir, pluginDir) {
  const hooksDir = join7(pluginDir, "hooks");
  mkdirSync5(hooksDir, { recursive: true });
  const libSrc = join7(srcDir, "hooks", "lib");
  if (existsSync6(libSrc)) {
    cpSync3(libSrc, join7(hooksDir, "lib"), { recursive: true });
  }
  const scriptHookIds = /* @__PURE__ */ new Set();
  for (const hook of config.hooks["pre-tool"] || []) {
    if (hook.script && !BINARY_PATH_HOOKS.has(hook.id)) {
      scriptHookIds.add(hook.id);
    }
  }
  for (const hook of config.hooks["post-tool"] || []) {
    if (hook.script && !BINARY_PATH_HOOKS.has(hook.id)) {
      scriptHookIds.add(hook.id);
    }
  }
  for (const hook of config.hooks.session || []) {
    if (hook.script) {
      scriptHookIds.add(hook.id);
    }
  }
  for (const hookId of scriptHookIds) {
    const hookDef = config.hooks["pre-tool"]?.find((h) => h.id === hookId) || config.hooks["post-tool"]?.find((h) => h.id === hookId) || config.hooks.session?.find((h) => h.id === hookId);
    if (hookDef && hookDef.script) {
      const parts = hookDef.script.split("/");
      const filename = parts[parts.length - 1];
      const src = join7(srcDir, hookDef.script);
      const dest = join7(hooksDir, filename);
      if (existsSync6(src)) cpSync3(src, dest);
    }
  }
  const linearMcpSrc = join7(srcDir, "hooks", "linear-mcp.sh");
  if (existsSync6(linearMcpSrc)) {
    cpSync3(linearMcpSrc, join7(hooksDir, "linear-mcp.sh"));
  }
  const subagentHooksSrc = join7(srcDir, "hooks", "subagent");
  if (existsSync6(subagentHooksSrc)) {
    const files = readdirSync4(subagentHooksSrc);
    for (const file of files) {
      cpSync3(join7(subagentHooksSrc, file), join7(hooksDir, file));
    }
  }
  const instructionsSrc = join7(srcDir, "hooks", "instructions");
  if (existsSync6(instructionsSrc)) {
    cpSync3(instructionsSrc, join7(hooksDir, "instructions"), { recursive: true });
  }
}

