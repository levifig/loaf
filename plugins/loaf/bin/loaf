function getVersion2() {
  const __dirname7 = dirname3(fileURLToPath2(import.meta.url));
  for (const candidate of [
    join17(__dirname7, "..", "package.json"),
    join17(__dirname7, "..", "..", "package.json"),
    join17(__dirname7, "..", "..", "..", "package.json")
  ]) {
    try {
      const pkg = JSON.parse(readFileSync10(candidate, "utf-8"));
      if (pkg.name === "loaf") return pkg.version;
    } catch {
      continue;
    }
  }
  return "0.0.0";
}
function hasRsync() {
  try {
    execFileSync2("which", ["rsync"], { stdio: "ignore" });
    return true;
  } catch {
    return false;
  }
}
function syncDir(src, dest) {
  mkdirSync11(dest, { recursive: true });
  if (hasRsync()) {
    execFileSync2("rsync", ["-a", "--delete", `${src}/`, `${dest}/`], {
      stdio: "inherit"
    });
  } else {
    const entries = readdirSync7(dest);
    for (const entry of entries) {
      rmSync4(join17(dest, entry), { recursive: true, force: true });
    }
    cpSync6(src, dest, { recursive: true });
  }
}
function mergeDir(src, dest) {
  mkdirSync11(dest, { recursive: true });
  cpSync6(src, dest, { recursive: true, force: true });
}
function writeMarker(configDir) {
  mkdirSync11(configDir, { recursive: true });
  writeFileSync10(join17(configDir, LOAF_MARKER_FILE2), `${getVersion2()}
`);
}
function getHookSignature(hook) {
  const command = hook.command;
  const prompt = hook.prompt;
  const matcher = hook.matcher;
  const condition = hook.if;
  if (command) {
    return `command:${command}|matcher:${matcher || ""}|if:${condition || ""}`;
  }
  if (prompt) {
    return `prompt:${prompt}|matcher:${matcher || ""}|if:${condition || ""}`;
  }
  return null;
}
function isLegacyLoafHook(hook) {
  const signature = getHookSignature(hook);
  if (signature && LEGACY_LOAF_SIGNATURES.has(signature)) {
    return true;
  }
  const command = hook.command;
  const prompt = hook.prompt;
  if (command) {
    return LEGACY_LOAF_COMMANDS.has(command);
  }
  if (prompt) {
    return LEGACY_LOAF_PROMPT_PREFIXES.some((prefix) => prompt.startsWith(prefix));
  }
  return false;
}
function isLoafHook(hook) {
  if (hook[LOAF_HOOK_MARKER3] === true) {
    return true;
  }
  return isLegacyLoafHook(hook);
}
function loadHooksJson(path) {
  if (!existsSync12(path)) {
    return { version: 1, hooks: {} };
  }
  try {
    const content = readFileSync10(path, "utf-8");
    return JSON.parse(content);
  } catch {
    return { version: 1, hooks: {} };
  }
}
function saveHooksJson(path, hooks) {
  mkdirSync11(dirname3(path), { recursive: true });
  writeFileSync10(path, JSON.stringify(hooks, null, 2));
}
function installOpencode(distDir, configDir, _upgrade = false) {
  const dirs = ["skills", "agents", "commands", "plugins", "templates"];
  for (const dir of dirs) {
    const src = join17(distDir, dir);
    const dest = join17(configDir, dir);
    if (existsSync12(src)) {
      syncDir(src, dest);
    }
  }
  writeMarker(configDir);
}
function installCursor(distDir, configDir, upgrade = false) {
  const homeDir = process.env.HOME || process.env.USERPROFILE || "";
  const skillsDest = join17(homeDir, ".agents/skills");
  const skillsSrc = join17(distDir, "skills");
  if (existsSync12(skillsSrc)) {
    syncDir(skillsSrc, skillsDest);
  }
  const staleCommands = join17(configDir, "commands");
  if (existsSync12(staleCommands)) {
    rmSync4(staleCommands, { recursive: true });
  }
  const agentsSrc = join17(distDir, "agents");
  if (existsSync12(agentsSrc)) {
    syncDir(agentsSrc, join17(configDir, "agents"));
  }
  const hooksSrc = join17(distDir, "hooks.json");
  if (existsSync12(hooksSrc)) {
    const hooksPath = join17(configDir, "hooks.json");
    const existing = loadHooksJson(hooksPath);
    const loafHooks = loadHooksJson(hooksSrc);
    const merged = { version: 1, hooks: {} };
    const allHookTypes = /* @__PURE__ */ new Set([
      ...Object.keys(existing.hooks || {}),
      ...Object.keys(loafHooks.hooks || {})
    ]);
    for (const hookType of allHookTypes) {
      const existingHooks = existing.hooks?.[hookType] || [];
      const loafHooksList = loafHooks.hooks?.[hookType] || [];
      const userHooks = existingHooks.filter((hook) => !isLoafHook(hook));
      merged.hooks[hookType] = [...userHooks, ...loafHooksList];
    }
    saveHooksJson(hooksPath, merged);
  }
  const hooksDir = join17(distDir, "hooks");
  if (existsSync12(hooksDir)) {
    if (upgrade) {
      const installedHooksDir = join17(configDir, "hooks");
      for (const file of OBSOLETE_CURSOR_HOOK_FILES) {
        rmSync4(join17(installedHooksDir, file), { force: true });
      }
    }
    mergeDir(hooksDir, join17(configDir, "hooks"));
  }
  const templatesSrc = join17(distDir, "templates");
  if (existsSync12(templatesSrc)) {
    syncDir(templatesSrc, join17(configDir, "templates"));
  }
  writeMarker(configDir);
}
function installCodex(distDir, configDir, upgrade = false) {
