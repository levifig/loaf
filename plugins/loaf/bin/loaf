// cli/lib/detect/tools.ts
import { existsSync as existsSync11 } from "fs";
import { join as join15 } from "path";
import { execFileSync } from "child_process";
import { platform } from "os";
var HOME = process.env.HOME || process.env.USERPROFILE || "";
var XDG_CONFIG_HOME = process.env.XDG_CONFIG_HOME || join15(HOME, ".config");
var LOAF_MARKER_FILE = ".loaf-version";
function hasCmd(cmd) {
  try {
    execFileSync("which", [cmd], { stdio: "ignore" });
    return true;
  } catch {
    return false;
  }
}
function isMacOS() {
  return platform() === "darwin";
}
function isLoafInstalled(configDir) {
  if (existsSync11(join15(configDir, LOAF_MARKER_FILE))) {
    return true;
  }
  const skillsDir = join15(configDir, "skills");
  for (const skill of ["foundations", "python-development", "python"]) {
    if (existsSync11(join15(skillsDir, skill))) {
      return true;
    }
  }
  return false;
}
function detectClaudeCode() {
  return hasCmd("claude");
}
function detectTools() {
  const tools = [];
  const opencodeConfig = join15(XDG_CONFIG_HOME, "opencode");
  if (existsSync11(opencodeConfig)) {
    tools.push({
      key: "opencode",
      name: "OpenCode",
      configDir: opencodeConfig,
      installed: isLoafInstalled(opencodeConfig),
      detectedVia: "config"
    });
  }
  const cursorConfig = join15(HOME, ".cursor");
  let cursorDetected = false;
  let cursorVia = "";
  if (hasCmd("cursor")) {
    cursorDetected = true;
    cursorVia = "cli";
  } else if (isMacOS() && (existsSync11("/Applications/Cursor.app") || existsSync11(join15(HOME, "Applications/Cursor.app")))) {
    cursorDetected = true;
    cursorVia = "app";
  } else if (existsSync11(cursorConfig)) {
    cursorDetected = true;
    cursorVia = "config";
  }
  if (cursorDetected) {
    tools.push({
      key: "cursor",
      name: "Cursor",
      configDir: cursorConfig,
      installed: isLoafInstalled(cursorConfig),
      detectedVia: cursorVia
    });
  }
  const codexConfig = (process.env.CODEX_HOME || join15(HOME, ".codex")).replace(
    /\/$/,
    ""
  );
  let codexDetected = false;
  let codexVia = "";
  if (hasCmd("codex")) {
    codexDetected = true;
    codexVia = "cli";
  } else if (existsSync11(codexConfig) || existsSync11(join15(HOME, ".codex"))) {
    codexDetected = true;
    codexVia = "config";
  }
  if (codexDetected) {
    tools.push({
      key: "codex",
      name: "Codex",
      configDir: codexConfig,
      installed: isLoafInstalled(codexConfig),
      detectedVia: codexVia
    });
  }
  const geminiConfig = join15(HOME, ".gemini");
  let geminiDetected = false;
  let geminiVia = "";
  if (hasCmd("gemini")) {
    geminiDetected = true;
    geminiVia = "cli";
  } else if (existsSync11(geminiConfig)) {
    geminiDetected = true;
    geminiVia = "config";
  }
  if (geminiDetected) {
    tools.push({
      key: "gemini",
      name: "Gemini",
      configDir: geminiConfig,
      installed: isLoafInstalled(geminiConfig),
      detectedVia: geminiVia
    });
  }
  const ampConfig = join15(HOME, ".amp");
  let ampDetected = false;
  let ampVia = "";
  if (hasCmd("amp")) {
    ampDetected = true;
    ampVia = "cli";
  } else if (existsSync11(ampConfig)) {
    ampDetected = true;
    ampVia = "config";
  }
  if (ampDetected) {
    tools.push({
      key: "amp",
      name: "Amp",
      configDir: ampConfig,
      installed: isLoafInstalled(ampConfig),
      detectedVia: ampVia
    });
  }
  return tools;
}
var DEFAULT_CONFIG_DIRS = {
  opencode: join15(XDG_CONFIG_HOME, "opencode"),
  cursor: join15(HOME, ".cursor"),
  codex: process.env.CODEX_HOME || join15(HOME, ".codex"),
  gemini: join15(HOME, ".gemini"),
  amp: join15(HOME, ".amp")
};
function isDevMode(rootDir) {
  return existsSync11(join15(rootDir, ".git")) && existsSync11(join15(rootDir, "package.json")) && existsSync11(join15(rootDir, "content", "skills"));
}

// cli/lib/install/installer.ts
import {
  mkdirSync as mkdirSync10,
  cpSync as cpSync6,
  writeFileSync as writeFileSync10,
  rmSync as rmSync6,
  existsSync as existsSync12,
  readdirSync as readdirSync7,
  readFileSync as readFileSync11
} from "fs";
import { join as join16, dirname as dirname4 } from "path";
import { execFileSync as execFileSync2 } from "child_process";
import { fileURLToPath as fileURLToPath2 } from "url";
var LOAF_MARKER_FILE2 = ".loaf-version";
function getVersion2() {
  const __dirname7 = dirname4(fileURLToPath2(import.meta.url));
  for (const candidate of [
    join16(__dirname7, "..", "package.json"),
    join16(__dirname7, "..", "..", "package.json"),
    join16(__dirname7, "..", "..", "..", "package.json")
  ]) {
    try {
      const pkg = JSON.parse(readFileSync11(candidate, "utf-8"));
      if (pkg.name === "loaf") return pkg.version;
    } catch {
      continue;
    }
  }
  return "0.0.0";
}
function hasRsync() {
  try {
    execFileSync2("which", ["rsync"], { stdio: "ignore" });
    return true;
  } catch {
    return false;
  }
}
function syncDir(src, dest) {
  mkdirSync10(dest, { recursive: true });
  if (hasRsync()) {
    execFileSync2("rsync", ["-a", "--delete", `${src}/`, `${dest}/`], {
      stdio: "inherit"
    });
  } else {
    const entries = readdirSync7(dest);
    for (const entry of entries) {
      rmSync6(join16(dest, entry), { recursive: true, force: true });
    }
    cpSync6(src, dest, { recursive: true });
  }
}
function writeMarker(configDir) {
  mkdirSync10(configDir, { recursive: true });
  writeFileSync10(join16(configDir, LOAF_MARKER_FILE2), `${getVersion2()}
`);
}
function isLoafHook(hook) {
  const command = hook.command;
  return command?.startsWith("loaf check --hook") || false;
}
function loadHooksJson(path) {
  if (!existsSync12(path)) {
    return { version: 1, hooks: {} };
  }
  try {
    const content = readFileSync11(path, "utf-8");
    return JSON.parse(content);
  } catch {
    return { version: 1, hooks: {} };
  }
}
function saveHooksJson(path, hooks) {
  mkdirSync10(dirname4(path), { recursive: true });
  writeFileSync10(path, JSON.stringify(hooks, null, 2));
}
function installOpencode(distDir, configDir, _upgrade = false) {
  const dirs = ["skills", "agents", "commands", "plugins", "templates"];
  for (const dir of dirs) {
    const src = join16(distDir, dir);
    const dest = join16(configDir, dir);
    if (existsSync12(src)) {
      syncDir(src, dest);
    }
  }
  writeMarker(configDir);
}
function installCursor(distDir, configDir, upgrade = false) {
  const homeDir = process.env.HOME || process.env.USERPROFILE || "";
  const skillsDest = join16(homeDir, ".agents/skills");
  const skillsSrc = join16(distDir, "skills");
  if (existsSync12(skillsSrc)) {
    syncDir(skillsSrc, skillsDest);
  }
  const staleCommands = join16(configDir, "commands");
  if (existsSync12(staleCommands)) {
    rmSync6(staleCommands, { recursive: true });
  }
  const agentsSrc = join16(distDir, "agents");
  if (existsSync12(agentsSrc)) {
    syncDir(agentsSrc, join16(configDir, "agents"));
  }
  const hooksSrc = join16(distDir, "hooks.json");
  if (existsSync12(hooksSrc)) {
    const hooksPath = join16(configDir, "hooks.json");
    const existing = loadHooksJson(hooksPath);
    const loafHooks = loadHooksJson(hooksSrc);
    const merged = { version: 1, hooks: {} };
    const allHookTypes = /* @__PURE__ */ new Set([
      ...Object.keys(existing.hooks || {}),
      ...Object.keys(loafHooks.hooks || {})
    ]);
    for (const hookType of allHookTypes) {
      const existingHooks = existing.hooks?.[hookType] || [];
      const loafHooksList = loafHooks.hooks?.[hookType] || [];
      const userHooks = existingHooks.filter((h) => !isLoafHook(h));
      merged.hooks[hookType] = [...userHooks, ...loafHooksList];
    }
    saveHooksJson(hooksPath, merged);
  }
  const hooksDir = join16(distDir, "hooks");
  if (existsSync12(hooksDir)) {
    syncDir(hooksDir, join16(configDir, "hooks"));
  }
  const templatesSrc = join16(distDir, "templates");
  if (existsSync12(templatesSrc)) {
    syncDir(templatesSrc, join16(configDir, "templates"));
  }
  writeMarker(configDir);
}
