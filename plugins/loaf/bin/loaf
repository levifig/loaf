      }
      return file;
    }
    matter14.engines = engines2;
    matter14.stringify = function(file, data, options2) {
      if (typeof file === "string") file = matter14(file, options2);
      return stringify(file, data, options2);
    };
    matter14.read = function(filepath, options2) {
      const str2 = fs.readFileSync(filepath, "utf8");
      const file = matter14(str2, options2);
      file.path = filepath;
      return file;
    };
    matter14.test = function(str2, options2) {
      return utils.startsWith(str2, defaults(options2).delimiters[0]);
    };
    matter14.language = function(str2, options2) {
      const opts = defaults(options2);
      const open = opts.delimiters[0];
      if (matter14.test(str2)) {
        str2 = str2.slice(open.length);
      }
      const language = str2.slice(0, str2.search(/\r?\n/));
      return {
        raw: language,
        name: language ? language.trim() : ""
      };
    };
    matter14.cache = {};
    matter14.clearCache = function() {
      matter14.cache = {};
    };
    module2.exports = matter14;
  }
});

