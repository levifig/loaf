function readLoafConfig(projectRoot) {
  const p = join19(projectRoot, ".agents", "loaf.json");
  if (!existsSync14(p)) return {};
  try {
    const raw = readFileSync12(p, "utf-8");
    return JSON.parse(raw);
  } catch {
    return {};
  }
}
function mergeLoafConfigIntegrations(projectRoot, updates) {
  const agentsDir = join19(projectRoot, ".agents");
  const p = join19(agentsDir, "loaf.json");
  const existing = readLoafConfig(projectRoot);
  const integrations = {
    ...existing.integrations
  };
  if (updates.linear !== void 0) {
    integrations.linear = updates.linear;
  }
  if (updates.serena !== void 0) {
    integrations.serena = updates.serena;
  }
  const next = {
    ...existing,
    integrations
  };
  if (!existsSync14(agentsDir)) {
    mkdirSync13(agentsDir, { recursive: true });
  }
  writeFileSync12(p, `${JSON.stringify(next, null, 2)}
`, "utf-8");
}

// cli/lib/detect/mcp.ts
import { existsSync as existsSync15, readFileSync as readFileSync13 } from "fs";
import { execFileSync as execFileSync3 } from "child_process";
import { join as join20 } from "path";
function home() {
  return process.env.HOME || process.env.USERPROFILE || "";
}
function expandHome(p) {
  return p.startsWith("~/") ? join20(home(), p.slice(2)) : p;
}
var TARGET_MCP_CONFIGS = {
  "claude-code": {
    globalPaths: ["~/.claude/settings.json", "~/.claude/settings.local.json"],
    projectPaths: [".claude/settings.json", ".claude/settings.local.json", ".mcp.json"],
    mcpKey: "mcpServers",
