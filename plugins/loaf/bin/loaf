function substituteCommands(content) {
  return content.replace(/\{\{IMPLEMENT_CMD\}\}/g, "/implement").replace(/\{\{RESUME_CMD\}\}/g, "/resume").replace(/\{\{ORCHESTRATE_CMD\}\}/g, "/implement");
}
async function build2({
  config,
  targetsConfig,
  rootDir,
  srcDir,
  distDir
}) {
  const version = getVersion(rootDir);
  const transformMd = (content) => substituteCommands(content);
  resetTargetOutput(distDir);
  copySkills2(rootDir, srcDir, distDir, targetsConfig, transformMd, version);
  copyAgents2(srcDir, distDir, version);
  generateCommandsFromSkills(rootDir, distDir, version);
  generateRuntimePlugin(
    config,
    srcDir,
    distDir,
    OpenCodePlatform,
    version
  );
  const soulTemplateSrc = join10(srcDir, "templates", "soul.md");
  if (existsSync8(soulTemplateSrc)) {
    const templatesDir = join10(distDir, "templates");
    mkdirSync8(templatesDir, { recursive: true });
    cpSync4(soulTemplateSrc, join10(templatesDir, "soul.md"));
  }
  const hooksSrc = join10(srcDir, "hooks");
  if (existsSync8(hooksSrc)) {
    const hooksDest = join10(distDir, "plugins", "hooks");
    mkdirSync8(hooksDest, { recursive: true });
    cpSync4(hooksSrc, hooksDest, { recursive: true });
  }
}
function copySkills2(rootDir, srcDir, distDir, targetsConfig, transformMd, version) {
  const destDir = join10(distDir, "skills");
  mkdirSync8(destDir, { recursive: true });
  copySkills({
    srcDir: join10(rootDir, "dist"),
    // Reads from dist/skills/
    destDir,
    targetName: "opencode",
    version,
    targetsConfig,
    transformMd,
    mergeFrontmatter: (base, skillDir) => {
      const skillName = skillDir.split("/").pop() || "";
      const sidecarPath = join10(srcDir, "skills", skillName, "SKILL.opencode.yaml");
      if (existsSync8(sidecarPath)) {
        const sidecarContent = readFileSync8(sidecarPath, "utf-8");
        const sidecar = (0, import_yaml2.parse)(sidecarContent) || {};
        return { ...base, ...sidecar };
      }
      return base;
    }
  });
}
function copyAgents2(srcDir, distDir, version) {
  const destDir = join10(distDir, "agents");
  mkdirSync8(destDir, { recursive: true });
  copyAgents({
    srcDir,
    destDir,
    targetName: "opencode",
    version,
    sidecarRequired: false
  });
}
function generateCommandsFromSkills(rootDir, distDir, version) {
  const skillsSrc = join10(rootDir, "dist", "skills");
  const sidecarsSrc = join10(rootDir, "content", "skills");
  const commandsDest = join10(distDir, "commands");
  if (!existsSync8(skillsSrc)) return;
  mkdirSync8(commandsDest, { recursive: true });
  const skills = readdirSync5(skillsSrc, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name);
  for (const skill of skills) {
    const sidecarPath = join10(sidecarsSrc, skill, "SKILL.opencode.yaml");
    if (!existsSync8(sidecarPath)) continue;
    const skillMdPath = join10(skillsSrc, skill, "SKILL.md");
    if (!existsSync8(skillMdPath)) continue;
    const content = readFileSync8(skillMdPath, "utf-8");
    const { content: body, data: skillFrontmatter } = (0, import_gray_matter4.default)(content);
    const sidecarContent = readFileSync8(sidecarPath, "utf-8");
    const sidecar = (0, import_yaml2.parse)(sidecarContent) || {};
    const mergedFrontmatter = {
      description: skillFrontmatter.description || "",
      ...sidecar,
      version
    };
    const relinked = body.replace(/\]\(templates\//g, `](../skills/${skill}/templates/`).replace(/\]\(references\//g, `](../skills/${skill}/references/`);
    const transformed = substituteCommands(import_gray_matter4.default.stringify(relinked, mergedFrontmatter));
    writeFileSync7(join10(commandsDest, `${skill}.md`), transformed);
  }
}

