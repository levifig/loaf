// cli/lib/install/fenced-section.ts
import { readFileSync as readFileSync12, writeFileSync as writeFileSync11, mkdirSync as mkdirSync11 } from "fs";
import { join as join17, dirname as dirname5 } from "path";
import { fileURLToPath as fileURLToPath3 } from "url";
var FENCED_START = "<!-- loaf:managed:start";
var FENCED_END = "<!-- loaf:managed:end -->";
var FENCED_WARNING = "<!-- Maintained by loaf install/upgrade \u2014 do not edit manually -->";
var TARGET_FILES = {
  "claude-code": ".claude/CLAUDE.md",
  cursor: ".cursor/rules/loaf.mdc",
  // Always use .mdc for Cursor rules
  codex: ".agents/AGENTS.md",
  opencode: ".agents/AGENTS.md",
  amp: ".agents/AGENTS.md"
  // NOTE: gemini excluded - per SPEC-020, Gemini has no prompt overlay/project-file layer
};
function getVersion3() {
  const __dirname7 = dirname5(fileURLToPath3(import.meta.url));
  for (const candidate of [
    join17(__dirname7, "..", "..", "..", "package.json"),
    join17(__dirname7, "..", "..", "package.json"),
    join17(__dirname7, "..", "package.json")
  ]) {
    try {
      const pkg = JSON.parse(readFileSync12(candidate, "utf-8"));
      if (pkg.name === "loaf") return pkg.version;
    } catch {
      continue;
    }
  }
  return "0.0.0";
}
function findFencedSection(content) {
  const startIdx = content.indexOf(FENCED_START);
  if (startIdx === -1) return null;
  const endIdx = content.indexOf(FENCED_END, startIdx);
  if (endIdx === -1) return null;
  const startLine = content.substring(
    startIdx,
    content.indexOf("-->", startIdx) + 3
  );
  const versionMatch = startLine.match(/v([\d.]+(?:-[-\w.]+)?)/);
  const version = versionMatch ? versionMatch[1] : null;
  return {
    startIndex: startIdx,
    endIndex: endIdx + FENCED_END.length,
    version,
    content: content.substring(startIdx, endIdx + FENCED_END.length)
  };
}
function generateFencedContent(version) {
  return [
    `<!-- loaf:managed:start v${version} -->`,
    FENCED_WARNING,
    "## Loaf Framework",
    "",
    "**Session Journal Entry Types:**",
    "- `decide(scope)`: Key decisions with rationale",
    "- `discover(scope)`: Something learned",
    "- `block(scope)` / `unblock(scope)`: Blockers and resolutions",
    "- `spark(scope)`: Ideas to promote via `/idea`",
    "- `todo(scope)`: Action items to promote to tasks",
    "",
    "**CLI Commands:**",
    "- `loaf session start/end/log/archive` \u2014 Session management",
    "- `loaf check` \u2014 Run enforcement hooks",
    "- `loaf task/spec/kb` \u2014 Task and knowledge management",
    "",
    "See [orchestration skill](skills/orchestration/SKILL.md) for full details.",
    "<!-- loaf:managed:end -->"
  ].join("\n");
}
function resolveTargetFile(target, projectRoot) {
  const targetPath = TARGET_FILES[target];
  if (!targetPath) return null;
  return join17(projectRoot, targetPath);
}
function installFencedSection(targetFile, upgrade = false) {
  const currentVersion = getVersion3();
  let fileContent = "";
  let fileExisted = false;
  try {
    fileContent = readFileSync12(targetFile, "utf-8");
    fileExisted = true;
  } catch {
  }
  const fencedSection = findFencedSection(fileContent);
  if (fencedSection) {
    if (upgrade && fencedSection.version === currentVersion) {
      return { action: "skipped", version: currentVersion };
    }
    const before = fileContent.substring(0, fencedSection.startIndex);
    const after = fileContent.substring(fencedSection.endIndex);
    const newContent = generateFencedContent(currentVersion);
    const trimmedBefore = before.trimEnd();
    const trimmedAfter = after.trimStart();
    fileContent = trimmedBefore + (trimmedBefore ? "\n\n" : "") + newContent + (trimmedAfter ? "\n\n" : "\n") + trimmedAfter;
    writeFileSync11(targetFile, fileContent);
    return { action: "updated", version: currentVersion };
  } else {
    const newContent = generateFencedContent(currentVersion);
    if (fileExisted) {
      const trimmedContent = fileContent.trimEnd();
      fileContent = trimmedContent + (trimmedContent ? "\n\n" : "") + newContent + "\n";
      writeFileSync11(targetFile, fileContent);
      return { action: "appended", version: currentVersion };
    } else {
      mkdirSync11(dirname5(targetFile), { recursive: true });
      const isMdc = targetFile.endsWith(".mdc");
      const prefix = isMdc ? "---\ndescription: Loaf framework conventions\nalwaysApply: true\n---\n\n" : "";
      writeFileSync11(targetFile, prefix + newContent + "\n");
      return { action: "created", version: currentVersion };
    }
  }
}
function installFencedSectionsForTargets(targets, projectRoot = process.cwd(), upgrade = false) {
  const results = {};
  for (const target of targets) {
    const targetFile = resolveTargetFile(target, projectRoot);
    if (!targetFile) {
      results[target] = { action: "error", error: `Unknown target: ${target}` };
      continue;
    }
    try {
      const result = installFencedSection(targetFile, upgrade);
      results[target] = result;
    } catch (error) {
      const msg = error instanceof Error ? error.message : String(error);
      results[target] = { action: "error", error: msg };
    }
  }
  return results;
}

// cli/commands/install.ts
var __dirname2 = dirname6(fileURLToPath4(import.meta.url));
var bold2 = (s) => `\x1B[1m${s}\x1B[0m`;
var green2 = (s) => `\x1B[32m${s}\x1B[0m`;
var red2 = (s) => `\x1B[31m${s}\x1B[0m`;
var yellow = (s) => `\x1B[33m${s}\x1B[0m`;
var gray2 = (s) => `\x1B[90m${s}\x1B[0m`;
var white = (s) => `\x1B[97m${s}\x1B[0m`;
function findRootDir2() {
  let dir = __dirname2;
  for (let i = 0; i < 10; i++) {
    const pkgPath = join18(dir, "package.json");
    try {
      const pkg = JSON.parse(readFileSync13(pkgPath, "utf-8"));
      if (pkg.name === "loaf") return dir;
    } catch {
    }
    const parent = dirname6(dir);
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error("Could not find loaf root directory");
}
function askYesNo(question) {
  const rl = createInterface({
    input: process.stdin,
    output: process.stdout
  });
  return new Promise((resolve2) => {
    rl.question(question, (answer) => {
      rl.close();
      resolve2(answer.trim().toLowerCase().startsWith("y"));
    });
  });
}
function isLoafOnPath() {
  try {
    execSync("which loaf", { stdio: "pipe" });
    return true;
  } catch {
    return false;
  }
}
async function installLoafBinary(rootDir) {
  const localBinDir = join18(process.env.HOME || "~", ".local", "bin");
  const sourceBinary = join18(rootDir, "dist-cli", "index.js");
  const targetBinary = join18(localBinDir, "loaf");
  if (!existsSync14(sourceBinary)) {
    console.log(`  ${red2("\u2717")} CLI binary not found at ${sourceBinary}`);
    console.log(`  ${gray2("Run 'npm run build:cli' first.")}`);
    return false;
  }
  if (!existsSync14(localBinDir)) {
    try {
      mkdirSync12(localBinDir, { recursive: true });
      console.log(`  ${green2("\u2713")} Created ${localBinDir}`);
    } catch (err) {
      console.log(`  ${red2("\u2717")} Could not create ${localBinDir}: ${err}`);
      return false;
    }
  }
  if (existsSync14(targetBinary)) {
    try {
      unlinkSync(targetBinary);
    } catch {
    }
  }
  try {
    copyFileSync2(sourceBinary, targetBinary);
    chmodSync2(targetBinary, 493);
    console.log(`  ${green2("\u2713")} Installed loaf binary to ${targetBinary}`);
    const pathEnv = process.env.PATH || "";
    if (!pathEnv.includes(localBinDir)) {
      console.log(`  ${yellow("\u26A0")} ${localBinDir} is not on your PATH`);
      console.log(`  ${gray2("Add this to your shell profile:")}`);
      console.log(`  ${gray2(`  export PATH="${localBinDir}:$PATH"`)}`);
    }
    return true;
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    console.log(`  ${red2("\u2717")} Failed to install binary: ${msg}`);
    return false;
  }
}
var VALID_TARGETS = Object.keys(DEFAULT_CONFIG_DIRS);
function registerInstallCommand(program2) {
  program2.command("install").description("Install Loaf to detected AI tool configurations").option("--to <target>", 'Target to install to (or "all")').option("--upgrade", "Update only already-installed targets").action(async (options) => {
    const rootDir = findRootDir2();
    const distDir = join18(rootDir, "dist");
    const devMode = isDevMode(rootDir);
    console.log(`
${bold2("loaf install")}
`);
    const hasClaudeCode = detectClaudeCode();
    const tools = detectTools();
    if (hasClaudeCode) {
      console.log(`  ${green2("\u2713")} Claude Code detected`);
      if (devMode) {
        console.log(
          `    ${gray2("Test locally:")} ${white(`/plugin marketplace add ${rootDir}`)}`
        );
      } else {
        console.log(
          `    ${gray2("Install via:")} ${white("/plugin marketplace add levifig/loaf")}`
        );
      }
      console.log();
    }
    for (const tool of tools) {
      const status = tool.installed ? ` ${yellow("(installed)")}` : "";
      console.log(`  ${green2("\u2713")} ${tool.name} detected${status}`);
    }
    if (tools.length === 0 && !hasClaudeCode) {
      console.log(`  ${gray2("No AI tools detected")}`);
      console.log();
      return;
    }
    console.log();
    let selectedTargets;
    if (options.to === "all") {
      selectedTargets = tools.map((t) => t.key);
    } else if (options.to) {
      if (!VALID_TARGETS.includes(options.to) && options.to !== "all") {
        console.error(
          `${red2("error:")} Unknown target ${bold2(options.to)}
${gray2("Valid targets:")} ${VALID_TARGETS.join(", ")}, all`
        );
        process.exit(1);
      }
      const tool = tools.find((t) => t.key === options.to);
      selectedTargets = [options.to];
      if (!tool) {
        console.log(
          `  ${yellow("\u26A1")} ${options.to} was not auto-detected; installing to ${DEFAULT_CONFIG_DIRS[options.to]}`
        );
      }
    } else if (options.upgrade) {
      selectedTargets = tools.filter((t) => t.installed).map((t) => t.key);
      if (selectedTargets.length === 0) {
        if (hasClaudeCode) {
          const projectRoot2 = process.cwd();
          const fencedResults2 = installFencedSectionsForTargets(
            ["claude-code"],
            projectRoot2,
            options.upgrade ?? false
          );
          if (fencedResults2["claude-code"]?.action === "updated") {
            console.log(`  ${green2("\u2713")} claude-code updated Loaf framework section in project file`);
          } else if (fencedResults2["claude-code"]?.action === "skipped") {
            console.log(`  ${gray2("\u25CB")} claude-code Loaf framework section already current`);
          }
          console.log();
        }
        console.log(`  ${gray2("No installed targets to upgrade")}`);
        console.log();
        return;
      }
      console.log(`  ${gray2("Upgrading:")} ${selectedTargets.join(", ")}`);
    } else {
      selectedTargets = [];
      for (const tool of tools) {
        const status = tool.installed ? ` ${yellow("(installed)")}` : "";
        const yes = await askYesNo(
          `  Install to ${bold2(tool.name)}${status}? [y/N] `
        );
        if (yes) {
          selectedTargets.push(tool.key);
        }
      }
    }
    if (selectedTargets.length === 0) {
      if (hasClaudeCode) {
        const projectRoot2 = process.cwd();
        const fencedResults2 = installFencedSectionsForTargets(
          ["claude-code"],
          projectRoot2,
          options.upgrade ?? false
        );
        if (fencedResults2["claude-code"]?.action === "created") {
          console.log(`  ${green2("\u2713")} claude-code created project file with Loaf framework section`);
        } else if (fencedResults2["claude-code"]?.action === "appended") {
          console.log(`  ${green2("\u2713")} claude-code added Loaf framework section to project file`);
        } else if (fencedResults2["claude-code"]?.action === "updated") {
          console.log(`  ${green2("\u2713")} claude-code updated Loaf framework section in project file`);
        } else if (fencedResults2["claude-code"]?.action === "skipped") {
          console.log(`  ${gray2("\u25CB")} claude-code Loaf framework section already current`);
        }
        console.log();
      }
      console.log(`  ${gray2("No targets selected")}`);
      console.log();
      return;
    }
    const pathDependentTargets = ["opencode", "cursor", "codex", "amp"];
    const needsPathBinary = selectedTargets.some(
      (t) => pathDependentTargets.includes(t)
    );
    if (needsPathBinary && !isLoafOnPath()) {
      console.log(
        `  ${yellow("\u26A0")} Selected targets need 'loaf' on PATH but it's not available`
      );
      console.log(
        `  ${gray2("Targets:")} ${selectedTargets.filter((t) => pathDependentTargets.includes(t)).join(", ")}`
      );
      const shouldInstallBinary = await askYesNo(
        `  Install 'loaf' binary to ~/.local/bin? [y/N] `
      );
      if (shouldInstallBinary) {
        await installLoafBinary(rootDir);
        console.log();
      } else {
        console.log(
          `  ${gray2("Skipping binary installation. Some hooks may not work for PATH-dependent targets.")}`
        );
        console.log();
      }
    } else if (needsPathBinary) {
      console.log(`  ${green2("\u2713")} loaf binary available on PATH for target hooks`);
      console.log();
    }
    console.log();
    const installedTargets = [];
    for (const target of selectedTargets) {
      const tool = tools.find((t) => t.key === target);
      const configDir = tool?.configDir || DEFAULT_CONFIG_DIRS[target];
      const targetDistDir = join18(distDir, target);
      if (!existsSync14(targetDistDir)) {
        console.log(
          `  ${red2("\u2717")} ${target} \u2014 no build output found. Run ${bold2("loaf build")} first.`
        );
        continue;
      }
      const installer = INSTALLERS[target];
      if (!installer) {
        console.log(`  ${red2("\u2717")} ${target} \u2014 no installer available`);
        continue;
      }
      try {
        installer(targetDistDir, configDir, options.upgrade ?? false);
        console.log(`  ${green2("\u2713")} ${target} installed to ${gray2(configDir)}`);
        installedTargets.push(target);
      } catch (error) {
        const msg = error instanceof Error ? error.message : String(error);
        console.log(`  ${red2("\u2717")} ${target} \u2014 ${msg}`);
      }
    }
    console.log();
    const projectRoot = process.cwd();
    const targetsWithFencedSections = installedTargets.filter((t) => t !== "gemini");
    const fencedTargets = hasClaudeCode ? ["claude-code", ...targetsWithFencedSections] : [...targetsWithFencedSections];
    const fencedResults = installFencedSectionsForTargets(
      fencedTargets,
      projectRoot,
      options.upgrade ?? false
    );
    let hasFencedOutput = false;
    for (const [target, result] of Object.entries(fencedResults)) {
      if (result.action === "error") {
        console.log(
          `  ${red2("\u2717")} ${target} project file \u2014 ${result.error}`
        );
        hasFencedOutput = true;
      } else if (result.action === "created") {
        console.log(
          `  ${green2("\u2713")} ${target} created project file with Loaf framework section`
        );
        hasFencedOutput = true;
      } else if (result.action === "appended") {
        console.log(
          `  ${green2("\u2713")} ${target} added Loaf framework section to project file`
        );
        hasFencedOutput = true;
      } else if (result.action === "updated") {
        console.log(
          `  ${green2("\u2713")} ${target} updated Loaf framework section in project file (v${result.version})`
        );
        hasFencedOutput = true;
      } else if (result.action === "skipped") {
        console.log(
          `  ${gray2("\u25CB")} ${target} Loaf framework section already current (v${result.version})`
        );
        hasFencedOutput = true;
      }
    }
    if (hasFencedOutput) {
      console.log();
    }
  });
}

