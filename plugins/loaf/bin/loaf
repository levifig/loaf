import { mkdirSync as mkdirSync9, writeFileSync as writeFileSync9 } from "fs";
import { join as join11 } from "path";
var TARGET_NAME3 = "codex";
var ENFORCEMENT_HOOKS2 = /* @__PURE__ */ new Set([
  "check-secrets",
  "validate-push",
  "validate-commit",
  "workflow-pre-pr",
  "security-audit"
]);
async function build4({
  config,
  rootDir,
  distDir,
  targetsConfig
}) {
  const version = getVersion(rootDir);
  const transformMd = (content) => content;
  const mergeFrontmatter = (base, skillDir) => {
    const sidecar = loadTargetSkillSidecar(skillDir, TARGET_NAME3);
    return { ...base, ...sidecar };
  };
  copySkills({
    srcDir: join11(rootDir, "dist"),
    // Read from dist/skills/ intermediate
    destDir: join11(distDir, "skills"),
    targetName: TARGET_NAME3,
    version,
    targetsConfig,
    transformMd,
    mergeFrontmatter
  });
  generateCodexHooksJson(config, distDir);
}
function generateCodexHooksJson(config, distDir) {
  const preToolHooks = config.hooks["pre-tool"] || [];
  const enforcementHooks = preToolHooks.filter((hook) => {
    if (!ENFORCEMENT_HOOKS2.has(hook.id)) return false;
    const matcher = hook.matcher || "";
    return matcher.includes("Bash");
  });
  if (enforcementHooks.length === 0) {
    return;
  }
  const hooksJson = {
    version: 1,
    hooks: {}
  };
  const hooks = hooksJson.hooks;
  hooks.PreToolUse = enforcementHooks.map((hook) => {
    const result = {
      matcher: "Bash",
      command: `loaf check --hook ${hook.id}`,
      timeout: Math.floor((hook.timeout || 3e4) / 1e3),
      failClosed: hook.failClosed !== false
      // Default to true for enforcement
    };
    if (hook.description) {
      result.description = hook.description;
    }
    return result;
  });
  const codexDir = join11(distDir, ".codex");
  mkdirSync9(codexDir, { recursive: true });
  writeFileSync9(
    join11(codexDir, "hooks.json"),
    JSON.stringify(hooksJson, null, 2)
  );
}

