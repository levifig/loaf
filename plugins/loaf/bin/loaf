function substituteCommands2(content) {
  return content.replace(/\{\{IMPLEMENT_CMD\}\}/g, "/implement").replace(/\{\{RESUME_CMD\}\}/g, "/resume").replace(/\{\{ORCHESTRATE_CMD\}\}/g, "/implement");
}
async function build3({
  config,
  targetConfig,
  targetsConfig,
  rootDir,
  srcDir,
  distDir
}) {
  const version = getVersion(rootDir);
  const transformMd = (content) => substituteCommands2(content);
  const skillsDir = join10(distDir, "skills");
  const agentsDir = join10(distDir, "agents");
  const hooksDir = join10(distDir, "hooks");
  const staleCommandsDir = join10(distDir, "commands");
  if (existsSync8(staleCommandsDir)) {
    rmSync3(staleCommandsDir, { recursive: true });
  }
  for (const dir of [skillsDir, agentsDir, hooksDir]) {
    if (existsSync8(dir)) rmSync3(dir, { recursive: true });
    mkdirSync8(dir, { recursive: true });
  }
  copySkills({
    srcDir: join10(rootDir, "dist"),
    destDir: skillsDir,
    targetName: TARGET_NAME2,
    version,
    targetsConfig,
    transformMd,
    extraDirs: ["assets"],
    mergeFrontmatter: (base, skillDir) => {
      const sidecarFrontmatter = loadTargetSkillSidecar(skillDir, TARGET_NAME2);
      return injectVersion({ ...base, ...sidecarFrontmatter }, version);
    }
  });
  copyAgents({
    srcDir,
    destDir: agentsDir,
    targetName: TARGET_NAME2,
    version,
    sidecarRequired: false,
    defaults: DEFAULT_AGENT_FRONTMATTER
  });
  copyHooks(srcDir, hooksDir);
  generateHooksJson(config, distDir);
  const soulTemplateSrc = join10(srcDir, "templates", "soul.md");
  if (existsSync8(soulTemplateSrc)) {
    const templatesDir = join10(distDir, "templates");
    mkdirSync8(templatesDir, { recursive: true });
    cpSync5(soulTemplateSrc, join10(templatesDir, "soul.md"));
  }
}
function copyHooks(srcDir, destDir) {
  const hooksSrc = join10(srcDir, "hooks");
  if (!existsSync8(hooksSrc)) return;
  const subdirs = ["session", "lib", "instructions"];
  for (const subdir of subdirs) {
    const subSrc = join10(hooksSrc, subdir);
    const subDest = join10(destDir, subdir);
    if (existsSync8(subSrc)) {
      mkdirSync8(subDest, { recursive: true });
      copyHookFiles(subSrc, subDest);
    }
  }
  const entries = readdirSync6(hooksSrc, { withFileTypes: true });
  for (const entry of entries) {
    if (entry.isFile()) {
      cpSync5(join10(hooksSrc, entry.name), join10(destDir, entry.name));
    }
  }
}
function copyHookFiles(srcDir, destDir) {
  const entries = readdirSync6(srcDir, { withFileTypes: true });
  const cursorOverrides = /* @__PURE__ */ new Set();
  for (const entry of entries) {
    if (entry.isFile() && entry.name.endsWith(".cursor.sh")) {
      cursorOverrides.add(entry.name.replace(".cursor.sh", ".sh"));
    }
  }
  for (const entry of entries) {
    if (entry.isDirectory()) {
      const subSrc = join10(srcDir, entry.name);
      const subDest = join10(destDir, entry.name);
      mkdirSync8(subDest, { recursive: true });
      copyHookFiles(subSrc, subDest);
    } else if (entry.isFile()) {
      if (entry.name.endsWith(".cursor.sh")) {
        const destName = entry.name.replace(".cursor.sh", ".sh");
        cpSync5(join10(srcDir, entry.name), join10(destDir, destName));
      } else if (!cursorOverrides.has(entry.name)) {
        cpSync5(join10(srcDir, entry.name), join10(destDir, entry.name));
      }
    }
  }
}
function mapSessionEvent(event) {
  const mapping = {
    SessionStart: "sessionStart",
    SessionEnd: "sessionEnd",
    PreCompact: "preCompact",
    Stop: "stop"
  };
  return mapping[event] || event.toLowerCase();
}
function getCursorHookCommand(hook) {
  if (BINARY_PATH_HOOKS2.has(hook.id)) {
    if (!hook.command) {
      return `loaf check --hook ${hook.id}`;
    }
    return hook.command;
  }
  if (hook.command) {
    return hook.command;
  }
  const scriptPath = hook.script.replace(/^hooks\//, "");
  const basePath = "$HOME/.cursor/hooks";
  if (hook.script.endsWith(".py")) {
    return `python3 ${basePath}/${scriptPath}`;
  } else if (hook.script.endsWith(".ts")) {
    return `bun run ${basePath}/${scriptPath}`;
  }
  return `bash ${basePath}/${scriptPath}`;
}
function generateHooksJson(config, distDir) {
  const preToolHooks = config.hooks["pre-tool"] || [];
  const postToolHooks = config.hooks["post-tool"] || [];
  const sessionHooks = config.hooks.session || [];
  const hooksJson = {
    version: 1,
    hooks: {}
  };
  const hooks = hooksJson.hooks;
  if (preToolHooks.length > 0) {
    hooks.preToolUse = preToolHooks.map((hook) => {
      const result = {
        timeout: Math.floor((hook.timeout || 6e4) / 1e3),
        ...hook.matcher && { matcher: hook.matcher },
        ...hook.failClosed && { failClosed: hook.failClosed }
      };
      if (hook.type === "prompt") {
        if (hook.prompt) result.prompt = hook.prompt;
      } else {
        result.command = getCursorHookCommand(hook);
      }
      if (hook.if) result.if = hook.if;
      return result;
    });
  }
  if (postToolHooks.length > 0) {
    hooks.postToolUse = postToolHooks.map((hook) => {
      const result = {
        timeout: 30,
        ...hook.matcher && { matcher: hook.matcher },
        ...hook.failClosed && { failClosed: hook.failClosed }
      };
      if (hook.type === "prompt") {
        if (hook.prompt) result.prompt = hook.prompt;
      } else {
        result.command = getCursorHookCommand(hook);
      }
      if (hook.if) result.if = hook.if;
      return result;
    });
  }
  for (const hook of sessionHooks) {
    const eventName = mapSessionEvent(hook.event || "");
    if (!hooks[eventName]) hooks[eventName] = [];
    const result = {
      timeout: Math.floor((hook.timeout || 6e4) / 1e3)
    };
    if (hook.type === "prompt") {
      if (hook.prompt) result.prompt = hook.prompt;
    } else {
      result.command = getCursorHookCommand(hook);
    }
    if (hook.if) result.if = hook.if;
    if (hook.failClosed) result.failClosed = hook.failClosed;
    hooks[eventName].push(result);
  }
  writeFileSync8(
    join10(distDir, "hooks.json"),
    JSON.stringify(hooksJson, null, 2)
  );
}

// cli/lib/build/targets/codex.ts
var codex_exports = {};
