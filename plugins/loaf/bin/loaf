// cli/lib/build/lib/shared-templates.ts
import { existsSync as existsSync2, readFileSync as readFileSync3, writeFileSync, mkdirSync } from "fs";
import { join as join3 } from "path";
function copySharedTemplates(skillName, skillDest, srcDir, targetsConfig, transformFn) {
  const sharedTemplates = targetsConfig?.["shared-templates"] || {};
  for (const [templateFile, skills] of Object.entries(sharedTemplates)) {
    if (!Array.isArray(skills) || !skills.includes(skillName)) {
      continue;
    }
    const templateSrc = join3(srcDir, "templates", templateFile);
    if (!existsSync2(templateSrc)) {
      continue;
    }
    const templatesDest = join3(skillDest, "templates");
    const destPath = join3(templatesDest, templateFile);
    if (existsSync2(destPath)) {
      continue;
    }
    mkdirSync(templatesDest, { recursive: true });
    let content = readFileSync3(templateSrc, "utf-8");
    if (transformFn && templateFile.endsWith(".md")) {
      content = transformFn(content);
    }
    writeFileSync(destPath, content);
  }
}

// cli/lib/build/lib/copy-utils.ts
import {
  mkdirSync as mkdirSync2,
  cpSync,
  writeFileSync as writeFileSync2,
  readFileSync as readFileSync4,
  readdirSync,
  existsSync as existsSync3
} from "fs";
import { join as join4 } from "path";
function copyDirWithTransform(srcDir, destDir, transformMd) {
  mkdirSync2(destDir, { recursive: true });
  const entries = readdirSync(srcDir, { withFileTypes: true });
  for (const entry of entries) {
    const srcPath = join4(srcDir, entry.name);
    const destPath = join4(destDir, entry.name);
    if (entry.isDirectory()) {
      copyDirWithTransform(srcPath, destPath, transformMd);
    } else if (entry.name.endsWith(".md")) {
      const content = readFileSync4(srcPath, "utf-8");
      writeFileSync2(destPath, transformMd(content));
    } else {
      cpSync(srcPath, destPath);
    }
  }
}
function discoverSkills(srcDir) {
  const skillsDir = join4(srcDir, "skills");
  if (!existsSync3(skillsDir)) return [];
  return readdirSync(skillsDir).filter((f) => {
    const skillPath = join4(skillsDir, f);
    return existsSync3(join4(skillPath, "SKILL.md")) || existsSync3(join4(skillPath, "references"));
  });
}

// cli/lib/build/lib/skills.ts
function copySkills(options) {
  const {
    srcDir,
    destDir,
    version,
    targetsConfig,
    transformMd,
    extraDirs = [],
    mergeFrontmatter
  } = options;
  const src = join5(srcDir, "skills");
  if (!existsSync4(src)) return;
  const skills = readdirSync2(src, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name);
  for (const skill of skills) {
    const skillSrc = join5(src, skill);
    const skillDest = join5(destDir, skill);
    mkdirSync3(skillDest, { recursive: true });
    let frontmatter = loadSkillFrontmatter(skillSrc);
    if (mergeFrontmatter) {
      frontmatter = mergeFrontmatter(frontmatter, skillSrc);
    }
    if (version !== void 0) {
      frontmatter = { ...frontmatter, version };
    }
    const skillMdPath = join5(skillSrc, "SKILL.md");
    if (existsSync4(skillMdPath)) {
      const content = readFileSync5(skillMdPath, "utf-8");
      const { content: body } = matter2(content);
      writeFileSync3(
        join5(skillDest, "SKILL.md"),
        transformMd(matter2.stringify(body, frontmatter))
      );
    }
    for (const subdir of ["references", "templates"]) {
      const subSrc = join5(skillSrc, subdir);
      if (existsSync4(subSrc)) {
        copyDirWithTransform(subSrc, join5(skillDest, subdir), transformMd);
      }
    }
    const scriptsSrc = join5(skillSrc, "scripts");
    if (existsSync4(scriptsSrc)) {
      cpSync2(scriptsSrc, join5(skillDest, "scripts"), { recursive: true });
    }
    for (const extraDir of extraDirs) {
      const extraSrc = join5(skillSrc, extraDir);
      if (existsSync4(extraSrc)) {
        cpSync2(extraSrc, join5(skillDest, extraDir), { recursive: true });
      }
    }
    copySharedTemplates(skill, skillDest, srcDir, targetsConfig, transformMd);
  }
}

// cli/lib/build/lib/agents.ts
import {
  writeFileSync as writeFileSync4,
  readFileSync as readFileSync6,
  existsSync as existsSync5,
  readdirSync as readdirSync3
} from "fs";
import matter3 from "gray-matter";
import { join as join6 } from "path";
function copyAgents(options) {
  const {
    srcDir,
    destDir,
    targetName,
    version,
    defaults = {},
    sidecarRequired = false
  } = options;
  const src = join6(srcDir, "agents");
  if (!existsSync5(src)) return;
  const files = readdirSync3(src).filter((f) => f.endsWith(".md"));
  for (const file of files) {
    const srcPath = join6(src, file);
    const destPath = join6(destDir, file);
    const agentName = file.replace(".md", "");
    const content = readFileSync6(srcPath, "utf-8");
    const { content: body, data: sourceFrontmatter } = matter3(content);
    const sidecarFrontmatter = sidecarRequired ? loadAgentSidecar(srcPath, targetName) : loadAgentSidecarOptional(srcPath, targetName);
    const mergedFrontmatter = {
      ...defaults,
      name: sourceFrontmatter.name || agentName,
      description: sourceFrontmatter.description || `${agentName} agent for specialized tasks`,
      ...sidecarFrontmatter
    };
    const bodyWithFooter = body.trim() + `

---
version: ${version}
`;
    writeFileSync4(destPath, matter3.stringify(bodyWithFooter, mergedFrontmatter));
  }
}

// cli/lib/build/lib/commands.ts
function createCommandSubstituter(targetName) {
  void targetName;
  return (content) => {
    return content.replace(/\{\{IMPLEMENT_CMD\}\}/g, "/implement").replace(/\{\{RESUME_CMD\}\}/g, "/implement").replace(/\{\{ORCHESTRATE_CMD\}\}/g, "/implement");
  };
}

