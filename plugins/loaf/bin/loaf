function getTargetMcpConfig(target) {
  return TARGET_MCP_CONFIGS[target];
}
var SERENA_BASE_ARGS = [
  "uvx",
  "-p",
  "3.13",
  "--from",
  "git+https://github.com/oraios/serena",
  "serena",
  "start-mcp-server"
];
var MCP_REGISTRY = [
  {
    id: "linear",
    displayName: "Linear",
    tier: "recommended",
    defaultArgs: ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
    manualHint: "npx -y mcp-remote https://mcp.linear.app/mcp"
  },
  {
