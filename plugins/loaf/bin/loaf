function isLoafInstalled(configDir) {
  if (existsSync11(join16(configDir, LOAF_MARKER_FILE))) {
    return true;
  }
  const skillsDir = join16(configDir, "skills");
  for (const skill of ["foundations", "python-development", "python"]) {
