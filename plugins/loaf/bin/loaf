async function buildTarget2(targetName, rootDir, contentDir, distDir, hooksConfig, targetsConfig) {
  const targetModule = TARGETS2[targetName];
  if (!targetModule) {
    throw new Error(`Unknown target: ${targetName}`);
  }
  const outputDir = targetName === "claude-code" ? rootDir : join35(distDir, targetName);
  const targetConfig = targetsConfig.targets?.[targetName] || {};
  await targetModule.build({
    config: hooksConfig,
    targetConfig,
    targetsConfig,
    rootDir,
    srcDir: contentDir,
    distDir: outputDir,
    targetName
  });
}
function runInstall(rootDir) {
  const distDir = join35(rootDir, "dist");
  const devMode = isDevMode(rootDir);
  const hasClaudeCode = detectClaudeCode();
  const tools = detectTools();
  const installed = [];
  const failed = [];
  if (hasClaudeCode) {
    if (devMode) {
      console.log(
        `  ${green9("\u2713")} Claude Code detected ${gray10("(test via")} ${white2(`/plugin marketplace add ${rootDir}`)}${gray10(")")}`
      );
    } else {
      console.log(
        `  ${green9("\u2713")} Claude Code detected ${gray10("(install via")} ${white2("/plugin marketplace add levifig/loaf")}${gray10(")")}`
      );
    }
  }
  const selectedTargets = tools.map((t) => t.key);
  for (const target of selectedTargets) {
    const tool = tools.find((t) => t.key === target);
    const configDir = tool?.configDir || DEFAULT_CONFIG_DIRS[target];
    const targetDistDir = join35(distDir, target);
    if (!existsSync30(targetDistDir)) {
      console.log(
        `  ${red7("\u2717")} ${target} \u2014 no build output found`
      );
      failed.push(target);
      continue;
    }
    const installer = INSTALLERS[target];
    if (!installer) {
      console.log(`  ${red7("\u2717")} ${target} \u2014 no installer available`);
      failed.push(target);
      continue;
    }
    try {
      installer(targetDistDir, configDir);
      console.log(
        `  ${green9("\u2713")} ${target} installed to ${gray10(configDir)}`
      );
      installed.push(target);
    } catch (error) {
      const msg = error instanceof Error ? error.message : String(error);
      console.log(`  ${red7("\u2717")} ${target} \u2014 ${msg}`);
      failed.push(target);
    }
  }
  return { installed, failed, claudeCodeDetected: hasClaudeCode };
}
function registerSetupCommand(program3) {
  program3.command("setup").description(
    "One-step bootstrap: init + build + install"
  ).argument("[path]", "Directory to set up (created if it does not exist)").action(async (pathArg) => {
    console.log(`
${bold9("loaf setup")}
`);
    if (pathArg) {
      const targetDir = resolve(pathArg);
      if (existsSync30(targetDir)) {
        const stat = statSync(targetDir);
        if (!stat.isDirectory()) {
          console.error(
            `  ${red7("error:")} Path exists but is not a directory: ${targetDir}`
          );
          process.exit(1);
        }
        console.log(
          `  ${gray10("\xB7")} ${gray10(targetDir)} already exists`
        );
      } else {
        mkdirSync20(targetDir, { recursive: true });
        console.log(
          `  ${green9("\u2713")} Created ${gray10(targetDir)}`
        );
      }
      process.chdir(targetDir);
      console.log();
    }
    const cwd = process.cwd();
    console.log(`  ${cyan7("init")} Scaffolding project structure...`);
    const dirs = scaffoldDirs2(cwd);
    const files = scaffoldFiles2(cwd);
    const allSkipped = [...dirs.skipped, ...files.skipped];
    if (dirs.created.length > 0 || files.created.length > 0) {
      for (const dir of dirs.created) {
        console.log(`    ${green9("+")} ${dir}`);
      }
      for (const file of files.created) {
        console.log(`    ${green9("+")} ${file}`);
      }
    } else if (allSkipped.length === 0) {
      console.log(`    ${gray10("Nothing to create \u2014 all files exist")}`);
    }
    if (allSkipped.length > 0) {
      console.log(`    ${yellow11("Skipped")} (paths resolve outside project root):`);
      for (const path of allSkipped) {
        console.log(`      ${yellow11("!")} ${path}`);
      }
    }
    console.log();
    console.log(`  ${cyan7("build")} Compiling skills and agents...`);
    let rootDir;
    try {
      rootDir = findRootDir3();
    } catch (error) {
      const msg = error instanceof Error ? error.message : String(error);
      console.error(`
  ${red7("error:")} ${msg}`);
      process.exit(1);
    }
    const contentDir = join35(rootDir, "content");
    const configDir = join35(rootDir, "config");
    const distDir = join35(rootDir, "dist");
    const hooksConfigPath = join35(configDir, "hooks.yaml");
    if (!existsSync30(hooksConfigPath)) {
      console.error(
        `
  ${red7("error:")} Hooks config not found: ${hooksConfigPath}`
      );
      process.exit(1);
    }
    const hooksConfig = loadYamlConfig2(hooksConfigPath);
    const targetsConfig = loadYamlConfig2(
      join35(configDir, "targets.yaml")
    );
    let buildFailed = false;
    for (const targetName of TARGET_NAMES2) {
      const targetStart = Date.now();
      try {
        await buildTarget2(
          targetName,
          rootDir,
          contentDir,
          distDir,
          hooksConfig,
          targetsConfig
        );
        const elapsed = ((Date.now() - targetStart) / 1e3).toFixed(2);
        console.log(
          `    ${green9("\u2713")} ${targetName} ${gray10(`(${elapsed}s)`)}`
        );
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        console.log(`    ${red7("\u2717")} ${targetName}`);
        console.error(`      ${red7(message)}`);
        buildFailed = true;
      }
    }
    if (buildFailed) {
      console.error(`
  ${red7("Build failed. Stopping setup.")}`);
      process.exit(1);
    }
    console.log();
    console.log(`  ${cyan7("install")} Distributing to detected tools...`);
    const installResult = runInstall(rootDir);
    if (installResult.failed.length > 0) {
      console.error(
        `
  ${red7("Install failed for:")} ${installResult.failed.join(", ")}`
      );
      process.exit(1);
    }
    if (installResult.installed.length === 0 && !installResult.claudeCodeDetected) {
      console.log(`    ${gray10("No AI tools detected")}`);
    }
    console.log();
    console.log(
      `  ${green9("\u2713")} Setup complete. Run ${bold9("/bootstrap")} in Claude Code to set up your project.`
    );
    console.log();
  });
}

// cli/commands/version.ts
var import_yaml5 = __toESM(require_dist(), 1);
import { existsSync as existsSync31, readFileSync as readFileSync26, readdirSync as readdirSync12 } from "fs";
import { join as join36, dirname as dirname10 } from "path";
import { fileURLToPath as fileURLToPath6 } from "url";
var __dirname4 = dirname10(fileURLToPath6(import.meta.url));
var bold10 = (s) => `\x1B[1m${s}\x1B[0m`;
var gray11 = (s) => `\x1B[90m${s}\x1B[0m`;
var TARGET_OUTPUTS = {
  "claude-code": "plugins/loaf/",
  cursor: "dist/cursor/",
  opencode: "dist/opencode/",
  codex: "dist/codex/",
  gemini: "dist/gemini/"
};
function findRootDir4() {
  let dir = __dirname4;
  for (let i = 0; i < 10; i++) {
    const pkgPath = join36(dir, "package.json");
    try {
      const pkg = JSON.parse(readFileSync26(pkgPath, "utf-8"));
      if (pkg.name === "loaf") return dir;
    } catch {
    }
    const parent = dirname10(dir);
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error("Could not find loaf root directory");
}
function getVersion4(rootDir) {
  try {
    const pkg = JSON.parse(readFileSync26(join36(rootDir, "package.json"), "utf-8"));
    return pkg.version || "0.0.0";
  } catch {
    return "0.0.0";
  }
}
function countSkills(rootDir) {
  const skillsDir = join36(rootDir, "content", "skills");
  if (!existsSync31(skillsDir)) return 0;
  return readdirSync12(skillsDir, { withFileTypes: true }).filter((entry) => entry.isDirectory()).length;
}
function countAgents(rootDir) {
  const agentsDir = join36(rootDir, "content", "agents");
  if (!existsSync31(agentsDir)) return 0;
  return readdirSync12(agentsDir).filter((name) => name.endsWith(".md")).length;
}
function countHooks(rootDir) {
  const hooksPath = join36(rootDir, "config", "hooks.yaml");
  if (!existsSync31(hooksPath)) return 0;
  try {
    const config = (0, import_yaml5.parse)(readFileSync26(hooksPath, "utf-8"));
    const hooks = config?.hooks;
    if (!hooks) return 0;
    return (hooks["pre-tool"]?.length ?? 0) + (hooks["post-tool"]?.length ?? 0) + (hooks.session?.length ?? 0);
  } catch {
    return 0;
  }
}
function getBuiltTargets(rootDir) {
  const built = [];
  for (const [name, relPath] of Object.entries(TARGET_OUTPUTS)) {
    if (existsSync31(join36(rootDir, relPath))) {
      built.push({ name, path: relPath });
    }
  }
  return built;
}
function registerVersionCommand(program3) {
  program3.command("version").description("Show version info and project statistics").action(() => {
    const rootDir = findRootDir4();
    const version = getVersion4(rootDir);
    console.log(`
${bold10("loaf")} ${version}`);
    console.log(`${gray11("node")} ${process.version}`);
    const targets = getBuiltTargets(rootDir);
    if (targets.length > 0) {
      console.log(`
${bold10("Targets:")}`);
      const maxName = Math.max(...targets.map((t) => t.name.length));
      for (const target of targets) {
        console.log(`  ${target.name.padEnd(maxName + 2)}${gray11(target.path)}`);
      }
    }
    const skills = countSkills(rootDir);
    const agents = countAgents(rootDir);
    const hooks = countHooks(rootDir);
    console.log(`
${bold10("Content:")}`);
    console.log(`  Skills:  ${skills}`);
    console.log(`  Agents:  ${agents}`);
    console.log(`  Hooks:   ${hooks}`);
    console.log();
  });
}

// cli/commands/housekeeping.ts
var import_gray_matter12 = __toESM(require_gray_matter(), 1);
