var __dirname6 = dirname14(fileURLToPath9(import.meta.url));
function getVersion5() {
  for (const candidate of [join41(__dirname6, "..", "package.json"), join41(__dirname6, "..", "..", "package.json")]) {
    try {
      const pkg = JSON.parse(readFileSync31(candidate, "utf-8"));
      if (pkg.name === "loaf") return pkg.version;
    } catch {
      continue;
    }
  }
  return "0.0.0";
}
