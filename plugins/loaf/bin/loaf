function findSpecForBranch(agentsDir, branch) {
  const specsDir = join40(agentsDir, "specs");
  if (!existsSync35(specsDir)) return null;
  const files = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
  for (const file of files) {
    try {
      const content = readFileSync30(join40(specsDir, file), "utf-8");
      const parsed = (0, import_gray_matter13.default)(content);
      const fm = parsed.data;
      if (fm.branch === branch) {
        return {
          id: fm.id || file.replace(/\.md$/, ""),
          title: fm.title || "Untitled",
          sessionFile: fm.session
        };
      }
    } catch {
      continue;
    }
  }
  return null;
}
function updateSpecSessionField(agentsDir, specId, sessionFileName) {
  const specsDir = join40(agentsDir, "specs");
  if (!existsSync35(specsDir)) return;
  const files = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
  for (const file of files) {
    if (file.includes(specId)) {
      const filePath = join40(specsDir, file);
      try {
        const content = readFileSync30(filePath, "utf-8");
        const parsed = (0, import_gray_matter13.default)(content);
        if (parsed.data.session !== sessionFileName) {
          parsed.data.session = sessionFileName;
          const newContent = import_gray_matter13.default.stringify(parsed.content, parsed.data);
          writeFileSync21(filePath, newContent, "utf-8");
        }
      } catch {
      }
      break;
    }
  }
}
function getSessionFilePath(agentsDir) {
  return join40(agentsDir, "sessions", `${getTimestampForFilename()}-session.md`);
}
function getTimestampForFilename() {
  const now = /* @__PURE__ */ new Date();
  const year = now.getFullYear();
  const month = String(now.getMonth() + 1).padStart(2, "0");
  const day = String(now.getDate()).padStart(2, "0");
  const hour = String(now.getHours()).padStart(2, "0");
  const minute = String(now.getMinutes()).padStart(2, "0");
  const second = String(now.getSeconds()).padStart(2, "0");
  return `${year}${month}${day}-${hour}${minute}${second}`;
}
function findActiveSessionForBranch(agentsDir, branch) {
  const sessionsDir = join40(agentsDir, "sessions");
  if (!existsSync35(sessionsDir)) return null;
  const files = readdirSync14(sessionsDir).filter((f) => f.endsWith(".md") && !f.startsWith("archive"));
  const candidates = [];
  for (const file of files) {
    const filePath = join40(sessionsDir, file);
    const session = readSessionFile(filePath);
    if (session && session.data.branch === branch && session.data.status !== "archived") {
      candidates.push({ filePath, data: session.data, content: session.content });
    }
  }
  if (candidates.length === 0) {
    let parentBranch = null;
    try {
      const reflogOutput = execSync3(`git reflog show --format='%H %gs' ${branch} 2>/dev/null | head -10`, { encoding: "utf-8" });
      const renamedMatch = reflogOutput.match(/Branch: renamed refs\/heads\/([^\s]+) to/);
      if (renamedMatch) {
        parentBranch = renamedMatch[1];
      }
    } catch {
    }
    if (parentBranch) {
      const specsDir = join40(agentsDir, "specs");
      if (existsSync35(specsDir)) {
        const specFiles = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
        for (const specFile of specFiles) {
          try {
            const specPath = join40(specsDir, specFile);
            const specContent = readFileSync30(specPath, "utf-8");
            const specParsed = (0, import_gray_matter13.default)(specContent);
            const specFm = specParsed.data;
            if (specFm.branch === parentBranch && specFm.session) {
              const sessionPath = join40(agentsDir, "sessions", specFm.session);
              if (existsSync35(sessionPath)) {
                const session = readSessionFile(sessionPath);
                if (session && session.data.branch === parentBranch && session.data.status !== "archived") {
                  session.data.branch = branch;
                  const newSessionContent = import_gray_matter13.default.stringify(session.content, session.data);
                  writeFileSync21(sessionPath, newSessionContent, "utf-8");
                  specFm.branch = branch;
                  const newSpecContent = import_gray_matter13.default.stringify(specParsed.content, specFm);
                  writeFileSync21(specPath, newSpecContent, "utf-8");
                  candidates.push({ filePath: sessionPath, data: session.data, content: session.content });
                  break;
                }
              }
            }
          } catch {
            continue;
          }
        }
      }
    }
  }
  if (candidates.length === 0) return null;
  const statusPriority = {
    active: 1,
    paused: 2,
    blocked: 2,
    complete: 2
  };
  candidates.sort((a, b) => {
    const priorityA = statusPriority[a.data.status] ?? 3;
    const priorityB = statusPriority[b.data.status] ?? 3;
    if (priorityA !== priorityB) {
      return priorityA - priorityB;
    }
    const timeA = a.data.last_updated || a.data.last_entry || "0";
    const timeB = b.data.last_updated || b.data.last_entry || "0";
    return timeB.localeCompare(timeA);
  });
  return candidates[0];
}
async function getOrCreateSession(agentsDir, branch, specInfo) {
  const sessionsDir = join40(agentsDir, "sessions");
  const lockPath = join40(sessionsDir, `.create-${branch.replace(/[^a-zA-Z0-9-]/g, "-")}.lock`);
  await acquireLock(lockPath, 100, 50);
  try {
    const existing = findActiveSessionForBranch(agentsDir, branch);
    if (existing) {
      return { ...existing, isNew: false };
    }
    const filePath = getSessionFilePath(agentsDir);
    createSessionFile(filePath, branch, specInfo);
    const session = readSessionFile(filePath);
    return { filePath, data: session.data, content: session.content, isNew: true };
  } finally {
    releaseLock(lockPath);
  }
}
function readSessionFile(filePath) {
  if (!existsSync35(filePath)) return null;
  try {
    const raw = readFileSync30(filePath, "utf-8");
    const parsed = (0, import_gray_matter13.default)(raw);
    const rawData = parsed.data;
    if (rawData.session && typeof rawData.session === "object") {
      const nested = rawData.session;
      const migratedData = { ...rawData };
      delete migratedData.session;
      for (const [key, value] of Object.entries(nested)) {
        migratedData[key] = value;
      }
      return {
        data: migratedData,
        content: parsed.content
      };
    }
    return {
      data: rawData,
      content: parsed.content
    };
  } catch {
    return null;
  }
}
function parseEntry(entry) {
  const match = entry.match(/^([a-z]+)(?:\(([^)]+)\))?:\s*(.+)$/);
  if (!match) return null;
  const [, type, scope, description] = match;
  const validTypes = [
    "start",
    "resume",
    "pause",
    "progress",
    "commit",
    "pr",
    "merge",
    "decision",
    "discover",
    "conclude",
    "block",
    "unblock",
    "spark",
    "todo",
    "assume",
    // New types
    "branch",
    "task",
    "linear",
    "hypothesis",
    "try",
    "reject",
    "compact",
    "skill"
  ];
  if (!validTypes.includes(type)) return null;
  return {
    type,
    scope,
    description
  };
}
function getTimestamp() {
  return (/* @__PURE__ */ new Date()).toISOString();
}
function getDateTimeString() {
  const now = /* @__PURE__ */ new Date();
  const date = now.toISOString().split("T")[0];
  const time = now.toTimeString().split(":")[0] + ":" + now.toTimeString().split(":")[1];
  return `${date} ${time}`;
}
function createSessionFile(filePath, branch, specInfo) {
  if (existsSync35(filePath)) {
    return null;
  }
  const now = getTimestamp();
  const frontmatter = {
    branch,
    status: "active",
    created: now,
    last_entry: now
  };
  if (specInfo?.id) {
    frontmatter.spec = specInfo.id;
  }
  const title = specInfo ? `${specInfo.id}: ${specInfo.title}` : branch;
  const entry = `[${getDateTimeString()}] start: SESSION STARTED`;
  const body = `# Session: ${title}

## Current State

*No state summary yet \u2014 updated by PreCompact or /wrap.*

## Journal

${entry}
`;
  const content = import_gray_matter13.default.stringify(body, frontmatter);
  try {
    const fd = openSync(filePath, "wx");
    writeFileSync21(fd, content, "utf-8");
    closeSync(fd);
  } catch {
    return null;
  }
  return frontmatter;
}
async function appendEntry(filePath, entryLines, updateFrontmatter) {
  const lockPath = `${filePath}.lock`;
  await acquireLock(lockPath);
  try {
    const session = readSessionFile(filePath);
    if (!session) {
      throw new Error("Session file not found");
    }
    updateFrontmatter(session.data);
    const trimmedContent = session.content.trimEnd();
    const hasNewSession = entryLines.some(
      (line) => /\] (?:start|resume)[:(]/.test(line)
    );
    const separator = hasNewSession ? "\n\n" : "\n";
    const newContent = import_gray_matter13.default.stringify(
      trimmedContent + separator + entryLines.join("\n") + "\n",
      session.data
    );
    writeFileAtomic(filePath, newContent);
  } finally {
    releaseLock(lockPath);
  }
}
function extractRecentEntries(content, count = 15) {
  const lines = content.split("\n");
  const entries = [];
  const entryPattern = /^\[\d{4}-\d{2}-\d{2} \d{2}:\d{2}\] /;
  for (const line of lines) {
    if (entryPattern.test(line)) {
      entries.push(line.trim());
    }
  }
  return entries.slice(-count);
}
function extractDecisionEntries(content) {
  const entries = [];
  const lines = content.split("\n");
  for (const line of lines) {
    if (line.match(/^\[\d{4}-\d{2}-\d{2} \d{2}:\d{2}\] decision\([^)]+\):/)) {
      entries.push(line.trim());
    }
  }
  return entries;
}
function persistDecisionsToSpec(agentsDir, specId, decisionEntries, sessionBranch) {
  const specsDir = join40(agentsDir, "specs");
  if (!existsSync35(specsDir)) {
    return { success: false, message: "No specs directory found" };
  }
  const specFiles = readdirSync14(specsDir).filter((f) => f.endsWith(".md"));
  const specFile = specFiles.find((f) => f.includes(specId));
  if (!specFile) {
    return { success: false, message: `Spec ${specId} not found` };
  }
  const specPath = join40(specsDir, specFile);
  const specContent = readFileSync30(specPath, "utf-8");
  const changelogMatch = specContent.match(/\n## Changelog\n/);
  const dateStr = (/* @__PURE__ */ new Date()).toISOString().split("T")[0];
  const entryHeader = `- ${dateStr} \u2014 Session ${sessionBranch} archived: ${decisionEntries.length} decision(s) extracted`;
  let updatedContent;
  if (changelogMatch) {
    const insertPos = changelogMatch.index + changelogMatch[0].length;
    const decisionsList = decisionEntries.map((e) => `  ${e}`).join("\n");
    const entry = `${entryHeader}
${decisionsList}

`;
    updatedContent = specContent.slice(0, insertPos) + entry + specContent.slice(insertPos);
  } else {
    const decisionsList = decisionEntries.map((e) => `  ${e}`).join("\n");
    const entry = `
## Changelog

${entryHeader}
${decisionsList}
`;
    updatedContent = specContent + entry;
  }
  writeFileSync21(specPath, updatedContent, "utf-8");
  return { success: true, message: `Appended to ${specFile}` };
}
function countTasksInSession(content) {
  const completed = (content.match(/- \[x\]/gi) || []).length;
  const total = (content.match(/- \[[ x]\]/gi) || []).length;
  return { completed, total };
}
function countJournalActivity(content) {
  const systemTypes = /* @__PURE__ */ new Set(["start", "resume", "pause", "progress", "conclude"]);
  const pattern = /^\[\d{4}-\d{2}-\d{2} \d{2}:\d{2}\] (\w+)\(/gm;
  let commits = 0;
  let decisions = 0;
  let entries = 0;
  let match;
  while ((match = pattern.exec(content)) !== null) {
    const type = match[1];
    if (systemTypes.has(type)) continue;
    entries++;
    if (type === "commit") commits++;
    if (type === "decision") decisions++;
  }
  return { commits, decisions, entries };
}
function buildProgressLine(stats) {
  const parts = [];
  if (stats.total > 0) parts.push(`${stats.completed}/${stats.total} tasks`);
  if (stats.commits > 0) parts.push(`${stats.commits} commits`);
  if (stats.decisions > 0) parts.push(`${stats.decisions} decisions`);
  const other = stats.entries - stats.commits - stats.decisions;
  if (other > 0) parts.push(`${other} entries`);
  return parts.length > 0 ? parts.join(", ") : "no activity logged";
}
function quickArchiveSession(filePath, agentsDir) {
  const archiveDir = join40(agentsDir, "sessions", "archive");
  if (!existsSync35(archiveDir)) {
    mkdirSync22(archiveDir, { recursive: true });
  }
  try {
    const session = readSessionFile(filePath);
    if (session) {
      session.data.status = "archived";
      session.data.archived_at = getTimestamp();
      const content = import_gray_matter13.default.stringify(session.content, session.data);
      writeFileSync21(filePath, content, "utf-8");
    }
    renameSync3(filePath, join40(archiveDir, basename5(filePath)));
  } catch {
  }
}
