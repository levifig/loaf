{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook artifact-body-write",
            "timeout": 30,
            "description": "Block direct .agents artifact body writes that bypass SQLite registration",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook check-secrets",
            "timeout": 30,
            "description": "Check for hardcoded secrets before writing",
            "failClosed": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook security-audit",
            "timeout": 600,
            "description": "Run security audit on bash commands",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook render-drift",
            "if": "Bash(git push:*)",
            "timeout": 30,
            "description": "Validate stamped durable renders are self-consistent before push",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook ephemeral-provenance",
            "if": "Bash(git push:*)",
            "timeout": 30,
            "description": "Block active specs from pointing at deleted ephemeral Markdown after cutover",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook github-account",
            "timeout": 10,
            "description": "Switch the active GitHub account to project config before gh commands; block only if the switch fails",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook validate-push --advisory",
            "if": "Bash(git push:*)",
            "timeout": 60,
            "description": "Validates version bump, CHANGELOG, and build before git push"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook workflow-pre-pr --advisory",
            "if": "Bash(gh pr create:*)",
            "timeout": 5,
            "description": "Remind about PR format and CHANGELOG entry before gh pr create"
          },
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions/pre-merge.md\"",
            "if": "Bash(gh pr merge:*)",
            "timeout": 5,
            "description": "Remind about squash merge conventions before gh pr merge"
          },
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions/pre-push.md\"",
            "if": "Bash(git push:*)",
            "timeout": 5,
            "description": "Advisory reminders before git push"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook validate-commit",
            "if": "Bash(git commit:*)",
            "timeout": 30,
            "description": "Validate commit messages follow conventions",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" journal log --detect-linear",
            "if": "Bash(git commit:*)",
            "timeout": 30,
            "description": "Detect Linear magic words for auto-status updates"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" task refresh",
            "description": "Regenerate TASKS.md when task files change",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/kb-staleness-nudge.sh",
            "description": "Track covered edits and nudge when covered knowledge is stale",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions/post-merge.md\"",
            "if": "Bash(gh pr merge:*)",
            "description": "Inject housekeeping checklist after a gh pr merge hook; command matching does not prove success",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "description": "Emit the layered continuity digest at conversation start",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" journal context --from-hook --claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "description": "Inject implementation conventions on prompt submit",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" journal context for-prompt"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 60,
            "description": "Inject journal flush guidance before compaction",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" journal context for-compact"
          }
        ]
      }
    ]
  }
}