{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook check-secrets",
            "timeout": 30,
            "description": "Check for hardcoded secrets before writing",
            "failClosed": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook security-audit",
            "timeout": 600,
            "description": "Run security audit on bash commands",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook validate-push",
            "if": "Bash(git push:*)",
            "timeout": 60,
            "description": "Validates version bump, CHANGELOG, and build before git push"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook workflow-pre-pr",
            "if": "Bash(gh pr create:*)",
            "timeout": 5,
            "description": "Remind about PR format and CHANGELOG entry before gh pr create"
          },
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions/pre-merge.md\"",
            "if": "Bash(gh pr merge:*)",
            "timeout": 5,
            "description": "Remind about squash merge conventions before gh pr merge"
          },
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions/pre-push.md\"",
            "if": "Bash(git push:*)",
            "timeout": 5,
            "description": "Advisory reminders before git push"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" check --hook validate-commit",
            "if": "Bash(git commit:*)",
            "timeout": 30,
            "description": "Validate commit messages follow conventions",
            "failClosed": true
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" session log --detect-linear",
            "if": "Bash(git commit:*)",
            "timeout": 30,
            "description": "Detect Linear magic words for auto-status updates"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" task refresh",
            "description": "Regenerate TASKS.md when task files change",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/kb-staleness-nudge.sh",
            "description": "Track covered edits and nudge when covered knowledge is stale",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/instructions/post-merge.md\"",
            "if": "Bash(gh pr merge:*)",
            "description": "Inject housekeeping checklist after successful gh pr merge",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "loaf session log --from-hook",
            "if": "Bash(git commit:*)",
            "description": "Auto-log git commits to session journal",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "loaf session log --from-hook",
            "if": "Bash(gh pr:*)",
            "description": "Auto-log GitHub PR events (create, merge) to session journal",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "description": "Start session journal and surface session context",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" session start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "description": "End session with progress summary and KB follow-up",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" session end --if-active"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "description": "Auto-log task completion or cancellation to session journal",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" session log --from-hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "description": "Inject session context and implementation conventions on prompt submit",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" session context for-prompt"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 60,
            "description": "Log compact marker and inject journal flush instructions before compaction",
            "command": "loaf session context for-compact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 60,
            "description": "Print session state, spec, journal, and git context for post-compaction resumption",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/loaf\" session context for-resumption"
          }
        ]
      }
    ]
  }
}